---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = "発酵とローフードのクロス理論に基づくプレミアムスクール。東京・渋谷（表参道）。",
  canonical,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = false,
  lang = "ja",
} = Astro.props;

const siteUrl = "https://www.andlabtokyo.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = title.includes("&LAB TOKYO") ? title : `${title} | &LAB TOKYO`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex
      ? <meta name="robots" content="noindex,nofollow" />
      : <meta name="robots" content="index,follow" />
    }
    <!-- OGP -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="&LAB TOKYO" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://static.wixstatic.com/media/745f65_5f8a0988e14b437298642730a9117f7b%7Emv2.png" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <!-- JSON-LD -->
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"EducationalOrganization","name":"&LAB TOKYO","url":"https://www.andlabtokyo.com","logo":"https://www.andlabtokyo.com/logo-wide.svg","description":"発酵とローフードのクロス理論に基づくプレミアムスクール。東京・渋谷（表参道）。","address":{"@type":"PostalAddress","streetAddress":"5-2-11 Jingumae, Shibuya-ku","addressLocality":"渋谷区","addressRegion":"東京都","postalCode":"150-0001","addressCountry":"JP"},"founder":{"@type":"Person","name":"安藤千英"},"sameAs":["https://www.instagram.com/chie_andlab/"]}</script>
    <slot name="head" />

    <style is:global>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      /* ================================================
         DESIGN TOKENS
      ================================================ */
      :root {
        --bg:    #FAF9F6;
        --ink:   #1C1C1A;
        /* extended palette for pages */
        --f-serif: 'Noto Serif JP', serif;
        --f-sans:  'Noto Sans JP', sans-serif;
        --fh:      'Cormorant Garamond', serif;
        --linen:   #FAF9F6;
        --linen-2: #F5F3EE;
        --linen-3: rgba(28,28,26,0.09);
        --ink-2:   #3C3C3A;
        --ink-3:   #8C8C8A;
        --divider: rgba(28,28,26,0.09);
        --sumi:    #1A1715;
        --sumi-2:  #1E1B19;
        --bg-card: #24211E;
        --bg-dark: #110E0B;
        --amber:   #C6A15B;
        --amber-d: #A8865A;
        --green:     #6B9A3A;
        --green-d:   #4A7A1E;
        --green-btn: #4D7C2A;
      }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Noto Serif JP', serif;
        line-height: 1.8;
        -webkit-font-smoothing: antialiased;
      }

      /* ================================================
         HEADER
      ================================================ */
      .site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 900;
        padding: 1.6rem 4rem;
        background: rgba(250,249,246,0.93);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(0,0,0,0.05);
      }
      .header-logo {
        height: 36px;
        width: auto;
        display: block;
      }

      /* ================================================
         DESKTOP NAV
      ================================================ */
      .site-nav {
        display: none; /* hidden on mobile, shown ≥1024px */
        gap: 2.5rem;
        align-items: center;
      }

      /* Plain link (About) */
      .site-nav > a {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7A7A72;
        text-decoration: none;
        transition: color 0.25s;
        white-space: nowrap;
      }
      .site-nav > a:hover { color: var(--ink); }

      /* Contact button */
      .nav-contact-btn {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
        padding: 0.5rem 1.4rem;
        border: 1px solid rgba(28,28,26,0.22);
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
      }
      .nav-contact-btn:hover { background: var(--ink); color: #FAF9F6; }

      /* ---- Dropdown item ---- */
      .nav-item {
        position: relative;
        cursor: pointer;
        padding: 0.6rem 0;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7A7A72;
        white-space: nowrap;
        user-select: none;
      }
      .nav-item:hover { color: var(--ink); }

      .nav-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: #fff;
        min-width: 260px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: opacity 0.25s, transform 0.25s, visibility 0.25s;
        box-shadow: 0 12px 40px rgba(0,0,0,0.07);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 1.2rem 0;
        z-index: 1000;
      }
      .nav-item:hover .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .nav-dropdown a {
        display: block;
        padding: 0.7rem 1.8rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        letter-spacing: 0.1em;
        color: #7A7A72;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        white-space: nowrap;
      }
      .nav-dropdown a:hover {
        background: var(--bg);
        color: var(--ink);
      }
      .nav-dropdown a.dd-footer {
        margin-top: 0.4rem;
        padding-top: 0.9rem;
        border-top: 1px solid rgba(0,0,0,0.05);
        font-weight: 500;
        letter-spacing: 0.12em;
      }

      /* ================================================
         HAMBURGER + MOBILE MENU
      ================================================ */
      .hamburger {
        display: flex;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
        background: none;
        border: none;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--ink);
        transition: all 0.3s;
      }

      .mobile-menu {
        display: none;
        position: fixed;
        top: 73px; left: 0; right: 0;
        background: #fff;
        border-top: 1px solid rgba(0,0,0,0.05);
        z-index: 899;
        max-height: calc(100vh - 73px);
        overflow-y: auto;
      }
      .mobile-menu.open { display: block; }
      .mob-section {
        border-bottom: 1px solid rgba(0,0,0,0.05);
      }
      .mob-section-title {
        display: block;
        padding: 0.9rem 1.5rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink);
        background: #FAF9F6;
      }
      .mob-section a {
        display: block;
        padding: 0.75rem 2rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 12px;
        letter-spacing: 0.08em;
        color: #5A5A58;
        text-decoration: none;
        border-bottom: 1px solid rgba(0,0,0,0.03);
      }
      .mob-section a:last-child { border-bottom: none; }
      .mob-contact {
        display: block;
        margin: 1.2rem 1.5rem 1.5rem;
        padding: 0.8rem;
        background: var(--ink);
        color: #FAF9F6;
        text-align: center;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 12px;
        letter-spacing: 0.15em;
        text-decoration: none;
        text-transform: uppercase;
      }

      /* ================================================
         MAIN + FOOTER
      ================================================ */
      main { padding-top: 73px; }

      .site-footer {
        background: var(--bg);
        padding: 5rem 4rem;
        border-top: 1px solid rgba(0,0,0,0.05);
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
      }
      .footer-logo {
        height: 24px;
        width: auto;
        display: block;
        margin-bottom: 0.9rem;
        opacity: 0.55;
      }
      .footer-left p {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        color: #7A7A72;
        letter-spacing: 0.1em;
        line-height: 1.9;
      }
      .footer-right { text-align: right; }
      .footer-right p {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        color: #7A7A72;
        letter-spacing: 0.1em;
        line-height: 1.9;
      }
      .footer-map {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        color: #7A7A72;
        text-decoration: none;
        border-bottom: 1px solid #7A7A72;
        display: inline-block;
        margin-top: 0.3rem;
        transition: color 0.2s, border-color 0.2s;
      }
      .footer-map:hover { color: var(--ink); border-color: var(--ink); }
      .footer-links {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.3rem;
        margin-top: 1rem;
      }
      .footer-links a {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.12em;
        color: #BDBDB5;
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-links a:hover { color: #7A7A72; }
      .footer-copy {
        margin-top: 3rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        color: rgba(28,28,26,0.18);
        letter-spacing: 0.2em;
        text-align: center;
        text-transform: uppercase;
      }

      /* ================================================
         RESPONSIVE
      ================================================ */
      @media (min-width: 1024px) {
        .site-nav  { display: flex; }
        .hamburger { display: none; }
      }
      @media (max-width: 1023px) {
        .site-header { padding: 1.2rem 1.5rem; }
      }
      @media (max-width: 767px) {
        .site-footer { padding: 3.5rem 1.5rem; }
        .footer-inner { flex-direction: column; align-items: flex-start; }
        .footer-right { text-align: left; }
        .footer-links { align-items: flex-start; flex-direction: row; flex-wrap: wrap; gap: 0.8rem; }
      }
    </style>
  </head>

  <body>
    <!-- ===== HEADER ===== -->
    <header class="site-header">
      <a href="/" aria-label="&LAB TOKYO ホーム">
        <img
          src="/logo-wide.svg"
          alt="&LAB TOKYO"
          class="header-logo"
          onerror="this.outerHTML='<span style=\'font-family:Noto Serif JP,serif;font-size:13px;letter-spacing:.2em;color:#1C1C1A\'>&LAB TOKYO</span>'"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="site-nav" role="navigation" aria-label="メインナビゲーション">

        <!-- 各種講座 ▾ -->
        <div class="nav-item">
          各種講座 ▾
          <div class="nav-dropdown">
            <a href="/experiencelessons">体験レッスン</a>
            <a href="/rawfood-kentei-meister">ローフードマイスター講座</a>
            <a href="/fermentedfood">発酵プランナー講座</a>
            <a href="/professional-training">プロ養成</a>
            <a href="/rawchocolatier/rawchocolatemeister">ローチョコレートマイスター</a>
            <a href="/rawchocolatier/rawpatissier">ローパティシエ養成</a>
            <a href="/koji-fermentation-experience-tokyo">UMAMI &amp; KOJI LAB</a>
            <a href="/trial-fermentation">トライアルレッスン「発酵」</a>
            <a href="/plating-creator">プレイティングクリエイター</a>
            <a href="/listofcourses" class="dd-footer">▶ 全講座一覧</a>
          </div>
        </div>

        <!-- Association ▾ -->
        <div class="nav-item">
          Association ▾
          <div class="nav-dropdown">
            <a href="/rawchocolatier/rawchocolatier-course">ローショコラティエ</a>
            <a href="/rawchocolatier/rawchocolateconcierge">ローチョコレートコンシェルジュ</a>
            <a href="/rawchocolatier/online-lesson">オンラインレッスン</a>
            <a href="/rawchocolatier/faq">よくある質問</a>
            <a href="/rawchocolatier/about-association">協会概要</a>
            <a href="/rawchocolatier" class="dd-footer">▶ 協会トップ</a>
          </div>
        </div>

        <!-- Knowledge ▾ -->
        <div class="nav-item">
          Knowledge ▾
          <div class="nav-dropdown">
            <a href="/rawfood">ローフードとは</a>
            <a href="/fermentedfood">発酵とは</a>
            <a href="/livingfood">リビングフードとは</a>
            <a href="/rawchocolatier/rawchocolate">ローチョコレートとは</a>
            <a href="/rawchocolatier/whatrawsweets">ロースイーツとは</a>
            <a href="/spirulina">スピルリナとは</a>
            <a href="/knowledge" class="dd-footer">▶ ナレッジ一覧</a>
          </div>
        </div>

        <!-- About (plain link) -->
        <a href="/brand">About</a>

        <!-- Contact (button) -->
        <a href="/contact" class="nav-contact-btn">Contact</a>
      </nav>

      <!-- Hamburger -->
      <button class="hamburger" id="hamburger" aria-label="メニューを開く">
        <span></span><span></span><span></span>
      </button>
    </header>

    <!-- ===== MOBILE MENU ===== -->
    <div class="mobile-menu" id="mobileMenu">
      <div class="mob-section">
        <span class="mob-section-title">各種講座</span>
        <a href="/experiencelessons">体験レッスン</a>
        <a href="/rawfood-kentei-meister">ローフードマイスター講座</a>
        <a href="/fermentedfood">発酵プランナー講座</a>
        <a href="/professional-training">プロ養成</a>
        <a href="/rawchocolatier/rawchocolatemeister">ローチョコレートマイスター</a>
        <a href="/rawchocolatier/rawpatissier">ローパティシエ養成</a>
        <a href="/koji-fermentation-experience-tokyo">UMAMI &amp; KOJI LAB</a>
        <a href="/listofcourses">全講座一覧 →</a>
      </div>
      <div class="mob-section">
        <span class="mob-section-title">Association</span>
        <a href="/rawchocolatier/rawchocolatier-course">ローショコラティエ</a>
        <a href="/rawchocolatier/rawchocolateconcierge">コンシェルジュ</a>
        <a href="/rawchocolatier/faq">よくある質問</a>
        <a href="/rawchocolatier">協会トップ →</a>
      </div>
      <div class="mob-section">
        <span class="mob-section-title">Knowledge</span>
        <a href="/rawfood">ローフードとは</a>
        <a href="/fermentedfood">発酵とは</a>
        <a href="/livingfood">リビングフードとは</a>
        <a href="/rawchocolatier/rawchocolate">ローチョコレートとは</a>
        <a href="/spirulina">スピルリナとは</a>
        <a href="/knowledge">ナレッジ一覧 →</a>
      </div>
      <div class="mob-section">
        <span class="mob-section-title">About</span>
        <a href="/brand">About &amp;LAB TOKYO</a>
        <a href="/instructor-chie-ando">安藤千英 プロフィール</a>
        <a href="/beginner">はじめての方へ</a>
        <a href="/media">活動・メディア</a>
      </div>
      <a href="/contact" class="mob-contact">Contact お問い合わせ</a>
    </div>

    <!-- ===== MAIN ===== -->
    <main>
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-left">
          <img
            src="/logo-wide.svg"
            alt="&LAB TOKYO"
            class="footer-logo"
            onerror="this.outerHTML='<span style=\'font-family:Noto Serif JP,serif;font-size:12px;letter-spacing:.2em;color:#7A7A72;display:block;margin-bottom:0.9rem;opacity:.55\'>&LAB TOKYO</span>'"
          />
          <p>Raw Food &amp; Fermentation School</p>
          <p>Tokyo · Shibuya, Japan</p>
        </div>
        <div class="footer-right">
          <p>5-2-11 Jingumae, Shibuya-ku,</p>
          <p>Tokyo 150-0001, Japan</p>
          <a
            href="https://www.google.com/maps/search/&LAB+TOKYO+渋谷"
            target="_blank"
            rel="noopener"
            class="footer-map"
          >Google Map</a>
          <div class="footer-links">
            <a href="/listofcourses">Courses</a>
            <a href="/rawchocolatier">協会</a>
            <a href="/knowledge">Knowledge</a>
            <a href="/brand">About</a>
            <a href="/contact">Contact</a>
            <a href="/tokushoho">特定商取引法</a>
          </div>
        </div>
      </div>
      <p class="footer-copy">&copy; 2026 &LAB TOKYO. All rights reserved.</p>
    </footer>

    <script>
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobileMenu');
      hamburger?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('open');
        const spans = hamburger.querySelectorAll('span');
        if (mobileMenu?.classList.contains('open')) {
          spans[0].style.transform = 'translateY(6.5px) rotate(45deg)';
          spans[1].style.opacity = '0';
          spans[2].style.transform = 'translateY(-6.5px) rotate(-45deg)';
        } else {
          spans.forEach((s: HTMLElement) => { s.style.transform = ''; s.style.opacity = ''; });
        }
      });
      mobileMenu?.querySelectorAll('a').forEach((a: HTMLElement) => {
        a.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          hamburger?.querySelectorAll('span').forEach((s: HTMLElement) => {
            s.style.transform = ''; s.style.opacity = '';
          });
        });
      });
    </script>
  </body>
</html>
