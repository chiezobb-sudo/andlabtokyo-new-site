---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = "東京・渋谷のローフード・発酵料理教室 &LAB TOKYO。ELLE gourmet認定料理家・安藤千英が主宰するローショコラティエ協会本部。",
  canonical,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = false,
  lang = "ja",
} = Astro.props;

const siteUrl = "https://www.andlabtokyo.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = title.includes("&LAB TOKYO") ? title : `${title} | &LAB TOKYO`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

  <!-- OGP -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="&LAB TOKYO" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" href="https://static.wixstatic.com/media/745f65_5f8a0988e14b437298642730a9117f7b%7Emv2.png" type="image/png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />

  <!-- JSON-LD -->
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"EducationalOrganization","name":"&LAB TOKYO","url":"https://www.andlabtokyo.com","description":"東京・渋谷のローフード・発酵料理教室。ローショコラティエ協会本部。","founder":{"@type":"Person","name":"安藤千英"},"sameAs":["https://www.instagram.com/chie_andlab/"]}</script>

  <slot name="head" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Serif JP', serif;
      background: #FAF9F6;
      color: #1C1C1A;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    /* ================================================
       HEADER & NAV
    ================================================ */
    .site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      background: rgba(250,249,246,0.97);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(28,28,26,0.07);
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
    }

    .header-logo {
      height: 36px;
      width: auto;
      display: block;
      flex-shrink: 0;
    }

    /* --- Desktop Nav --- */
    .site-nav {
      display: flex;
      align-items: center;
      gap: 0;
      height: 64px;
    }

    .nav-item {
      position: relative;
      height: 64px;
      display: flex;
      align-items: center;
    }

    .nav-label {
      display: flex;
      align-items: center;
      gap: 4px;
      height: 64px;
      padding: 0 1rem;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      color: #3C3C3A;
      text-decoration: none;
      white-space: nowrap;
      cursor: pointer;
      transition: color 0.2s;
      border-bottom: 2px solid transparent;
    }
    .nav-label:hover { color: #1C1C1A; border-bottom-color: #1C1C1A; }
    .nav-label svg { width: 10px; height: 10px; opacity: 0.5; transition: transform 0.2s; }
    .nav-item:hover .nav-label svg { transform: rotate(180deg); }

    /* --- Dropdown --- */
    .nav-dropdown {
      position: absolute;
      top: 64px;
      left: 0;
      min-width: 220px;
      background: #fff;
      border: 1px solid rgba(28,28,26,0.08);
      border-top: 2px solid #1C1C1A;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px);
      transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
      z-index: 200;
    }
    .nav-item:hover .nav-dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .nav-dropdown a {
      display: block;
      padding: 0.65rem 1.2rem;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #4A4A48;
      text-decoration: none;
      letter-spacing: 0.04em;
      border-bottom: 1px solid rgba(28,28,26,0.05);
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { background: #FAF9F6; color: #1C1C1A; }

    /* Contact button */
    .nav-contact {
      margin-left: 0.5rem;
      padding: 0.5rem 1.2rem;
      background: #1C1C1A;
      color: #FAF9F6 !important;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-decoration: none;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .nav-contact:hover { background: #3C3C3A !important; color: #FAF9F6 !important; }

    /* --- Hamburger (mobile) --- */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
      background: none;
      border: none;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: #1C1C1A;
      transition: all 0.3s;
    }

    /* Mobile menu */
    .mobile-menu {
      display: none;
      position: fixed;
      top: 64px; left: 0; right: 0;
      background: #fff;
      border-top: 1px solid rgba(28,28,26,0.08);
      overflow-y: auto;
      max-height: calc(100vh - 64px);
      z-index: 999;
    }
    .mobile-menu.open { display: block; }
    .mobile-section { border-bottom: 1px solid rgba(28,28,26,0.07); }
    .mobile-section-title {
      display: block;
      padding: 1rem 1.5rem;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: #1C1C1A;
      background: #FAF9F6;
    }
    .mobile-section a {
      display: block;
      padding: 0.75rem 2rem;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      color: #4A4A48;
      text-decoration: none;
      border-bottom: 1px solid rgba(28,28,26,0.04);
    }
    .mobile-contact-link {
      display: block;
      margin: 1.5rem;
      padding: 0.9rem;
      background: #1C1C1A;
      color: #FAF9F6 !important;
      text-align: center;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-decoration: none;
    }

    /* ================================================
       MAIN
    ================================================ */
    main { padding-top: 64px; }

    /* ================================================
       FOOTER
    ================================================ */
    .site-footer {
      background: #1C1C1A;
      color: rgba(250,249,246,0.6);
      padding: 5rem 2rem 3rem;
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 4rem;
    }
    .footer-col-title {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(250,249,246,0.35);
      display: block;
      margin-bottom: 1.2rem;
    }
    .footer-col a {
      display: block;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px;
      color: rgba(250,249,246,0.55);
      text-decoration: none;
      margin-bottom: 0.6rem;
      transition: color 0.2s;
    }
    .footer-col a:hover { color: rgba(250,249,246,0.9); }
    .footer-bottom {
      max-width: 1100px;
      margin: 0 auto;
      padding-top: 2rem;
      border-top: 1px solid rgba(250,249,246,0.08);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
    .footer-logo-white { height: 28px; width: auto; filter: brightness(0) invert(1); opacity: 0.7; }
    .footer-copy {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 10px;
      color: rgba(250,249,246,0.3);
      letter-spacing: 0.08em;
    }
    .footer-sns {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .footer-sns a {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 11px;
      color: rgba(250,249,246,0.4);
      text-decoration: none;
      letter-spacing: 0.12em;
    }
    .footer-sns a:hover { color: rgba(250,249,246,0.8); }

    @media (max-width: 1024px) {
      .site-nav { display: none; }
      .hamburger { display: flex; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    }
    @media (max-width: 640px) {
      .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
      .footer-bottom { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>
