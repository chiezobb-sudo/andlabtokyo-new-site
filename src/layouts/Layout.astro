---
/**
 * &LAB TOKYO — Master Layout (Premium Minimalism)
 * グローバルナビ・フッター・SEO・OGP を一元管理
 */

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = "発酵と美の学校。表参道・代々木上原のプレミアム・ライフスタイルラボ。",
  canonical,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = false,
  lang = "ja",
} = Astro.props;

const siteUrl = "https://www.andlabtokyo.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = title.includes("&LAB TOKYO") ? title : `${title} | &LAB TOKYO`;
const path = Astro.url.pathname;

const navItems = [
  { label: "ABOUT", href: "/brand" },
  { label: "COURSES", href: "/listofcourses" },
  { label: "JOURNAL", href: "/knowledge" },
  { label: "ACCESS", href: "/contact" },
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

  <!-- OGP -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="&LAB TOKYO" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" href="https://static.wixstatic.com/media/745f65_5f8a0988e14b437298642730a9117f7b%7Emv2.png" type="image/png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Organization JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "&LAB TOKYO",
    "url": "https://www.andlabtokyo.com",
    "logo": "https://www.andlabtokyo.com/logo-wide.svg",
    "description": "発酵とローフードのクロス理論に基づくプレミアム・プロフェッショナルスクール。表参道・代々木上原。",
    "address": { "@type": "PostalAddress", "streetAddress": "東京都渋谷区神宮前（表参道・原宿エリア）", "addressLocality": "渋谷区", "addressRegion": "東京都", "postalCode": "150-0001", "addressCountry": "JP" },
    "founder": { "@type": "Person", "name": "安藤千英" },
    "sameAs": ["https://www.instagram.com/chie_andlab/"]
  }
  </script>

  <slot name="head" />

  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: 'Noto Serif JP', serif;
      background: #FAF9F6;
      color: #1C1C1A;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    /* HEADER */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 900;
      padding: 2rem 4rem;
      background: rgba(250, 249, 246, 0.98);
      backdrop-filter: blur(12px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(28, 28, 26, 0.05);
    }

    .logo {
      height: 40px;
      width: auto;
      display: block;
    }

    nav {
      display: flex;
      gap: 3rem;
      align-items: center;
    }

    nav a {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #7A7A72;
      text-decoration: none;
      transition: color 0.3s;
      font-weight: 400;
    }

    nav a:hover,
    nav a[data-active] {
      color: #1C1C1A;
    }

    /* BODY PADDING */
    main {
      padding-top: 100px;
    }

    /* FOOTER */
    footer {
      background: #FAF9F6;
      padding: 6rem 4rem;
      border-top: 1px solid rgba(28, 28, 26, 0.05);
      position: relative;
    }

    .footer-content {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .footer-logo {
      height: 30px;
      width: auto;
    }

    .footer-address {
      text-align: right;
      font-size: 11px;
      color: #7A7A72;
      line-height: 1.8;
      letter-spacing: 0.1em;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      header {
        padding: 1.5rem 2rem;
        flex-direction: column;
        gap: 1.5rem;
      }

      nav {
        gap: 1.5rem;
      }

      .footer-content {
        flex-direction: column;
        gap: 3rem;
        align-items: flex-start;
      }

      .footer-address {
        text-align: left;
      }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <a href="/" aria-label="&LAB TOKYO ホーム">
      <img src="/logo-wide.svg" alt="&LAB TOKYO" class="logo" />
    </a>

    <nav role="navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          data-active={path.startsWith(item.href) && item.href !== "/" ? "true" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </header>

  <!-- MAIN CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-content">
      <a href="/" aria-label="&LAB TOKYO ホーム">
        <img src="/logo-wide.svg" alt="&LAB TOKYO" class="footer-logo" />
      </a>

      <div class="footer-address">
        <p>5-2-11 Jingumae, Shibuya-ku,</p>
        <p>Tokyo 150-0001, Japan</p>
        <p style="margin-top: 0.8rem;"><a href="https://goo.gl/maps/andlab" target="_blank" rel="noopener" style="color: #7A7A72; text-decoration: none; border-bottom: 1px solid #7A7A72;">Google Map</a></p>
      </div>
    </div>
  </footer>

</body>
</html>
