---
/**
 * &LAB TOKYO — Master Layout
 * グローバルナビ・フッター・SEO・OGP を一元管理
 *
 * 使い方:
 * import Layout from '../layouts/Layout.astro';
 * <Layout title="ページタイトル" description="説明" canonical="https://...">
 *   <script slot="head" type="application/ld+json">...</script>
 *   <!-- page content -->
 * </Layout>
 */

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = "ELLE gourmet認定料理家・安藤千英。東京・渋谷の発酵×ローフード ライフスタイルラボ。",
  canonical,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = false,
  lang = "ja",
} = Astro.props;

const siteUrl = "https://www.andlabtokyo.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = title.includes("&LAB TOKYO") ? title : `${title} | &LAB TOKYO`;
const path = Astro.url.pathname;

const navLeft = [
  { label: "Concept", href: "/brand" },
  { label: "Courses", href: "/listofcourses" },
];
const navRight = [
  { label: "Journal", href: "/knowledge" },
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

  <!-- OGP -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="&LAB TOKYO" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

  <!-- Organization JSON-LD (全ページ共通) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "&LAB TOKYO",
    "url": "https://www.andlabtokyo.com",
    "logo": "https://www.andlabtokyo.com/logo-wide.png",
    "description": "東京・渋谷発。ローフード×発酵のクロス理論に基づくプレミアム・プロフェッショナルスクール。",
    "address": { "@type": "PostalAddress", "addressLocality": "渋谷区", "addressRegion": "東京都", "addressCountry": "JP" },
    "founder": { "@type": "Person", "name": "安藤千英", "alternateName": "Chie Ando" },
    "sameAs": ["https://www.instagram.com/chie_andlab/", "https://www.andlabtokyo.com"]
  }
  </script>

  <!-- Page-specific head (JSON-LD etc.) -->
  <slot name="head" />

  <style is:global>
    /* ─── CSS Variables ─── */
    :root {
      --linen:   #FBFBFA;
      --linen-2: #F4F2EE;
      --linen-3: #EAE7E0;
      --sumi:    #1C1C1A;
      --sumi-2:  #2A2A27;
      --sumi-3:  #3A3A36;
      --ink:     #1C1C1A;
      --ink-2:   #3D3D38;
      --ink-3:   #7A7A72;
      --green:   #A9D159;
      --green-d: #7AAF2A;
      --green-btn: #4E8A18;
      --f-serif: 'Noto Serif JP', serif;
      --f-sans:  'Noto Sans JP', sans-serif;
      --nav-h:   64px;
    }

    /* ─── Base Reset ─── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--f-sans);
      background: var(--linen);
      color: var(--ink);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
      padding-top: var(--nav-h);
    }

    /* ─── GLOBAL NAV (マスター・ナビゲーション) ─── */
    .g-nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 900;
      height: var(--nav-h);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 4rem;
      background: rgba(251, 251, 250, 0.96);
      backdrop-filter: blur(24px) saturate(1.3);
      -webkit-backdrop-filter: blur(24px) saturate(1.3);
      border-bottom: 1px solid rgba(28, 28, 26, .05);
    }
    /* Center logo */
    .g-nav-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }
    .g-nav-logo img {
      height: 44px;
      width: auto;
      display: block;
    }

    /* Left nav */
    .g-nav-left {
      display: flex;
      align-items: center;
      list-style: none;
      gap: 0;
      flex: 1;
    }
    .g-nav-left a,
    .g-nav-right-list a {
      font-family: var(--f-serif);
      font-size: .68rem;
      font-weight: 400;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--ink-3);
      text-decoration: none;
      padding: 0 1.8rem;
      display: block;
      line-height: var(--nav-h);
      border-bottom: 2px solid transparent;
      transition: color .3s, border-color .3s;
    }
    .g-nav-left a:hover,
    .g-nav-right-list a:hover { color: var(--ink); }
    .g-nav-left a[data-active="true"],
    .g-nav-right-list a[data-active="true"] {
      color: var(--ink);
      border-bottom-color: var(--ink);
    }

    /* Right side */
    .g-nav-right { display: flex; align-items: center; gap: 1.4rem; flex-shrink: 0; flex: 1; justify-content: flex-end; }
    .g-nav-right-list { display: flex; align-items: center; list-style: none; gap: 0; }
    .g-nav-contact {
      font-family: var(--f-serif);
      font-size: .65rem;
      font-weight: 400;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--ink-2);
      text-decoration: none;
      border: 1px solid rgba(28,28,26,.18);
      padding: .5rem 1.6rem;
      transition: all .3s;
      line-height: 1;
    }
    .g-nav-contact:hover {
      background: var(--ink);
      color: var(--linen);
      border-color: var(--ink);
    }
    /* ハンバーガー（モバイル用） */
    .g-nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .g-nav-burger span {
      display: block;
      width: 22px;
      height: 1px;
      background: var(--ink);
      transition: all .3s;
    }

    /* ─── GLOBAL FOOTER ─── */
    .g-footer {
      background: var(--sumi);
      padding: 6rem 4rem 2.5rem;
      border-top: 1px solid rgba(244, 242, 238, .04);
    }
    .g-footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2.2fr 1fr 1fr 1fr;
      gap: 5rem;
      padding-bottom: 4rem;
      border-bottom: 1px solid rgba(244, 242, 238, .05);
    }
    .g-footer-brand {}
    .g-footer-logo img {
      height: 38px;
      display: block;
      margin-bottom: 1.8rem;
      opacity: .65;
    }
    .g-footer-tag {
      font-family: var(--f-serif);
      font-size: .8rem;
      font-weight: 300;
      color: rgba(244, 242, 238, .25);
      line-height: 2.2;
      letter-spacing: .06em;
    }
    .g-footer-col h5 {
      font-family: var(--f-serif);
      font-size: .58rem;
      font-weight: 400;
      letter-spacing: .26em;
      text-transform: uppercase;
      color: rgba(244, 242, 238, .2);
      margin-bottom: 1.8rem;
    }
    .g-footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
    .g-footer-col a {
      font-family: var(--f-serif);
      font-size: .82rem;
      font-weight: 300;
      letter-spacing: .06em;
      color: rgba(244, 242, 238, .28);
      text-decoration: none;
      transition: color .25s;
    }
    .g-footer-col a:hover { color: rgba(244, 242, 238, .7); }
    .g-footer-copy {
      max-width: 1100px;
      margin: 2.2rem auto 0;
      text-align: center;
      font-family: var(--f-serif);
      font-size: .65rem;
      font-weight: 300;
      letter-spacing: .12em;
      color: rgba(244, 242, 238, .12);
    }

    /* ─── Responsive ─── */
    @media (max-width: 960px) {
      .g-nav { padding: 0 1.5rem; }
      .g-nav-logo img { height: 34px; }
      .g-nav-left { display: none; }
      .g-nav-right-list { display: none; }
      .g-nav-burger { display: flex; }
      .g-nav-contact { display: none; }
      .g-footer { padding: 4rem 1.5rem 2rem; }
      .g-footer-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    }
    @media (max-width: 600px) {
      .g-footer-inner { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- ══ MASTER NAVIGATION ══ -->
  <nav class="g-nav" role="navigation" aria-label="グローバルナビゲーション">

    <!-- Left nav items -->
    <ul class="g-nav-left" role="list">
      {navLeft.map(item => (
        <li>
          <a href={item.href} data-active={path.startsWith(item.href) ? "true" : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Center logo -->
    <a href="/" class="g-nav-logo" aria-label="&LAB TOKYO ホーム">
      <img src="/logo-wide.png" alt="&LAB TOKYO" />
    </a>

    <!-- Right nav items + contact -->
    <div class="g-nav-right">
      <ul class="g-nav-right-list" role="list">
        {navRight.map(item => (
          <li>
            <a href={item.href} data-active={path.startsWith(item.href) ? "true" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/contact" class="g-nav-contact">Contact</a>
      <button class="g-nav-burger" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ══ PAGE CONTENT ══ -->
  <slot />

  <!-- ══ GLOBAL FOOTER ══ -->
  <footer class="g-footer" role="contentinfo">
    <div class="g-footer-inner">

      <div class="g-footer-brand">
        <div class="g-footer-logo">
          <img src="/logo-wide.png" alt="&LAB TOKYO" />
        </div>
        <p class="g-footer-tag">
          発酵創家 安藤千英<br />
          Raw Food × Fermentation<br />
          Lifestyle Lab · Tokyo Shibuya
        </p>
      </div>

      <div class="g-footer-col">
        <h5>Program</h5>
        <ul>
          <li><a href="/listofcourses">講座・資格一覧</a></li>
          <li><a href="/rawfood-kentei-meister">ローフードマイスター</a></li>
          <li><a href="/rawchocolatier">ローショコラティエ協会</a></li>
          <li><a href="/koji-fermentation-experience-tokyo">UMAMI &amp; KOJI LAB</a></li>
        </ul>
      </div>

      <div class="g-footer-col">
        <h5>Knowledge</h5>
        <ul>
          <li><a href="/knowledge">知識ハブ</a></li>
          <li><a href="/rawfood">ローフードとは</a></li>
          <li><a href="/fermentedfood">発酵とは</a></li>
          <li><a href="/rawchocolatier/whatrawsweets">ロースイーツとは</a></li>
          <li><a href="/spirulina">スピルリナとは</a></li>
        </ul>
      </div>

      <div class="g-footer-col">
        <h5>Connect</h5>
        <ul>
          <li><a href="/about">安藤千英について</a></li>
          <li><a href="/blog">Journal</a></li>
          <li><a href="/contact">お問い合わせ</a></li>
          <li><a href="#" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="#" target="_blank" rel="noopener">YouTube</a></li>
        </ul>
      </div>

    </div>
    <p class="g-footer-copy">© 2026 &LAB TOKYO · 安藤千英. All rights reserved.</p>
  </footer>

</body>
</html>
