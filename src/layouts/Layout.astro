---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = "発酵とローフードのクロス理論に基づくプレミアムスクール。東京・渋谷（表参道）。",
  canonical,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = false,
  lang = "ja",
} = Astro.props;

const siteUrl = "https://www.andlabtokyo.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = title.includes("&LAB TOKYO") ? title : `${title} | &LAB TOKYO`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex
      ? <meta name="robots" content="noindex,nofollow" />
      : <meta name="robots" content="index,follow" />
    }
    <!-- OGP -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="&LAB TOKYO" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://static.wixstatic.com/media/745f65_5f8a0988e14b437298642730a9117f7b%7Emv2.png" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <!-- JSON-LD -->
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"EducationalOrganization","name":"&LAB TOKYO","url":"https://www.andlabtokyo.com","logo":"https://www.andlabtokyo.com/logo-wide.svg","description":"発酵とローフードのクロス理論に基づくプレミアムスクール。東京・渋谷（表参道）。","address":{"@type":"PostalAddress","streetAddress":"5-2-11 Jingumae, Shibuya-ku","addressLocality":"渋谷区","addressRegion":"東京都","postalCode":"150-0001","addressCountry":"JP"},"founder":{"@type":"Person","name":"安藤千英"},"sameAs":["https://www.instagram.com/chie_andlab/"]}</script>
    <slot name="head" />

    <style is:global>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      /* ================================================
         DESIGN TOKENS
      ================================================ */
      :root {
        --bg:    #FAF9F6;
        --ink:   #1C1C1A;
        /* extended palette for pages */
        --f-serif: 'Noto Serif JP', serif;
        --f-sans:  'Noto Sans JP', sans-serif;
        --fh:      'Cormorant Garamond', serif;
        --linen:   #FAF9F6;
        --linen-2: #F5F3EE;
        --linen-3: rgba(28,28,26,0.09);
        --ink-2:   #3C3C3A;
        --ink-3:   #8C8C8A;
        --divider: rgba(28,28,26,0.09);
        --sumi:    #1A1715;
        --sumi-2:  #1E1B19;
        --bg-card: #24211E;
        --bg-dark: #110E0B;
        --amber:   #C6A15B;
        --amber-d: #A8865A;
        --green:     #6B9A3A;
        --green-d:   #4A7A1E;
        --green-btn: #4D7C2A;
      }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Noto Serif JP', serif;
        line-height: 1.8;
        -webkit-font-smoothing: antialiased;
      }

      /* ================================================
         HEADER
      ================================================ */
      .site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 900;
        padding: 1.6rem 4rem;
        background: rgba(250,249,246,0.93);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(0,0,0,0.05);
      }
      .header-logo {
        height: 36px;
        width: auto;
        display: block;
      }

      /* ================================================
         DESKTOP NAV
      ================================================ */
      .site-nav {
        display: none; /* hidden on mobile, shown ≥1024px */
        gap: 2.5rem;
        align-items: center;
      }

      /* Plain link (About) */
      .site-nav > a {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7A7A72;
        text-decoration: none;
        transition: color 0.25s;
        white-space: nowrap;
      }
      .site-nav > a:hover { color: var(--ink); }

      /* Contact button */
      .nav-contact-btn {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
        padding: 0.5rem 1.4rem;
        border: 1px solid rgba(28,28,26,0.22);
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
      }
      .nav-contact-btn:hover { background: var(--ink); color: #FAF9F6; }

      /* ---- Dropdown item ---- */
      .nav-item {
        position: relative;
        cursor: pointer;
        padding: 0.6rem 0;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7A7A72;
        white-space: nowrap;
        user-select: none;
      }
      .nav-item:hover { color: var(--ink); }

      .nav-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: #fff;
        min-width: 260px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: opacity 0.25s, transform 0.25s, visibility 0.25s;
        box-shadow: 0 12px 40px rgba(0,0,0,0.07);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 1.2rem 0;
        z-index: 1000;
      }
      .nav-item:hover .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .nav-dropdown a {
        display: block;
        padding: 0.7rem 1.8rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        letter-spacing: 0.1em;
        color: #7A7A72;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        white-space: nowrap;
      }
      .nav-dropdown a:hover {
        background: var(--bg);
        color: var(--ink);
      }
      .nav-dropdown a.dd-footer {
        margin-top: 0.4rem;
        padding-top: 0.9rem;
        border-top: 1px solid rgba(0,0,0,0.05);
        font-weight: 500;
        letter-spacing: 0.12em;
      }

      /* ================================================
         HAMBURGER + MOBILE MENU
      ================================================ */
      .hamburger {
        display: flex;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
        background: none;
        border: none;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--ink);
        transition: all 0.3s;
      }

      .mobile-menu {
        display: none;
        position: fixed;
        top: 73px; left: 0; right: 0;
        background: #fff;
        border-top: 1px solid rgba(0,0,0,0.05);
        z-index: 899;
        max-height: calc(100vh - 73px);
        overflow-y: auto;
      }
      .mobile-menu.open { display: block; }
      .mob-section {
        border-bottom: 1px solid rgba(0,0,0,0.05);
      }
      .mob-section-title {
        display: block;
        padding: 0.9rem 1.5rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink);
        background: #FAF9F6;
      }
      .mob-section a {
        display: block;
        padding: 0.75rem 2rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 12px;
        letter-spacing: 0.08em;
        color: #5A5A58;
        text-decoration: none;
        border-bottom: 1px solid rgba(0,0,0,0.03);
      }
      .mob-section a:last-child { border-bottom: none; }
      .mob-contact {
        display: block;
        margin: 1.2rem 1.5rem 1.5rem;
        padding: 0.8rem;
        background: var(--ink);
        color: #FAF9F6;
        text-align: center;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 12px;
        letter-spacing: 0.15em;
        text-decoration: none;
        text-transform: uppercase;
      }

      /* ================================================
         MAIN + FOOTER
      ================================================ */
      main { padding-top: 73px; }

      /* ---- FOOTER ---- */
      .site-footer {
        background: #252320;
        color: rgba(250,249,246,0.55);
      }

      /* Top: logo center */
      .footer-logo-area {
        text-align: center;
        padding: 4rem 2rem 3rem;
        border-bottom: 1px solid rgba(250,249,246,0.07);
      }
      .footer-main-logo {
        height: 44px;
        width: auto;
        display: inline-block;
        opacity: 0.75;
        filter: brightness(0) invert(1);
      }
      .footer-tagline {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 9px;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: rgba(250,249,246,0.3);
        margin-top: 0.6rem;
        display: block;
      }

      /* Middle: 5-column links */
      .footer-cols {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem;
        border-bottom: 1px solid rgba(250,249,246,0.07);
      }
      .footer-col-head {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(250,249,246,0.4);
        display: block;
        margin-bottom: 1rem;
      }
      .footer-col a {
        display: block;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 11px;
        color: rgba(250,249,246,0.5);
        text-decoration: none;
        margin-bottom: 0.55rem;
        letter-spacing: 0.04em;
        transition: color 0.2s;
        line-height: 1.6;
      }
      .footer-col a::before {
        content: '・';
        opacity: 0.4;
        font-size: 10px;
      }
      .footer-col a:hover { color: rgba(250,249,246,0.9); }

      /* Bottom: LINE + SNS */
      .footer-bottom-bar {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid rgba(250,249,246,0.07);
      }
      .footer-line-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        padding: 1.4rem 2rem;
        background: #1A1A18;
        text-decoration: none;
        border-right: 1px solid rgba(250,249,246,0.07);
        transition: background 0.2s;
      }
      .footer-line-btn:hover { background: #111110; }
      .footer-line-btn svg { width: 28px; height: 28px; flex-shrink: 0; }
      .footer-line-btn span {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.25em;
        color: rgba(250,249,246,0.8);
      }
      .footer-sns-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.4rem;
        padding: 1.4rem 2rem;
        background: #1E1C1A;
      }
      .footer-sns-row a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        color: rgba(250,249,246,0.45);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-sns-row a:hover { color: rgba(250,249,246,0.9); }
      .footer-sns-row svg { width: 20px; height: 20px; }
      .footer-sns-row .sns-label {
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        letter-spacing: 0.04em;
        color: rgba(250,249,246,0.4);
      }

      /* Copyright */
      .footer-copy {
        text-align: center;
        padding: 1.2rem 2rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        color: rgba(250,249,246,0.2);
        letter-spacing: 0.1em;
        background: #1A1A18;
      }
      .footer-copy {
        margin-top: 3rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 10px;
        color: rgba(28,28,26,0.18);
        letter-spacing: 0.2em;
        text-align: center;
        text-transform: uppercase;
      }

      /* ================================================
         RESPONSIVE
      ================================================ */
      @media (min-width: 1024px) {
        .site-nav  { display: flex; }
        .hamburger { display: none; }
      }
      @media (max-width: 1023px) {
        .site-header { padding: 1.2rem 1.5rem; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); gap: 2rem 3rem; }
      }
      @media (max-width: 640px) {
        .footer-cols { grid-template-columns: 1fr 1fr; gap: 1.5rem 2rem; padding: 2rem 1.5rem; }
        .footer-bottom-bar { grid-template-columns: 1fr; }
        .footer-line-btn { border-right: none; border-bottom: 1px solid rgba(250,249,246,0.07); }
        .footer-sns-row { flex-wrap: wrap; gap: 1rem; padding: 1.2rem 1.5rem; }
        .footer-logo-area { padding: 3rem 1.5rem 2rem; }
      }
    </style>
  </head>

  <body>
    <!-- ===== HEADER ===== -->
    <header class="site-header">
      <a href="/" aria-label="&LAB TOKYO ホーム">
