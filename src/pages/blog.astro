---
import Layout from '../layouts/Layout.astro';

// ブログ記事データ
const articles = [
  {
    slug: 'what-is-rawfood',
    title: 'ローフードとは何か？基礎知識とライフスタイル',
    category: 'Knowledge',
    publishDate: '2026-06-06',
    description: 'ローフードの基本的な定義から、細胞レベルでの変化、日常生活への取り入れ方まで。酵素の力と48℃の科学的根拠を解説します。',
    image: '/rawfood-zucchini.jpg'
  },
  {
    slug: 'cross-theory',
    title: 'クロス理論：ローフード×発酵の融合',
    category: 'Philosophy',
    publishDate: '2026-06-06',
    description: '&LAB TOKYOが独自開発した「ローフード×発酵」のクロス理論。生きた酵素と発酵の力で、細胞から整う真のウェルネスを実現する理論的背景。',
    image: '/hacco-koji.jpg'
  },
  {
    slug: 'raw-sweets-benefits',
    title: 'ロースイーツの驚くべき健康効果',
    category: 'Wellness',
    publishDate: '2026-06-06',
    description: '砂糖不使用・加熱なしのロースイーツが、血糖値・腸内環境・肌に与える効果を科学的に解説。美しく甘いお菓子を罪悪感なく楽しむ方法。',
    image: '/raw-chocolate.jpg'
  }
];

// 公開日でソート（新しい順）
const sortedArticles = articles.sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());

// ユニークなカテゴリを取得
const categories = ['すべて', ...new Set(articles.map(a => a.category))];
---
<Layout
  title="ジャーナル｜発酵・ローフード・リビングフードの知恵と実践 | &LAB TOKYO"
  canonical="https://www.andlabtokyo.com/blog"
>

<style>
/* ===== HEADER ===== */
.blog-header {
  padding: 6rem 4rem;
  background: #FAF9F6;
  border-bottom: 1px solid rgba(28,28,26,0.06);
}
.blog-header-inner {
  max-width: 1100px;
  margin: 0 auto;
  text-align: center;
}
.blog-eyebrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 1rem;
}
.blog-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #1C1C1A;
  margin-bottom: 1rem;
  line-height: 1.6;
}
.blog-desc {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  letter-spacing: 0.05em;
  line-height: 2;
  color: #7A7A72;
  max-width: 720px;
  margin: 0 auto;
}

/* ===== CATEGORIES ===== */
.blog-categories {
  padding: 2.5rem 4rem;
  background: #FAF9F6;
}
.blog-categories-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}
.blog-cat-btn {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  letter-spacing: 0.1em;
  color: #7A7A72;
  background: transparent;
  border: 1px solid rgba(28,28,26,0.2);
  padding: 0.6rem 1.2rem;
  cursor: pointer;
  transition: all 0.3s;
  text-decoration: none;
  display: inline-block;
}
.blog-cat-btn:hover,
.blog-cat-btn.active {
  color: #1C1C1A;
  border-color: #1C1C1A;
  background: rgba(28,28,26,0.02);
}

/* ===== ARTICLES GRID ===== */
.blog-articles {
  padding: 5rem 4rem 6rem;
  background: #FAF9F6;
}
.blog-articles-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.articles-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem;
}
.article-item {
  text-decoration: none;
  color: inherit;
  display: block;
}
.article-item-img {
  aspect-ratio: 4/3;
  overflow: hidden;
  margin-bottom: 1.6rem;
  background: #E5E0DA;
}
.article-item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1s ease;
}
.article-item:hover .article-item-img img {
  transform: scale(1.04);
}
.article-item-category {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.6rem;
}
.article-item-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 15px;
  font-weight: 400;
  letter-spacing: 0.05em;
  line-height: 1.7;
  color: #1C1C1A;
  margin-bottom: 0.8rem;
}
.article-item-desc {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  color: #7A7A72;
  line-height: 1.8;
  margin-bottom: 1.2rem;
  font-weight: 300;
}
.article-item-date {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.08em;
  color: #999;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .articles-list { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .blog-header { padding: 4rem 1.5rem; }
  .blog-categories { padding: 2rem 1.5rem; }
  .blog-articles { padding: 4rem 1.5rem 5rem; }
  .articles-list { grid-template-columns: 1fr; gap: 2rem; }
  .blog-categories-inner { gap: 0.6rem; }
  .blog-cat-btn { font-size: 10px; padding: 0.5rem 1rem; }
}
</style>

<!-- ===== HEADER ===== -->
<div class="blog-header">
  <div class="blog-header-inner">
    <span class="blog-eyebrow">Journal</span>
    <h1 class="blog-title">食と発酵の、知恵と実践。</h1>
    <p class="blog-desc">
      ローフード・発酵・リビングフード・ロースイーツについて。<br>
      細胞から整える食の知恵を、&LAB TOKYOがお届けします。
    </p>
  </div>
</div>

<!-- ===== CATEGORIES ===== -->
<div class="blog-categories">
  <div class="blog-categories-inner">
    {categories.map(cat => (
      <button class={`blog-cat-btn ${cat === 'すべて' ? 'active' : ''}`} data-category={cat}>
        {cat}
      </button>
    ))}
  </div>
</div>

<!-- ===== ARTICLES ===== -->
<section class="blog-articles">
  <div class="blog-articles-inner">
    <div class="articles-list">
      {sortedArticles.map(article => (
        <a href={`/blog/${article.slug}`} class="article-item">
          <div class="article-item-img">
            <img src={article.image} alt={article.title} loading="lazy" onerror="this.style.display='none'" />
          </div>
          <span class="article-item-category">{article.category}</span>
          <h2 class="article-item-title">{article.title}</h2>
          <p class="article-item-desc">{article.description}</p>
          <span class="article-item-date">{article.publishDate}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
// カテゴリフィルター（将来の拡張用）
document.querySelectorAll('.blog-cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.blog-cat-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    // 将来：記事をフィルターする処理
  });
});
</script>

</Layout>
