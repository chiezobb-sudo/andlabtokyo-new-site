    .back-link{display:inline-flex;align-items:center;gap:.5rem;font-size:.82rem;color:var(--ink-3);text-decoration:none;margin-top:3rem;transition:color .2s;}
    .back-link:hover{color:var(--ink);}
    footer{background:var(--sumi);padding:3rem;text-align:center;border-top:1px solid rgba(244,242,238,.06);}
    .footer-logo img{height:28px;mix-blend-mode:screen;filter:brightness(1.1);margin-bottom:1rem;}
    .footer-copy{font-size:.72rem;color:rgba(244,242,238,.18);}
    @media(max-width:768px){nav{padding:0 1.5rem;}.nav-links{display:none;}.article-wrap{padding:3rem 1.5rem 5rem;}.article-hero-text{padding:0 1.5rem 2rem;}.benefit-item{grid-template-columns:40px 1fr;}.story-box{padding:1.6rem;}.association-box{flex-direction:column;gap:1rem;}}
  </style>
