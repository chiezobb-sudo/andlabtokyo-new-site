  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --linen:#FBFBFA; --linen-2:#F4F2EE; --linen-3:#EAE7E0;
      --sumi:#1C1C1A; --sumi-2:#2A2A27; --sumi-3:#3A3A36;
      --ink:#1C1C1A; --ink-2:#3D3D38; --ink-3:#7A7A72;
      --green:#A9D159; --green-d:#7AAF2A; --green-btn:#4E8A18;
      --f-serif:'Noto Serif JP',serif; --f-sans:'Noto Sans JP',sans-serif;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;font-size:16px;}
    body{font-family:var(--f-sans);background:var(--linen);color:var(--ink);line-height:1.8;-webkit-font-smoothing:antialiased;}
    nav{position:fixed;inset:0 0 auto 0;z-index:500;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;background:rgba(28,28,26,.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(244,242,238,.08);}
    .nav-logo img{height:32px;width:auto;mix-blend-mode:screen;filter:brightness(1.1);}
    .nav-links{display:flex;list-style:none;gap:0;}
    .nav-links a{font-family:var(--f-sans);font-size:.82rem;font-weight:500;letter-spacing:.04em;color:rgba(244,242,238,.65);text-decoration:none;padding:0 1.1rem;transition:color .2s;}
    .nav-links a:hover{color:var(--green);}
    .nav-cta{font-family:var(--f-sans);font-size:.82rem;font-weight:700;display:inline-block;background:var(--green-btn);color:#FAF5EC;padding:.45rem 1.4rem;margin-left:1.2rem;text-decoration:none;transition:background .2s;}
    .nav-cta:hover{background:#3D6E12;color:#fff;}
    .nav-right{display:flex;align-items:center;}

    .article-hero{margin-top:52px;position:relative;height:52vh;min-height:320px;overflow:hidden;}
    .article-hero img{width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;}
    .article-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,28,26,.78) 0%,rgba(28,28,26,.2) 60%,transparent 100%);}
    .article-hero-text{position:absolute;bottom:0;left:0;right:0;padding:0 5vw 3rem;max-width:860px;}
    .article-cat{font-family:var(--f-sans);font-size:.72rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:1rem;}
    .article-hero-text h1{font-family:var(--f-serif);font-size:clamp(1.4rem,3vw,2.2rem);font-weight:600;letter-spacing:.06em;color:#FAF5EC;line-height:1.5;}

    .article-wrap{max-width:780px;margin:0 auto;padding:5rem 3rem 8rem;}
    .article-meta{display:flex;align-items:center;gap:2rem;padding-bottom:2rem;margin-bottom:3rem;border-bottom:1px solid var(--linen-3);}
    .meta-date{font-size:.8rem;color:var(--ink-3);}
    .meta-author{display:flex;align-items:center;gap:.7rem;font-size:.82rem;color:var(--ink-2);}
    .meta-author img{width:32px;height:32px;border-radius:50%;object-fit:cover;object-position:top;}

    .prose h2{font-family:var(--f-serif);font-size:clamp(1.2rem,2.2vw,1.6rem);font-weight:600;letter-spacing:.06em;color:var(--ink);margin:3.5rem 0 1.2rem;padding-top:3.5rem;border-top:1px solid var(--linen-3);line-height:1.5;}
    .prose h2:first-child{margin-top:0;padding-top:0;border-top:none;}
    .prose h3{font-family:var(--f-serif);font-size:1.05rem;font-weight:600;letter-spacing:.04em;color:var(--ink);margin:1.8rem 0 .7rem;}
    .prose p{font-size:.97rem;color:var(--ink-2);line-height:2.1;margin-bottom:1.4rem;}
    .prose strong{color:var(--ink);font-weight:700;}

    /* ナンバードリスト */
    .benefit-list{display:flex;flex-direction:column;gap:0;margin:2rem 0 2.4rem;}
    .benefit-item{display:grid;grid-template-columns:56px 1fr;gap:0;border-top:1px solid var(--linen-3);}
    .benefit-item:last-child{border-bottom:1px solid var(--linen-3);}
    .benefit-num{font-family:var(--f-serif);font-size:2.2rem;font-weight:300;color:var(--linen-3);padding:1.8rem 0;display:flex;align-items:flex-start;justify-content:flex-start;line-height:1;}
    .benefit-body{padding:1.8rem 0 1.8rem 1.4rem;border-left:1px solid var(--linen-3);}
    .benefit-title{font-family:var(--f-serif);font-size:1.05rem;font-weight:600;color:var(--ink);display:block;margin-bottom:.7rem;line-height:1.5;}
    .benefit-body p{font-size:.93rem;color:var(--ink-2);line-height:2.05;margin:0 0 .8rem;}
    .benefit-body p:last-child{margin-bottom:0;}

    /* ストーリーボックス */
    .story-box{
      margin:2rem 0;
      padding:2.4rem 2.8rem;
      background:var(--sumi);
      border-left:3px solid var(--green);
    }
    .story-box-label{
      font-family:var(--f-sans);font-size:.68rem;font-weight:700;
      letter-spacing:.18em;text-transform:uppercase;
      color:var(--green);display:block;margin-bottom:1.2rem;
    }
    .story-box p{font-size:.93rem;color:rgba(244,242,238,.8);line-height:2.1;margin-bottom:1rem;}
    .story-box p:last-child{margin-bottom:0;}
    .story-box strong{color:rgba(244,242,238,.95);}

    /* 協会バッジ */
    .association-box{
      margin:3rem 0;padding:2rem 2.4rem;
      background:var(--linen-2);
      border:1px solid var(--linen-3);
      display:flex;gap:1.6rem;align-items:flex-start;
    }
    .association-badge{
      flex-shrink:0;width:52px;height:52px;
      background:var(--sumi);
      display:flex;align-items:center;justify-content:center;
      font-family:var(--f-serif);font-size:.6rem;font-weight:600;
      letter-spacing:.04em;color:var(--green);text-align:center;
      line-height:1.4;
    }
    .association-text h3{font-family:var(--f-serif);font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:.5rem;letter-spacing:.04em;}
    .association-text p{font-size:.88rem;color:var(--ink-2);line-height:1.9;margin:0;}

    .pull-quote{margin:2.5rem 0;padding:1.6rem 2rem;border-left:3px solid var(--ink);background:var(--linen-2);}
    .pull-quote p{font-family:var(--f-serif);font-size:1.05rem;font-weight:400;letter-spacing:.06em;color:var(--ink);line-height:1.9;margin:0;}
    .tag-list{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:4rem;padding-top:2.5rem;border-top:1px solid var(--linen-3);}
    .tag{font-size:.75rem;color:var(--green-d);border:1px solid var(--green-d);padding:.25rem .75rem;letter-spacing:.06em;}
    .cta-box{margin-top:4rem;padding:2.5rem;background:var(--sumi);text-align:center;}
    .cta-box p{font-family:var(--f-serif);font-size:.95rem;color:rgba(244,242,238,.75);line-height:2;margin-bottom:1.6rem;}
    .cta-box a{display:inline-block;background:var(--green-btn);color:#FAF5EC;font-family:var(--f-sans);font-size:.85rem;font-weight:700;letter-spacing:.08em;padding:.9rem 2.4rem;text-decoration:none;transition:background .2s;}
    .cta-box a:hover{background:#3D6E12;}
    .breadcrumb{font-size:.78rem;color:var(--ink-3);margin-bottom:2rem;}
    .breadcrumb a{color:var(--ink-3);text-decoration:none;transition:color .2s;}
    .breadcrumb a:hover{color:var(--ink);}
