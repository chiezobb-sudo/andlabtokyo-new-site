    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": "https://andlabtokyo.biz/raw-chocolate.jpg",
    "author": { "@type": "Person", "name": "安藤千英", "url": "https://andlabtokyo.biz/about" },
    "publisher": { "@type": "Organization", "name": "&LAB TOKYO", "url": "https://andlabtokyo.biz" },
    "datePublished": "2026-04-28",
    "keywords": "ロースイーツ,ローチョコレート,グルテンフリー,ナッツフリー,アレルギー,ローショコラティエ協会,発酵スイーツ,砂糖不使用"
  })} />
