  <style>
    html, body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --linen:  #FBFBFA; --linen-2:#F4F2EE; --linen-3:#EAE7E0;
      --sumi:   #1C1C1A; --sumi-2: #2A2A27; --sumi-3:#332F2C;
      --ink:    #1C1C1A; --ink-2:  #3D3D38; --ink-3:  #7A7A72;
      --green:  #A9D159; --green-d:#7AAF2A;
      --divider:#D8D4CC;
      --f-s:'Noto Serif JP',serif; --f-b:'Noto Sans JP',sans-serif;
      --max:1040px; --pad:clamp(1rem,4vw,2.8rem);
    }
    html { scroll-behavior: smooth; }
    body { font-family:var(--f-b); background:var(--linen); color:var(--ink); line-height:1.8; -webkit-font-smoothing:antialiased; }

    /* ━━ Nav ━━ */
    nav { position:fixed;inset:0 0 auto 0;z-index:500;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 var(--pad);background:rgba(28,28,26,.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(244,242,238,.07); }
    .nav-logo img { height:30px;width:auto; }
    .nav-links { display:flex;list-style:none; }
    .nav-links a { font-size:.78rem;font-weight:500;color:rgba(244,242,238,.58);text-decoration:none;padding:0 .8rem;transition:color .2s; }
    .nav-links a:hover,.nav-links a.active { color:var(--green); }
    .nav-cta { font-size:.78rem;font-weight:700;background:var(--green);color:var(--sumi);padding:.42rem 1rem;margin-left:.8rem;text-decoration:none;transition:background .2s; }
    .nav-cta:hover { background:var(--green-d);color:#fff; }

    /* ━━ Hero ━━ */
    .hero { margin-top:52px;position:relative;height:62vh;min-height:420px;overflow:hidden;display:flex;align-items:flex-end; }
    .hero-img { position:absolute;inset:0; }
    .hero-img img { width:100%;height:100%;object-fit:cover;object-position:center 28%;display:block; }
    .hero-img::after { content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(28,28,26,.9) 0%,rgba(28,28,26,.32) 55%,rgba(28,28,26,.05) 100%); }
    .hero-body { position:relative;z-index:1;width:100%;padding:0 var(--pad) 3.2rem; }
    .hero-inner { max-width:640px; }
    .label-sm { font-family:var(--f-b);font-size:.68rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:.9rem; }
    .hero h1 { font-family:var(--f-s);font-size:clamp(1.7rem,3.8vw,2.8rem);font-weight:600;letter-spacing:.08em;line-height:1.4;color:#F4F2EE;margin-bottom:.7rem; }
    .hero-sub { font-family:var(--f-s);font-size:clamp(.85rem,1.4vw,.98rem);font-weight:300;letter-spacing:.06em;color:rgba(244,242,238,.68);margin-bottom:1.5rem;line-height:1.9; }
    .hero-tags { display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:2rem; }
    .tag { font-size:.65rem;font-weight:500;padding:.3rem .75rem;border:1px solid rgba(244,242,238,.22);color:rgba(244,242,238,.58);letter-spacing:.04em; }
    .btn-linen { display:inline-block;background:var(--linen);color:var(--sumi);font-family:var(--f-b);font-size:.8rem;font-weight:700;letter-spacing:.06em;padding:.85rem 2rem;text-decoration:none;transition:all .2s; }
    .btn-linen:hover { background:var(--green);color:var(--sumi); }

    /* ━━ 共通 ━━ */
    .sec { padding:5rem var(--pad); }
    .wrap { max-width:var(--max);margin:0 auto;width:100%; }
    .eyebrow { font-family:var(--f-b);font-size:.68rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green-d);display:block;margin-bottom:.8rem; }
    .sec-h2 { font-family:var(--f-s);font-size:clamp(1.35rem,2.4vw,2rem);font-weight:600;letter-spacing:.08em;line-height:1.5;color:var(--ink); }
    .rule { width:26px;height:1px;background:var(--divider);margin:1.5rem 0 2.2rem; }
    .body-p { font-size:.9rem;color:var(--ink-2);line-height:2.1;margin-bottom:1.1rem; }
    .body-p strong { color:var(--ink);font-weight:700; }

    /* ━━ コース（メイン） ━━ */
    .courses-sec { background:var(--linen);padding:5rem var(--pad); }
    .courses-intro { max-width:600px;margin-bottom:3.5rem; }
    .course-wrap { display:flex;flex-direction:column;gap:3px; }

    .c-card { overflow:hidden; }
    .c-head {
      background:var(--sumi);
      padding:2rem 2.4rem;
      display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-start;gap:1.2rem;
    }
    .c-head.lv3 { background:var(--sumi-2); }
    .c-badge { font-family:var(--f-b);font-size:.62rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:.45rem; }
    .c-name { font-family:var(--f-s);font-size:clamp(.95rem,1.8vw,1.35rem);font-weight:600;letter-spacing:.06em;color:#F4F2EE;margin-bottom:.3rem; }
    .c-tagline { font-size:.8rem;color:rgba(244,242,238,.5);line-height:1.7;max-width:400px; }
    .c-price { text-align:right;flex-shrink:0; }
    .c-price-num { font-family:var(--f-s);font-size:1.5rem;font-weight:300;color:var(--green);display:block;line-height:1.2; }
    .c-price-tax { font-size:.62rem;color:rgba(244,242,238,.38);display:block;margin-top:.15rem; }
    .c-price-recipe { font-size:.68rem;color:rgba(244,242,238,.45);display:block;margin-top:.3rem;letter-spacing:.06em; }

    .c-body { background:var(--linen-2);padding:2rem 2.4rem; }
    .c-cols { display:grid;grid-template-columns:1fr 1fr;gap:2.4rem; }
    .c-col-title { font-family:var(--f-s);font-size:.85rem;font-weight:600;letter-spacing:.06em;color:var(--ink);margin-bottom:.9rem;border-bottom:1px solid var(--linen-3);padding-bottom:.5rem; }
    .c-list { list-style:none;display:flex;flex-direction:column;gap:.55rem; }
    .c-list li { font-size:.82rem;color:var(--ink-2);line-height:1.75;padding-left:.9rem;position:relative; }
    .c-list li::before { content:'·';position:absolute;left:0;color:var(--green-d);font-size:1rem; }
    .c-info { display:flex;flex-direction:column;gap:.5rem; }
    .c-info-row { display:flex;gap:.6rem;font-size:.8rem; }
    .c-info-l { color:var(--ink-3);min-width:62px;flex-shrink:0;font-weight:500;font-size:.75rem; }
    .c-info-v { color:var(--ink-2);line-height:1.65; }

    .c-action { background:var(--linen-3);padding:1.2rem 2.4rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem; }
    .c-action-text { font-size:.8rem;color:var(--ink-3);flex:1;line-height:1.6; }
    .btn-apply { display:inline-block;background:var(--sumi);color:#F4F2EE;font-family:var(--f-b);font-size:.78rem;font-weight:700;letter-spacing:.06em;padding:.75rem 1.5rem;text-decoration:none;transition:background .2s;white-space:nowrap; }
    .btn-apply:hover { background:var(--sumi-2); }

    /* ━━ 選ばれる理由 ━━ */
    .reason-sec { background:var(--sumi);padding:5rem var(--pad); }
    .reason-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2px;margin-top:3rem; }
    .reason-item { background:rgba(244,242,238,.04);padding:2rem 1.8rem;border-top:1px solid rgba(244,242,238,.08); }
    .reason-icon { font-size:1.4rem;display:block;margin-bottom:.8rem; }
    .reason-item h4 { font-family:var(--f-s);font-size:.92rem;font-weight:600;letter-spacing:.04em;color:#F4F2EE;margin-bottom:.6rem; }
    .reason-item p { font-size:.8rem;color:rgba(244,242,238,.48);line-height:1.9; }

    /* ━━ とは解説 ━━ */
    .what-sec { background:var(--linen-2);padding:5rem var(--pad); }
    .what-grid { display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start; }
    .what-img img { width:100%;aspect-ratio:4/3;object-fit:cover;display:block; }
    .what-points { list-style:none;display:flex;flex-direction:column;gap:1rem;margin-top:2rem; }
    .what-points li { display:flex;gap:.75rem;font-size:.88rem;color:var(--ink-2);line-height:1.8; }
    .what-points li::before { content:'—';color:var(--green-d);flex-shrink:0;font-weight:700; }

    /* ━━ こんな方へ ━━ */
    .whom-sec { background:var(--linen);padding:5rem var(--pad); }
    .whom-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;margin-top:2.5rem; }
    .whom-item { background:var(--linen-2);padding:1.8rem 1.6rem; }
    .whom-item h4 { font-family:var(--f-s);font-size:.88rem;font-weight:600;color:var(--ink);margin-bottom:.5rem;letter-spacing:.04em; }
    .whom-item p { font-size:.78rem;color:var(--ink-3);line-height:1.85; }

    /* ━━ 講師 ━━ */
    .instructor-sec { background:var(--linen-2);padding:5rem var(--pad); }
    .instructor-grid { display:grid;grid-template-columns:200px 1fr;gap:3.5rem;align-items:start; }
    .instructor-img img { width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;display:block; }
    .instructor-cap { font-size:.68rem;color:var(--ink-3);margin-top:.45rem;text-align:center;letter-spacing:.08em; }

    /* ━━ 受講生の声 ━━ */
    .testi-sec { background:var(--linen);padding:5rem var(--pad); }
    .testi-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;margin-top:2.5rem; }
    .testi { background:var(--linen-2);padding:2rem 1.8rem; }
    .testi-q::before { content:'"';font-size:1.3rem;color:var(--green-d);line-height:.5;display:block;margin-bottom:.3rem; }
    .testi-q { font-family:var(--f-s);font-size:.88rem;color:var(--ink);line-height:1.9;margin-bottom:1.2rem; }
    .testi-name { font-family:var(--f-s);font-size:.83rem;font-weight:600;color:var(--ink); }
    .testi-role { font-size:.73rem;color:var(--ink-3);margin-top:.22rem;line-height:1.6; }

    /* ━━ FAQ ━━ */
    .faq-sec { background:var(--linen-2);padding:5rem var(--pad); }
    .faq-list { display:flex;flex-direction:column;margin-top:2.5rem; }
    .faq-item { border-bottom:1px solid var(--linen-3);padding:1.5rem 0; }
    .faq-q { font-family:var(--f-s);font-size:.92rem;font-weight:600;color:var(--ink);margin-bottom:.7rem;line-height:1.6; }
    .faq-q::before { content:'Q. ';color:var(--green-d); }
    .faq-a { font-size:.85rem;color:var(--ink-2);line-height:2;padding-left:1.1rem; }

    /* ━━ 1Day体験（独立ブロック） ━━ */
    .trial-block { background:var(--sumi-2);padding:4rem var(--pad); }
    .trial-inner { max-width:600px;margin:0 auto;text-align:center; }
    .trial-rule { width:22px;height:1px;background:rgba(244,242,238,.16);margin:1.3rem auto 1.8rem; }
    .trial-desc { font-size:.85rem;color:rgba(244,242,238,.48);line-height:2.1;margin-bottom:1.6rem; }
    .trial-price { font-family:var(--f-s);font-size:1.15rem;font-weight:300;color:var(--green);margin-bottom:1.6rem;display:block; }
    .btn-ghost { display:inline-block;border:1px solid rgba(244,242,238,.22);color:rgba(244,242,238,.62);font-family:var(--f-b);font-size:.8rem;font-weight:500;letter-spacing:.06em;padding:.75rem 1.8rem;text-decoration:none;transition:all .2s; }
    .btn-ghost:hover { border-color:var(--green);color:var(--green); }

    /* ━━ フォーム ━━ */
    .form-sec { background:var(--linen);padding:5rem var(--pad); }
    .form-box { max-width:660px;margin:0 auto; }
    .form-head { margin-bottom:2.2rem; }
    .form-title { font-family:var(--f-s);font-size:clamp(1.2rem,2.2vw,1.6rem);font-weight:600;letter-spacing:.08em;color:var(--ink);margin-bottom:.5rem; }
    .form-note { font-size:.82rem;color:var(--ink-3);line-height:1.8; }
    form.cf { display:flex;flex-direction:column;gap:1.1rem; }
    .f { display:flex;flex-direction:column;gap:.4rem; }
    .f label { font-size:.75rem;font-weight:500;color:var(--ink-2);letter-spacing:.04em; }
    .f label .r { color:var(--green-d);margin-left:2px; }
    .f input,.f select,.f textarea { width:100%;padding:.78rem .95rem;background:var(--linen-2);border:1px solid var(--divider);border-radius:0;color:var(--ink);font-family:var(--f-b);font-size:.85rem;outline:none;transition:border-color .2s,background .2s;-webkit-appearance:none; }
    .f input:focus,.f select:focus,.f textarea:focus { border-color:var(--green-d);background:#fff; }
    .f textarea { min-height:100px;resize:vertical; }
    .f-row { display:grid;grid-template-columns:1fr 1fr;gap:.9rem; }
    .nl-box { padding:.95rem 1.1rem;background:rgba(169,209,89,.06);border:1px solid rgba(169,209,89,.18);margin-top:.2rem; }
    .ck-label { display:flex;align-items:flex-start;gap:.65rem;cursor:pointer;font-size:.82rem;color:var(--ink-2);line-height:1.6; }
    .ck-label input[type="checkbox"] { width:14px;height:14px;flex-shrink:0;margin-top:3px;accent-color:var(--green-d); }
    .ck-note { font-size:.7rem;color:var(--ink-3);margin-top:.42rem;padding-left:20px;line-height:1.6; }
    .btn-sub { width:100%;padding:.95rem;background:var(--sumi);color:#F4F2EE;font-family:var(--f-b);font-size:.85rem;font-weight:700;letter-spacing:.08em;border:none;cursor:pointer;transition:background .2s;margin-top:.3rem; }
    .btn-sub:hover { background:var(--sumi-2); }
    .form-bottom { font-size:.72rem;color:var(--ink-3);text-align:center;margin-top:.35rem;line-height:1.7; }

    footer { background:var(--sumi);padding:1.6rem var(--pad);text-align:center;border-top:1px solid rgba(244,242,238,.05); }
    footer p { font-size:.68rem;color:rgba(244,242,238,.2); }
    footer a { color:rgba(244,242,238,.28);text-decoration:none; }
    footer a:hover { color:var(--green); }

    @media(max-width:760px){
      .nav-links{display:none;}
      .nav-cta{margin-left:auto;}
      .hero-inner{max-width:100%;}
      .c-head{flex-direction:column;}
      .c-price{text-align:left;}
      .c-cols{grid-template-columns:1fr;gap:1.6rem;}
      .what-grid{grid-template-columns:1fr;gap:2rem;}
      .what-img{display:none;}
      .instructor-grid{grid-template-columns:1fr;gap:2rem;}
      .instructor-img{max-width:180px;}
      .f-row{grid-template-columns:1fr;gap:.9rem;}
    }
    @media(max-width:420px){
      :root{--pad:1rem;}
      .hero h1{font-size:1.5rem;}
      .c-name{font-size:.9rem;}
    }
  </style>
</head>
