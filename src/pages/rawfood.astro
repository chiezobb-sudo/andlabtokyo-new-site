    footer a{color:rgba(244,242,238,.35);text-decoration:none;}
    footer a:hover{color:var(--green);}
    @media(max-width:900px){nav{padding:0 1.2rem;}.nav-links{display:none;}.hero-body{padding:0 1.5rem 4rem;}.what-grid{grid-template-columns:1fr;gap:3rem;}.benefits-grid{grid-template-columns:1fr;}.course-header{grid-template-columns:1fr;padding:2rem;}.course-price{text-align:left;}.course-body{padding:2rem;}.course-body-grid{grid-template-columns:1fr;gap:2rem;}.action-strip{flex-direction:column;align-items:flex-start;padding:1.5rem 2rem;}.whom-grid{grid-template-columns:1fr;}.instructor-grid{grid-template-columns:1fr;gap:2.5rem;}.testi-grid{grid-template-columns:1fr;}.sec,.courses-sec,.whom-sec,.testi-sec,.faq-sec,.cta-sec,.trial-sec,.instructor-sec,.benefits-sec{padding:5rem 1.5rem;}}
