          <!-- メルマガ（将来Brevo連携: name="newsletter" value="yes"を参照） -->
          <div class="newsletter-wrap">
            <label class="check-label">
              <input type="checkbox" name="newsletter" value="yes" id="newsletter" />
              <span><strong>&LAB TOKYOからのお知らせを受け取る</strong>（新しいレッスン情報・発酵×ローフードの知恵・安藤千英からのメッセージ）</span>
