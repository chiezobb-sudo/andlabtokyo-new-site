    .whom-item p{font-size:.85rem;color:var(--ink-3);line-height:1.85;}
    .instructor-sec{background:var(--linen);padding:7rem 5vw;}
    .instructor-grid{display:grid;grid-template-columns:280px 1fr;gap:6rem;align-items:start;}
