    .course-price-note{font-size:.72rem;color:rgba(244,242,238,.35);display:block;margin-top:.3rem;}
    .course-body{background:var(--linen-2);padding:3rem 4rem;}
    .course-body-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;}
    .curriculum-list{list-style:none;display:flex;flex-direction:column;gap:.8rem;}
    .curriculum-list li{font-size:.88rem;color:var(--ink-2);line-height:1.8;padding-left:1.2rem;position:relative;}
    .curriculum-list li::before{content:'・';position:absolute;left:0;color:var(--green-d);}
    .info-table{display:flex;flex-direction:column;gap:.8rem;}
