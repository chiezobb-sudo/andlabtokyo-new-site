---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Hacco LAB | &LAB TOKYO"
  canonical="https://www.andlabtokyo.com/hacco"
>

<style>
.coming { text-align:center; }
    .label { font-family:'Cormorant Garamond',serif; font-size:.75rem; letter-spacing:4px; text-transform:uppercase; color:#c8a96e; margin-bottom:1.5rem; }
    h1 { font-family:'Noto Serif JP',serif; font-weight:200; font-size:3rem; color:#fdfaf5; margin-bottom:1.5rem; }
    p { color:rgba(242,237,228,.5); }
    .back { display:inline-block; margin-top:2.5rem; padding:.8rem 2rem; border:1px solid rgba(200,169,110,.4); color:#c8a96e; text-decoration:none; font-size:.8rem; letter-spacing:2px; border-radius:1px; transition:background .2s; }
    .back:hover { background:#c8a96e; color:#0c0a08; }
</style>

<div class="coming">
    <p class="label">Coming Soon</p>
    <h1>Hacco LAB</h1>
    <p>このページは現在準備中です。</p>
    <a href="/" class="back">← TOPへ戻る</a>
  </div>

</Layout>
