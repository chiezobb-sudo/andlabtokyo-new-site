---
const title = "&LAB TOKYO 講座・資格一覧 | ローフード・発酵・ローショコラティエ 東京・渋谷";
const description = "東京・渋谷発。&LAB TOKYO安藤千英によるローフードマイスター、発酵ロー調味料、ローショコラティエ資格取得・プロ養成コース一覧。初心者から独立開業まで。";
const url = "https://www.andlabtokyo.com/listofcourses";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <link rel="icon" href="/favicon.ico" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "&LAB TOKYO",
    "url": "https://www.andlabtokyo.com/",
    "description": "東京・渋谷発のローフード・発酵専門教育機関。医師監修の独自カリキュラムで、ローフードマイスター・ローショコラティエ等の資格取得・プロ養成を行う。",
    "address": { "@type": "PostalAddress", "addressLocality": "渋谷区", "addressRegion": "東京都", "addressCountry": "JP" },
    "founder": { "@type": "Person", "name": "安藤千英" }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --linen:#FBFBFA; --linen-2:#F4F2EE; --linen-3:#EAE7E0;
      --sumi:#1C1C1A;  --sumi-2:#2A2A27; --sumi-3:#3A3A36;
      --ink:#1C1C1A;   --ink-2:#3D3D38;  --ink-3:#7A7A72;
      --green:#A9D159; --green-d:#7AAF2A; --green-btn:#4E8A18;
      --f-serif:'Noto Serif JP',serif; --f-sans:'Noto Sans JP',sans-serif;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--f-sans);background:var(--linen);color:var(--ink);line-height:1.8;-webkit-font-smoothing:antialiased;}

    nav{position:fixed;inset:0 0 auto 0;z-index:500;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;background:rgba(28,28,26,.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(244,242,238,.06);}
    .nav-logo img{height:32px;mix-blend-mode:screen;filter:brightness(1.1);}
    .nav-links{display:flex;list-style:none;}
    .nav-links a{font-size:.8rem;font-weight:500;letter-spacing:.04em;color:rgba(244,242,238,.55);text-decoration:none;padding:0 1rem;transition:color .2s;}
    .nav-links a:hover{color:var(--green);}
    .nav-right{display:flex;align-items:center;}
    .nav-cta{font-size:.8rem;font-weight:700;display:inline-block;background:transparent;color:rgba(244,242,238,.6);padding:.4rem 1.2rem;margin-left:1rem;text-decoration:none;border:1px solid rgba(244,242,238,.2);letter-spacing:.06em;transition:all .2s;}
    .nav-cta:hover{color:#FAF5EC;border-color:rgba(244,242,238,.5);}

    /* HERO */
    .page-hero{margin-top:52px;position:relative;height:65vh;min-height:420px;overflow:hidden;display:flex;align-items:flex-end;}
    .page-hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;}
    .page-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,12,10,.96) 0%,rgba(12,12,10,.5) 50%,rgba(12,12,10,.15) 100%);}
    .page-hero-text{position:relative;z-index:2;padding:0 5vw 7vh;max-width:680px;}
    .hero-eye{font-family:var(--f-sans);font-size:.62rem;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:rgba(244,242,238,.3);display:block;margin-bottom:1.8rem;}
    .page-hero h1{font-family:var(--f-serif);font-size:clamp(1.8rem,3.5vw,3rem);font-weight:300;letter-spacing:.15em;color:#FAF5EC;line-height:1.35;margin-bottom:1.4rem;}
    .page-hero p{font-family:var(--f-serif);font-size:.95rem;font-weight:300;color:rgba(244,242,238,.45);letter-spacing:.08em;line-height:2.1;}

    /* BREADCRUMB */
    .bc-bar{background:var(--linen-2);padding:.85rem 3rem;border-bottom:1px solid var(--linen-3);}
    .bc{font-size:.74rem;color:var(--ink-3);max-width:1100px;margin:0 auto;}
    .bc a{color:var(--ink-3);text-decoration:none;}
    .bc span{margin:0 .5rem;}

    /* 哲学バンド */
    .philosophy-band{background:var(--sumi-2);padding:5rem 3rem;border-left:3px solid rgba(169,209,89,.4);}
    .philosophy-band p{font-family:var(--f-serif);font-size:1rem;font-weight:300;color:rgba(244,242,238,.7);line-height:2.3;letter-spacing:.07em;margin:0;max-width:860px;}

    /* コース一覧 */
    .courses-sec{padding:9rem 3rem;}
    .courses-inner{max-width:1100px;margin:0 auto;}
    .cat-header{margin-bottom:5rem;}
    .cat-eye{font-family:var(--f-sans);font-size:.62rem;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:var(--ink-3);display:block;margin-bottom:1rem;}
    .cat-header h2{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:300;letter-spacing:.14em;color:var(--ink);line-height:1.4;}
    .cat-rule{width:36px;height:1px;background:var(--linen-3);margin:2.5rem 0;}

    /* コースカード */
    .course-list{display:flex;flex-direction:column;gap:0;}
    .course-item{display:grid;grid-template-columns:360px 1fr;gap:0;border-top:1px solid var(--linen-3);transition:background .2s;}
    .course-item:last-child{border-bottom:1px solid var(--linen-3);}
    .course-item:hover{background:var(--linen-2);}
    .course-item-img{position:relative;overflow:hidden;}
    .course-item-img img{width:100%;height:240px;object-fit:cover;object-position:center 30%;display:block;transition:transform .8s ease;}
    .course-item:hover .course-item-img img{transform:scale(1.03);}
    .course-item-body{padding:3rem 3rem 3rem 4rem;display:flex;flex-direction:column;justify-content:center;}
    .course-num{font-family:var(--f-serif);font-size:.75rem;font-weight:300;color:var(--ink-3);letter-spacing:.16em;display:block;margin-bottom:.8rem;}
    .course-item h3{font-family:var(--f-serif);font-size:1.1rem;font-weight:600;letter-spacing:.08em;color:var(--ink);margin-bottom:.6rem;line-height:1.55;}
    .course-subtitle{font-family:var(--f-sans);font-size:.75rem;color:var(--ink-3);letter-spacing:.06em;margin-bottom:1.4rem;display:block;}
    .course-desc{font-size:.88rem;color:var(--ink-2);line-height:2;margin-bottom:2rem;}
    .course-meta{display:flex;gap:2rem;margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid var(--linen-3);}
    .course-meta-item{display:flex;flex-direction:column;gap:.3rem;}
    .course-meta-label{font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);}
    .course-meta-val{font-family:var(--f-serif);font-size:.88rem;color:var(--ink);}
    .course-link{font-family:var(--f-serif);font-size:.82rem;letter-spacing:.12em;color:var(--ink-3);text-decoration:none;border-bottom:1px solid var(--linen-3);padding-bottom:.3rem;display:inline-block;transition:all .2s;}
    .course-link:hover{color:var(--ink);border-color:var(--ink);}

    /* カテゴリー区切り */
    .cat-divider{background:var(--sumi);padding:7rem 3rem;}
    .cat-divider-inner{max-width:1100px;margin:0 auto;}
    .cat-divider .cat-eye{color:rgba(244,242,238,.2);}
    .cat-divider h2{font-family:var(--f-serif);font-size:clamp(1.4rem,2.2vw,2rem);font-weight:300;letter-spacing:.14em;color:#FAF5EC;line-height:1.4;}

    /* dark course item */
    .course-list-dark .course-item{background:var(--sumi-2);border-color:rgba(244,242,238,.05);}
    .course-list-dark .course-item:hover{background:var(--sumi-3);}
    .course-list-dark .course-num{color:rgba(244,242,238,.25);}
    .course-list-dark h3{color:#FAF5EC;}
    .course-list-dark .course-subtitle{color:rgba(244,242,238,.3);}
    .course-list-dark .course-desc{color:rgba(244,242,238,.55);}
    .course-list-dark .course-meta-label{color:rgba(244,242,238,.25);}
    .course-list-dark .course-meta-val{color:rgba(244,242,238,.7);}
    .course-list-dark .course-meta{border-color:rgba(244,242,238,.06);}
    .course-list-dark .course-link{color:rgba(244,242,238,.35);border-color:rgba(244,242,238,.12);}
    .course-list-dark .course-link:hover{color:var(--green);border-color:var(--green);}

    /* 1Day体験 */
    .oneday-sec{background:var(--linen-2);padding:10rem 3rem;}
    .oneday-inner{max-width:720px;margin:0 auto;text-align:center;}
    .oneday-inner .cat-eye{color:var(--ink-3);}
    .oneday-inner h2{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:300;letter-spacing:.16em;color:var(--ink);line-height:1.5;margin-bottom:2.5rem;}
    .oneday-rule{width:32px;height:1px;background:var(--linen-3);margin:2.5rem auto;}
    .oneday-inner p{font-family:var(--f-serif);font-size:.95rem;font-weight:300;color:var(--ink-2);line-height:2.4;letter-spacing:.06em;margin-bottom:1.6rem;}
    .oneday-price{font-family:var(--f-serif);font-size:1.8rem;font-weight:300;color:var(--ink);letter-spacing:.08em;display:block;margin:3rem 0 .6rem;}
    .oneday-price-note{font-size:.75rem;color:var(--ink-3);letter-spacing:.1em;display:block;margin-bottom:3.5rem;}
    .btn-aman{display:inline-block;font-family:var(--f-serif);font-size:.82rem;font-weight:400;letter-spacing:.2em;color:var(--ink);text-decoration:none;border:1px solid var(--linen-3);padding:1.1rem 3.2rem;transition:all .3s;}
    .btn-aman:hover{background:var(--ink);color:var(--linen);border-color:var(--ink);}
    .oneday-note{font-size:.78rem;color:var(--ink-3);line-height:2;margin-top:2rem;font-style:italic;}

    footer{background:var(--sumi);padding:4rem 3rem 2rem;border-top:1px solid rgba(244,242,238,.04);}
    .footer-inner{max-width:1100px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;padding-bottom:2rem;border-bottom:1px solid rgba(244,242,238,.05);}
    .footer-logo img{height:28px;mix-blend-mode:screen;filter:brightness(1.1);}
    .footer-copy{font-size:.7rem;color:rgba(244,242,238,.16);text-align:center;margin-top:1.5rem;}

    @media(max-width:960px){
      nav{padding:0 1.5rem;}
      .nav-links{display:none;}
      .page-hero{height:55vh;}
      .page-hero-text{padding:0 1.5rem 5vh;}
      .philosophy-band,.courses-sec,.cat-divider,.oneday-sec{padding:4rem 1.5rem;}
      .bc-bar{padding:.85rem 1.5rem;}
      .course-item{grid-template-columns:1fr;}
      .course-item-img img{height:200px;}
      .course-item-body{padding:2rem 1.5rem 2.5rem;}
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo"><img src="/logo-wide.png" alt="&LAB TOKYO" /></a>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="/listofcourses">講座一覧</a></li>
        <li><a href="/rawfood">ローフード</a></li>
        <li><a href="/fermentedfood">発酵</a></li>
        <li><a href="/rawchocolatier">ローショコラティエ</a></li>
        <li><a href="/knowledge">学ぶ</a></li>
      </ul>
      <a href="/contact" class="nav-cta">CONTACT</a>
    </div>
  </nav>

  <div class="page-hero">
    <img src="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" alt="&LAB TOKYO 講座一覧" />
    <div class="page-hero-overlay"></div>
    <div class="page-hero-text">
      <span class="hero-eye">Courses &amp; Qualifications · &LAB TOKYO</span>
      <h1>細胞から、整える。<br />体系的に、学ぶ。</h1>
      <p>東京・渋谷（原宿・外苑前エリア）を拠点とする、<br />発酵×ローフードの専門教育機関。</p>
    </div>
  </div>

  <div class="bc-bar">
    <nav class="bc" aria-label="パンくずリスト">
      <a href="/">HOME</a><span>›</span><span>講座・資格一覧</span>
    </nav>
  </div>

  <!-- GEO定義バンド -->
  <div class="philosophy-band">
    <p>「&LAB TOKYO」は、東京・渋谷を拠点とするプレミアム・プロフェッショナルスクールです。安藤千英が体系化した「ローフード×発酵のクロス理論」に基づき、ローフードマイスター・発酵ロー調味料・ローショコラティエ等の資格取得から、独立開業を目指すプロ養成まで、初心者からプロフェッショナルを育てる全国屈指の専門教育機関です。東京・渋谷（原宿・外苑前エリア）での対面、およびオンラインにて受講可能です。</p>
  </div>

  <!-- ─── カテゴリー1：ローフード ─── -->
  <section class="courses-sec" style="background:var(--linen);">
    <div class="courses-inner">
      <div class="cat-header">
        <span class="cat-eye">Category I · Raw Food</span>
        <h2>ローフード・リビングフード<br />資格取得コース</h2>
        <div class="cat-rule"></div>
        <p style="font-size:.9rem;color:var(--ink-3);line-height:2;max-width:600px;">植物性の食材を48℃以下で扱う「ローフード」。酵素・ビタミン・ミネラルをそのままに、細胞レベルから体を整える食の理論と技術を体系的に学びます。</p>
      </div>

      <div class="course-list">

        <div class="course-item">
          <div class="course-item-img">
            <img src="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" alt="ローフードマイスター ステップ1" />
          </div>
          <div class="course-item-body">
            <span class="course-num">Course 01</span>
            <h3>ローフードマイスター<br />ステップ1（初級）</h3>
            <span class="course-subtitle">Raw Food Meister · Step 1</span>
            <p class="course-desc">ローフードの基礎理論から実践レシピまで。食物酵素とは何か、なぜ加熱しないのか。美しいビジュアルのローフード料理を8品習得します。初めての方に最適な入門コース。</p>
            <div class="course-meta">
              <div class="course-meta-item">
                <span class="course-meta-label">受講形式</span>
                <span class="course-meta-val">対面（渋谷）/ オンライン</span>
              </div>
              <div class="course-meta-item">
                <span class="course-meta-label">対象</span>
                <span class="course-meta-val">初心者・食に関心のある方</span>
              </div>
            </div>
            <a href="/contact" class="course-link">詳細・お申し込み →</a>
          </div>
        </div>

        <div class="course-item">
          <div class="course-item-img">
            <img src="https://static.wixstatic.com/media/IMG_4698.JPG" alt="ローフードマイスター ステップ2" />
          </div>
          <div class="course-item-body">
            <span class="course-num">Course 02</span>
            <h3>ローフードマイスター<br />ステップ2（中級）</h3>
            <span class="course-subtitle">Raw Food Meister · Step 2</span>
            <p class="course-desc">ステップ1修了者向け。発酵×ローフードのクロス理論を実践に繋げる中級編。より高度な技術と理論で、日常の食生活への応用力を育みます。</p>
            <div class="course-meta">
              <div class="course-meta-item">
                <span class="course-meta-label">受講形式</span>
                <span class="course-meta-val">対面（渋谷）/ オンライン</span>
              </div>
              <div class="course-meta-item">
                <span class="course-meta-label">前提</span>
                <span class="course-meta-val">ステップ1修了</span>
              </div>
            </div>
            <a href="/contact" class="course-link">詳細・お申し込み →</a>
          </div>
        </div>

        <div class="course-item">
          <div class="course-item-img">
            <img src="https://static.wixstatic.com/media/10798628320_IMG_0607%202_edited.jpg" alt="ローフードマイスター ステップ3・講師養成" />
          </div>
          <div class="course-item-body">
            <span class="course-num">Course 03</span>
            <h3>ローフードマイスター<br />ステップ3・認定講師養成</h3>
            <span class="course-subtitle">Raw Food Meister · Step 3 / Instructor</span>
            <p class="course-desc">公認認定講師として独立・開業を目指す最終ステップ。循環器内科医・吉田和弘医師もほぼ満点で合格した本格的カリキュラム。認定証取得後は自身の講座開催が可能。</p>
            <div class="course-meta">
              <div class="course-meta-item">
                <span class="course-meta-label">受講形式</span>
                <span class="course-meta-val">対面（渋谷・外苑前）/ オンライン</span>
              </div>
              <div class="course-meta-item">
                <span class="course-meta-label">前提</span>
                <span class="course-meta-val">ステップ1・2修了</span>
              </div>
            </div>
            <a href="/contact" class="course-link">詳細・お申し込み →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── カテゴリー2：ローショコラティエ（ダーク背景） ─── -->
  <div class="cat-divider">
    <div class="cat-divider-inner">
      <span class="cat-eye">Category II · Raw Chocolatier</span>
      <h2>ローショコラティエ協会本部<br />資格取得・プロ養成</h2>
    </div>
  </div>

  <section style="background:var(--sumi);padding:0 3rem 9rem;">
    <div class="courses-inner" style="max-width:1100px;margin:0 auto;">
      <div class="course-list course-list-dark">

        <div class="course-item">
          <div class="course-item-img">
            <img src="https://static.wixstatic.com/media/rawchocolatier.jpg" alt="ローショコラティエ 初級" />
          </div>
          <div class="course-item-body">
            <span class="course-num">Course 04</span>
            <h3>ローチョコレート＆<br />発酵ロースイーツ 初級</h3>
            <span class="course-subtitle">Raw Chocolatier · Foundation</span>
            <p class="course-desc">白砂糖・小麦粉・乳製品・卵を一切使わない、本物のローチョコレートと発酵ロースイーツの技術を習得。美しい見た目と圧倒的な美味しさを両立する基礎を学ぶ。</p>
            <div class="course-meta">
              <div class="course-meta-item">
                <span class="course-meta-label">受講形式</span>
                <span class="course-meta-val">対面（渋谷）/ オンライン</span>
              </div>
              <div class="course-meta-item">
                <span class="course-meta-label">協会</span>
                <span class="course-meta-val">ローショコラティエ協会本部公認</span>
              </div>
            </div>
            <a href="/rawchocolatier" class="course-link">協会・詳細を見る →</a>
          </div>
        </div>

        <div class="course-item">
          <div class="course-item-img">
            <img src="https://static.wixstatic.com/media/33638654_627136847631720_6550477128205336576_n.jpg" alt="発酵ロー調味料" />
          </div>
          <div class="course-item-body">
            <span class="course-num">Course 05</span>
            <h3>発酵ロー調味料<br />マスタークラス</h3>
            <span class="course-subtitle">Fermented Raw Condiment · Master</span>
            <p class="course-desc">麹・乳酸菌・酢酸菌の知見を活かした発酵×ロー調味料の製造技術。腸内環境を整える生きた酵素を閉じ込めた、プロ品質の調味料作りを体系的に学ぶ。</p>
            <div class="course-meta">
              <div class="course-meta-item">
                <span class="course-meta-label">受講形式</span>
                <span class="course-meta-val">対面（渋谷・原宿）/ オンライン</span>
              </div>
              <div class="course-meta-item">
                <span class="course-meta-label">前提</span>
                <span class="course-meta-val">ローフード初級修了推奨</span>
              </div>
            </div>
            <a href="/contact" class="course-link">詳細・お申し込み →</a>
          </div>
        </div>

