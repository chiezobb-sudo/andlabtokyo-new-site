---
import Layout from '../layouts/Layout.astro';
import OneDaySection from '../components/OneDaySection.astro';

// 写真URL定義（絶対パス）
const HERO_IMG = "https://static.wixstatic.com/media/857257_2f8d5c79f12f4e9593729e0260b5c3a6~mv2.jpg/v1/fill/w_2898,h_1304,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/857257_2f8d5c79f12f4e9593729e0260b5c3a6~mv2.jpg";
const RAWFOOD_IMG = "https://static.wixstatic.com/media/857257_8fddc85939c749f8ba4892cfa56de3c6~mv2.jpg/v1/fill/w_1450,h_970,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/857257_8fddc85939c749f8ba4892cfa56de3c6~mv2.jpg";
const FERMENT_IMG = "https://static.wixstatic.com/media/857257_03673322d71343759c8824f0c4398188~mv2.jpg";
const CHOCO_IMG = "https://static.wixstatic.com/media/857257_6f54c9c64603403290632b724f796a55~mv2.jpg";
const PROFILE_IMG = "https://static.wixstatic.com/media/745f65_69894e63459c44719001199341492987~mv2.jpg";
---

<Layout title="&LAB TOKYO | 表参道・渋谷のローフードと発酵料理ラボ">
    <!-- HERO SECTION -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <!-- ビデオがある場合はビデオを表示、なければ高品質静止画 -->
            <video autoplay muted loop playsinline poster={HERO_IMG} class="w-full h-full object-cover">
                <source src="/hero-video.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-black/20"></div>
        </div>
        <div class="relative z-10 text-center text-white px-6">
            <h1 class="text-4xl md:text-5xl font-extralight tracking-[0.4em] mb-12 leading-relaxed animate-fade-in">
                これからの私を、<br>美しく「醸す」。
            </h1>
            <div class="w-[1px] h-32 bg-white/40 mx-auto animate-scale-y"></div>
            <p class="mt-12 text-[10px] tracking-[0.5em] uppercase font-light opacity-80">Lifestyle Lab · Tokyo Shibuya</p>
        </div>
    </section>

    <!-- PHILOSOPHY / CONCEPT -->
    <section class="py-48 px-8 bg-[#FAF9F6]">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-24">
            <div class="w-full md:w-1/2">
                <img src={PROFILE_IMG} alt="安藤千英" class="w-full aspect-[3/4] object-cover shadow-sm" />
            </div>
            <div class="w-full md:w-1/2 space-y-12">
                <span class="text-[10px] tracking-[0.4em] uppercase text-[#B4934B]">Concept</span>
                <h2 class="text-2xl md:text-3xl font-extralight tracking-[0.2em] leading-relaxed">
                    細胞からデザインする、<br>一生モノの心と体。
                </h2>
                <p class="text-sm leading-[2.5] font-light text-gray-500 tracking-[0.1em]">
                    表参道の喧騒を離れた隠れ家ラボラトリー。<br>
                    10年の歳月を経て体系化された「発酵×ローフード」のクロス理論。<br>
                    それは単なる料理教室ではなく、あなたの生命力を最大化するための聖域。
                </p>
                <a href="/brand" class="inline-block border-b border-gray-300 pb-2 text-[10px] tracking-[0.3em] uppercase hover:border-[#B4934B] transition">Read Our Story</a>
            </div>
        </div>
    </section>

    <!-- COURSES SELECTION -->
    <section class="py-48 bg-white px-8 md:px-20">
        <div class="text-center mb-32">
            <h2 class="text-3xl font-extralight tracking-[0.4em] uppercase">Courses</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 max-w-7xl mx-auto">
            <!-- Raw Food -->
            <a href="/rawfood-kentei-meister" class="group">
                <div class="aspect-[4/5] overflow-hidden mb-8">
                    <img src={RAWFOOD_IMG} alt="Raw Food" class="w-full h-full object-cover group-hover:scale-105 transition duration-1000" />
                </div>
                <h3 class="text-sm tracking-[0.2em] font-medium mb-4">Raw Food Meister</h3>
                <p class="text-[11px] text-gray-400 leading-relaxed tracking-[0.1em]">酵素を活かし、身体の内側から再生を促す究極のメソッド。</p>
            </a>

            <!-- Fermentation -->
            <a href="/koji-fermentation-experience-tokyo" class="group mt-12 md:mt-24">
                <div class="aspect-[4/5] overflow-hidden mb-8">
                    <img src={FERMENT_IMG} alt="Fermentation" class="w-full h-full object-cover group-hover:scale-105 transition duration-1000" />
                </div>
                <h3 class="text-sm tracking-[0.2em] font-medium mb-4">UMAMI & KOJI LAB</h3>
                <p class="text-[11px] text-gray-400 leading-relaxed tracking-[0.1em]">日本の知恵、麹。五感で醸す特別な発酵エクスペリエンス。</p>
            </a>

            <!-- Raw Chocolate -->
            <a href="/rawchocolatier" class="group">
                <div class="aspect-[4/5] overflow-hidden mb-8">
                    <img src={CHOCO_IMG} alt="Raw Chocolate" class="w-full h-full object-cover group-hover:scale-105 transition duration-1000" />
                </div>
                <h3 class="text-sm tracking-[0.2em] font-medium mb-4">Raw Chocolatier</h3>
                <p class="text-[11px] text-gray-400 leading-relaxed tracking-[0.1em]">罪悪感のない、食べるサプリメントとしてのチョコレート教育。</p>
            </a>
        </div>
    </section>

    <!-- 1Day Experience Invitation -->
    <OneDaySection />
</Layout>

<style>
    :global(.animate-fade-in) { animation: fadeIn 3s ease-out forwards; }
    :global(.animate-scale-y) { animation: scaleY 2s ease-out forwards; transform-origin: top; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes scaleY { from { transform: scaleY(0); } to { transform: scaleY(1); } }
</style>
