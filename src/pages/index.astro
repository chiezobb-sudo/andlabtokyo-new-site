---
import Layout from '../layouts/Layout.astro';
import OneDaySection from '../components/OneDaySection.astro';

// Image URLs
const HERO_RIGHT = "https://static.wixstatic.com/media/857257_2f8d5c79f12f4e9593729e0260b5c3a6~mv2.jpg/v1/fill/w_2898,h_1304,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/857257_2f8d5c79f12f4e9593729e0260b5c3a6~mv2.jpg";
const TWO_DOORS_LEFT = "https://static.wixstatic.com/media/857257_8fddc85939c749f8ba4892cfa56de3c6~mv2.jpg";
const TWO_DOORS_RIGHT = "https://static.wixstatic.com/media/857257_03673322d71343759c8824f0c4398188~mv2.jpg";
---

<Layout title="発酵と、美の学校。 | &LAB TOKYO">

  <!-- HERO SECTION -->
  <section style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 100px);
    background: #FAF9F6;
  ">
    <!-- LEFT: TEXT -->
    <div style="
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 4rem;
      position: relative;
    ">
      <h1 style="
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 300;
        line-height: 1.4;
        margin-bottom: 2rem;
        color: #1C1C1A;
        letter-spacing: 0.08em;
      ">
        発酵と、<br>美の学校。
      </h1>

      <p style="
        font-size: 12px;
        line-height: 2.2;
        color: #7A7A72;
        margin-bottom: 3rem;
        letter-spacing: 0.12em;
        max-width: 320px;
      ">
        Fermentation and Raw Food School<br>in Omotesando, Tokyo.
      </p>

      <a href="/brand" style="
        display: inline-block;
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #1C1C1A;
        text-decoration: none;
        border-bottom: 1px solid #1C1C1A;
        padding-bottom: 0.5rem;
        transition: opacity 0.3s;
      ">
        &LAB TOKYO
      </a>

      <!-- SCROLL INDICATOR -->
      <div style="
        position: absolute;
        bottom: 3rem;
        left: 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      ">
        <span style="
          font-size: 9px;
          letter-spacing: 0.2em;
          color: #7A7A72;
          text-transform: uppercase;
        ">Scroll</span>
        <div style="
          width: 1px;
          height: 32px;
          background: #7A7A72;
          opacity: 0.4;
        "></div>
      </div>
    </div>

    <!-- RIGHT: IMAGE -->
    <div style="
      overflow: hidden;
      background: linear-gradient(135deg, #f0ede8, #e8e5e0);
    ">
      <img
        src={HERO_RIGHT}
        alt="&LAB TOKYO ラボスペース"
        style="
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
        "
      />
    </div>
  </section>

  <!-- THE TWO DOORS -->
  <section style="
    padding: 8rem 4rem;
    background: #FAF9F6;
  ">
    <div style="
      max-width: 1200px;
      margin: 0 auto;
    ">
      <!-- SECTION HEADER -->
      <div style="
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 4rem;
      ">
        <h2 style="
          font-size: 2.5rem;
          font-weight: 300;
          letter-spacing: 0.1em;
          color: #1C1C1A;
        ">
          The Two Doors
        </h2>
        <span style="
          font-size: 13px;
          color: #7A7A72;
          letter-spacing: 0.2em;
        ">
          ふたつの扉
        </span>
      </div>

      <!-- CARDS GRID -->
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        margin-bottom: 4rem;
      ">
        <!-- CARD 01: PROFESSIONAL -->
        <a href="/listofcourses" style="
          text-decoration: none;
          color: inherit;
          display: block;
          group: 'card-01';
        ">
          <div style="
            position: relative;
            aspect-ratio: 4/5;
            overflow: hidden;
            margin-bottom: 2rem;
            background: #e0ddd8;
          ">
            <img
              src={TWO_DOORS_LEFT}
              alt="Professional Courses"
              style="
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: center;
                transition: transform 0.8s ease;
              "
            />
            <!-- OVERLAY TEXT -->
            <div style="
              position: absolute;
              inset: 0;
              display: flex;
              flex-direction: column;
              justify-content: center;
              align-items: center;
              background: rgba(0, 0, 0, 0.2);
              color: white;
              text-align: center;
              padding: 2rem;
            ">
              <div style="
                font-size: 3.2rem;
                font-weight: 200;
                letter-spacing: 0.1em;
                margin-bottom: 1rem;
              ">01</div>
              <div style="
                font-size: 13px;
                letter-spacing: 0.2em;
                font-weight: 400;
              ">
                PROFESSIONAL<br>COURSES
              </div>
            </div>
          </div>
          <h3 style="
            font-size: 13px;
            letter-spacing: 0.1em;
            margin-bottom: 0.8rem;
            color: #1C1C1A;
          ">Professional Courses</h3>
          <p style="
            font-size: 11px;
            line-height: 1.8;
            color: #7A7A72;
            letter-spacing: 0.08em;
          ">
            高度なローフードと発酵の技術を体系化した本講座。
          </p>
        </a>

        <!-- CARD 02: KOJI WORKSHOPS -->
        <a href="/koji-fermentation-experience-tokyo" style="
          text-decoration: none;
          color: inherit;
          display: block;
          margin-top: 3rem;
        ">
          <div style="
            position: relative;
            aspect-ratio: 4/5;
            overflow: hidden;
            margin-bottom: 2rem;
            background: #e0ddd8;
          ">
            <img
              src={TWO_DOORS_RIGHT}
              alt="KOJI Workshops"
              style="
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: center;
                transition: transform 0.8s ease;
              "
            />
            <!-- OVERLAY TEXT -->
            <div style="
              position: absolute;
              inset: 0;
              display: flex;
              flex-direction: column;
              justify-content: center;
              align-items: center;
              background: rgba(0, 0, 0, 0.2);
              color: white;
              text-align: center;
              padding: 2rem;
            ">
              <div style="
                font-size: 3.2rem;
                font-weight: 200;
                letter-spacing: 0.1em;
                margin-bottom: 1rem;
              ">02</div>
              <div style="
                font-size: 13px;
                letter-spacing: 0.2em;
                font-weight: 400;
              ">
                TRADITIONAL<br>KOJI WORKSHOPS
              </div>
            </div>
          </div>
          <h3 style="
            font-size: 13px;
            letter-spacing: 0.1em;
            margin-bottom: 0.8rem;
            color: #1C1C1A;
          ">Traditional KOJI Workshops</h3>
          <p style="
            font-size: 11px;
            line-height: 1.8;
            color: #7A7A72;
            letter-spacing: 0.08em;
          ">
            日本の知恵を五感で学ぶ、特別な発酵体験。
          </p>
        </a>
      </div>

      <!-- VERTICAL TEXT ON RIGHT -->
      <div style="
        position: absolute;
        right: 4rem;
        top: 50%;
        transform: translateY(-50%);
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-size: 11px;
        color: #7A7A72;
        letter-spacing: 0.15em;
        opacity: 0.6;
      ">
        学ぶこととは、未来の美しさをつくること。
      </div>
    </div>
  </section>

  <!-- 1DAY SECTION -->
  <OneDaySection />

</Layout>

<style>
  img {
    display: block;
  }

  a {
    transition: opacity 0.3s ease;
  }

  a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    section {
      display: block !important;
      padding: 4rem 1.5rem !important;
    }

    h1 {
      font-size: 1.8rem !important;
    }
  }
</style>
