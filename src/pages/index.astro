---
const lang = Astro.url.searchParams.get('lang') || 'ja';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>安藤千英 | &LAB TOKYO — 発酵×ローフード 東京・渋谷</title>
  <meta name="description" content="ELLE gourmet認定料理家・安藤千英。東京・渋谷の発酵×ローフード ライフスタイルラボ。医師監修書籍、国内外の受講生実績。体験レッスン受付中。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━
       &LAB TOKYO — デザイントークン
       背景: 白・温かいクリーム系 / Shopifyカラーパレット参考
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    :root {
      /* 背景（白・クリーム系） */
      --bg-base:   #FAFAF8;   /* メイン背景（温かい白） */
      --bg-raised: #F5F1EB;   /* セクション段差A（クリーム） */
      --bg-card:   #EDE7DE;   /* セクション段差B（ベージュ） */
      --bg-dark:   #714329;   /* ダークセクション（深いテラコッタ） */
      --bg-nav:    rgba(250,250,248,.96);

      /* アクセント（テラコッタブラウン + ロゴグリーン） */
      --amber:     #714329;   /* プライマリアクセント（ボタン・下線） */
      --amber-lt:  #8B5534;   /* ホバー */
      --amber-mid: #B08463;   /* ミディアム */
      --amber-dim: rgba(113,67,41,.2); /* ボーダー */
      --leaf:      #4E8A18;   /* ロゴグリーン（ダーク葉） */
      --leaf-lt:   #6AAD22;   /* ロゴグリーン（ライト） */

      /* テキスト（濃いブラウン系） */
      --txt-head:  #1A0F08;   /* 見出し（ほぼ黒） */
      --txt-body:  #2C1F14;   /* 本文 */
      --txt-sub:   #7B6A5A;   /* サブテキスト */
      --txt-nav:   #3D2A1A;   /* ナビゲーション */
      --txt-btn:   #FAFAF8;   /* CTAボタン文字（白） */

      /* フォント — 2種のみ */
      --f-head: 'Cormorant Garamond', 'Noto Sans JP', serif;
      --f-body: 'Noto Sans JP', sans-serif;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--f-body);
      font-weight: 400;
      background: var(--bg-base);
      color: var(--txt-body);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* ━━ 言語切替（ナビ内右端に統合） ━━ */
    .lang { display: flex; align-items: center; gap: 0; margin-left: .8rem; }
    .lang a {
      padding: 6px 10px;
      font-family: var(--f-body);
      font-size: .72rem;
      font-weight: 500;
      letter-spacing: .5px;
      text-decoration: none;
      color: var(--txt-sub);
      border-left: 1px solid rgba(113,67,41,.15);
      transition: color .2s;
    }
    .lang a:first-child { border-left: none; }
    .lang a.on  { color: var(--amber); font-weight: 700; }
    .lang a:hover { color: var(--amber); }

    /* ━━ ナビゲーション ━━ */
    nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 500;
      height: 68px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.8rem;
      background: var(--bg-nav);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(113,67,41,.12);
    }
    .nav-logo img { height: 44px; width: auto; }
    .nav-right { display: flex; align-items: center; }
    .nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
    .nav-links a {
      font-family: var(--f-body);
      font-size: .875rem;
      font-weight: 500;
      letter-spacing: .5px;
      text-decoration: none;
      color: var(--txt-nav);
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--amber-lt); }
    .nav-cta {
      padding: .5rem 1.4rem !important;
      border: 1px solid var(--amber-dim) !important;
      color: var(--amber) !important;
      border-radius: 2px;
    }
    .nav-cta:hover {
      background: var(--amber) !important;
      color: var(--txt-btn) !important;
    }

    /* ━━ Hero ━━ */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 640px;
      display: grid;
      grid-template-columns: 52% 48%;
      overflow: hidden;
    }
    .hero-left {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 120px 4vw 7vh 5vw;
      background: var(--bg-base);
      z-index: 1;
    }
    .hero-right { position: relative; overflow: hidden; }
    .hero-right img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: top center; display: block;
    }
    .hero-right::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to right, var(--bg-base) 0%, transparent 22%);
    }

    .hero-tag {
      font-family: var(--f-head);
      font-size: .8rem;
      font-weight: 400;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 2rem;
    }
    .hero h1 {
      font-family: var(--f-head);
      font-weight: 600;
      font-size: clamp(2rem, 3.6vw, 3.2rem);
      line-height: 1.45;
      color: var(--txt-head);
      margin-bottom: 1.2rem;
      letter-spacing: .3px;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--leaf);
      display: block;
    }
    .hero-name {
      font-family: var(--f-head);
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: 2.5px;
      color: var(--txt-sub);
      margin-bottom: .4rem;
    }
    .hero-title {
      font-family: var(--f-body);
      font-size: .82rem;
      font-weight: 400;
      color: var(--txt-sub);
      letter-spacing: .5px;
      margin-bottom: 2.8rem;
    }
    .hero-desc {
      font-family: var(--f-body);
      font-size: .95rem;
      font-weight: 400;
      color: var(--txt-body);
      line-height: 1.95;
      margin-bottom: 3rem;
      max-width: 400px;
    }

    /* ━━ ボタン ━━ */
    .btns { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-gold {
      display: inline-block;
      padding: .9rem 2.2rem;
      background: var(--amber);
      color: var(--txt-btn);
      font-family: var(--f-body);
      font-size: .875rem;
      font-weight: 700;
      letter-spacing: 1px;
      text-decoration: none;
      border-radius: 3px;
      transition: background .25s, transform .2s, box-shadow .2s;
    }
    .btn-gold:hover { background: var(--amber-lt); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(113,67,41,.25); }
    .btn-ghost {
      display: inline-block;
      padding: .9rem 2.2rem;
      border: 1.5px solid var(--amber);
      color: var(--amber);
      font-family: var(--f-body);
      font-size: .875rem;
      font-weight: 500;
      letter-spacing: .5px;
      text-decoration: none;
      border-radius: 3px;
      transition: all .25s;
      background: transparent;
    }
    .btn-ghost:hover {
      background: var(--amber);
      color: var(--txt-btn);
      transform: translateY(-2px);
    }

    /* ━━ Credentials strip ━━ */
    .cred-strip {
      background: var(--bg-card);
      padding: 1.6rem 5vw;
      border-top: 1px solid var(--gold-line);
      border-bottom: 1px solid var(--gold-line);
    }
    .cred-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 2.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .cred-item {
      display: flex;
      align-items: center;
      gap: .7rem;
      font-family: var(--f-body);
      font-size: .8rem;
      font-weight: 400;
      color: var(--txt-sub);
      letter-spacing: .3px;
      white-space: nowrap;
    }
    .cred-item span.dot {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--amber);
      flex-shrink: 0;
    }

    /* ━━ セクション共通 ━━ */
    .sec { padding: 7rem 5vw; }
    .sec-eye {
      font-family: var(--f-head);
      font-size: .78rem;
      font-weight: 400;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1.2rem;
    }
    .sec-h2 {
      font-family: var(--f-head);
      font-weight: 600;
      font-size: clamp(1.8rem, 3.2vw, 2.8rem);
      line-height: 1.5;
      color: var(--txt-head);
      white-space: pre-line;
    }
    .rule {
      width: 32px;
      height: 1px;
      background: var(--amber-dim);
      margin: 1.8rem 0 2.5rem;
    }
    .inner { max-width: 1100px; margin: 0 auto; }

    /* ━━ Story ━━ */
    .story { background: var(--bg-base); }
    .story-grid {
      display: grid;
      grid-template-columns: 45% 1fr;
      gap: 5rem;
      align-items: start;
    }
    .story-img { position: relative; overflow: hidden; }
    .story-img img {
      width: 100%; height: 520px;
      object-fit: cover; object-position: center top; display: block;
    }
    .story-img::before {
      content: '';
      position: absolute;
      inset: -6px;
      border: 1px solid rgba(196,122,58,.18);
      z-index: 1; pointer-events: none;
    }
    .story-body { padding-top: 1rem; }
    .story-body p {
      font-family: var(--f-body);
      font-size: .95rem;
      font-weight: 400;
      color: var(--txt-body);
      line-height: 2.1;
      margin-bottom: 1.4rem;
    }
    .story-body p strong { color: var(--txt-head); font-weight: 700; }
    .story-link {
      display: inline-block;
      margin-top: .8rem;
      font-family: var(--f-body);
      font-size: .85rem;
      font-weight: 500;
      color: var(--txt-sub);
      text-decoration: none;
      border-bottom: 1px solid rgba(192,182,168,.35);
      padding-bottom: 2px;
      transition: color .2s, border-color .2s;
    }
    .story-link:hover { color: var(--amber-lt); border-color: var(--amber); }

    /* ━━ For Whom ━━ */
    .forwhom { background: var(--bg-raised); }
    .forwhom-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 5rem;
      align-items: start;
      margin-top: 3.5rem;
    }
    .whom-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
    .whom-list li {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      font-family: var(--f-body);
      font-size: .95rem;
      font-weight: 400;
      color: var(--txt-body);
      line-height: 1.85;
    }
    .whom-list li::before {
      content: '—';
      color: var(--amber);
      flex-shrink: 0;
      margin-top: .05rem;
      font-weight: 400;
    }
    .forwhom-right {
      background: white;
      padding: 2.5rem;
      border-left: 3px solid var(--amber);
      box-shadow: 0 2px 16px rgba(113,67,41,.08);
    }
    .forwhom-right .label {
      font-family: var(--f-head);
      font-size: .75rem;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1.4rem;
      display: block;
    }
    .forwhom-right p {
      font-family: var(--f-body);
      font-size: .92rem;
      font-weight: 400;
      color: var(--txt-body);
      line-height: 2;
    }

    /* ━━ Theory ━━ */
    .theory { background: var(--bg-dark); text-align: center; padding: 7rem 5vw; color: #FAF5EC; }
    .theory .sec-eye { color: #D0B9A7; }
    .theory .sec-h2 { color: #FAF5EC; }
    .theory-formula {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      margin: 3.5rem 0;
      flex-wrap: wrap;
    }
    .theory-block {
      padding: 2.2rem 2.8rem;
      border: 1px solid rgba(250,245,236,.25);
      background: rgba(250,245,236,.05);
    }
    .theory-block .label {
      font-family: var(--f-head);
      font-size: .7rem;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #D0B9A7;
      margin-bottom: .8rem;
      display: block;
    }
    .theory-block h3 {
      font-family: var(--f-head);
      font-weight: 600;
      font-size: 1.5rem;
      color: #FAF5EC;
    }
    .theory-op {
      font-family: var(--f-head);
      font-size: 2.8rem;
      font-weight: 400;
      color: rgba(208,185,167,.6);
    }
    .theory-result {
      padding: 1.8rem 3.5rem;
      background: rgba(250,245,236,.12);
      border: 1px solid rgba(250,245,236,.35);
    }
    .theory-result h3 {
      font-family: var(--f-head);
      font-weight: 600;
      font-size: 1.3rem;
      color: #EDD9C0;
    }
    .theory-body {
      max-width: 600px;
      margin: 2rem auto 0;
      font-family: var(--f-body);
      font-size: .92rem;
      font-weight: 400;
      color: rgba(250,245,236,.8);
      line-height: 2;
    }

    /* ━━ Programs ━━ */
    .programs { background: var(--bg-base); }
    .prog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
      margin-top: 3.5rem;
    }
    .prog {
      position: relative;
      overflow: hidden;
      height: 460px;
      text-decoration: none;
      display: block;
    }
    .prog img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .8s ease;
      display: block;
    }
    .prog:hover img { transform: scale(1.04); }
    .prog-ov {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,23,21,.92) 0%, rgba(26,23,21,.15) 100%);
      transition: background .3s;
    }
    .prog:hover .prog-ov {
      background: linear-gradient(to top, rgba(26,23,21,.96) 0%, rgba(26,23,21,.3) 100%);
    }
    .prog-body { position: absolute; bottom: 0; left: 0; right: 0; padding: 2.5rem 2rem; }
    .prog-eye {
      font-family: var(--f-head);
      font-size: .68rem;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: .7rem;
      display: block;
    }
    .prog h3 {
      font-family: var(--f-head);
      font-weight: 600;
      font-size: 1.25rem;
      color: var(--txt-head);
      margin-bottom: .7rem;
    }
    .prog-detail {
      font-family: var(--f-body);
      font-size: .85rem;
      font-weight: 400;
      color: var(--txt-body);
      line-height: 1.85;
      margin-bottom: .9rem;
    }
    .prog-meta {
      font-family: var(--f-body);
      font-size: .78rem;
      font-weight: 500;
      color: var(--amber);
      letter-spacing: .5px;
    }

    /* ━━ Book + Credentials ━━ */
    .credentials { background: var(--bg-raised); }
    .cred-grid {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 5.5rem;
      align-items: start;
    }
    .book-cover img {
      width: 100%;
      border-radius: 3px;
      box-shadow: 0 24px 64px rgba(0,0,0,.55);
    }
    .cred-list { display: flex; flex-direction: column; gap: 2rem; }
    .cred-item-lg {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(196,122,58,.1);
    }
    .cred-item-lg:last-child { border-bottom: none; padding-bottom: 0; }
    .cred-icon {
      font-family: var(--f-head);
      font-size: 1.6rem;
      font-weight: 400;
      font-style: italic;
      color: rgba(196,122,58,.35);
      flex-shrink: 0;
      width: 2rem;
    }
    .cred-text h4 {
      font-family: var(--f-body);
      font-size: .95rem;
      font-weight: 700;
      color: var(--txt-head);
      margin-bottom: .4rem;
    }
    .cred-text p {
      font-family: var(--f-body);
      font-size: .88rem;
      font-weight: 400;
      color: var(--txt-sub);
      line-height: 1.85;
    }

    /* ━━ Testimonials (Custifyスタイル: 写真上・中央) ━━ */
    .testimonials { background: var(--bg-base); }
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3.5rem;
    }
    .testi {
      background: white;
      padding: 2.8rem 2.2rem 2.5rem;
      border-radius: 6px;
      box-shadow: 0 2px 20px rgba(113,67,41,.08);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      border-top: 3px solid var(--amber-mid);
    }
    .testi-img {
      width: 96px; height: 96px;
      border-radius: 50%;
      object-fit: cover; object-position: top center;
      margin-bottom: 1.8rem;
      border: 3px solid #EDE7DE;
      box-shadow: 0 4px 12px rgba(113,67,41,.12);
    }
    .testi-quote-mark {
      font-family: var(--f-head);
      font-size: 3rem;
      line-height: .6;
      color: #D0B9A7;
      margin-bottom: 1rem;
      display: block;
    }
    .testi-quote {
      font-family: var(--f-body);
      font-weight: 400;
      font-size: .92rem;
      color: var(--txt-body);
      line-height: 1.95;
      margin-bottom: 2rem;
      flex-grow: 1;
    }
    .testi-divider {
      width: 32px; height: 1px;
      background: #D0B9A7;
      margin: 0 auto 1.2rem;
    }
    .testi-name {
      font-family: var(--f-body);
      font-size: .9rem;
      font-weight: 700;
      color: var(--txt-head);
      letter-spacing: .3px;
    }
    .testi-role {
      font-family: var(--f-body);
      font-size: .78rem;
      font-weight: 400;
      color: var(--txt-sub);
      margin-top: .3rem;
      line-height: 1.6;
    }

    /* ━━ Blog ━━ */
    .blog-sec { background: var(--bg-raised); }
    .blog-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3rem;
    }
    .blog-link {
      font-family: var(--f-body);
      font-size: .85rem;
      font-weight: 500;
      color: var(--txt-sub);
      text-decoration: none;
      letter-spacing: .5px;
      transition: color .2s;
    }
    .blog-link:hover { color: var(--amber-lt); }
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .post {
      background: white;
      padding: 2.5rem 2rem;
      text-decoration: none;
      color: inherit;
      border-bottom: 2px solid transparent;
      transition: border-color .3s, background .3s;
      display: block;
    }
    .post:hover { border-bottom-color: var(--amber); background: var(--bg-raised); }
    .post-cat {
      font-family: var(--f-head);
      font-size: .7rem;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: .9rem;
      display: block;
    }
    .post h4 {
      font-family: var(--f-body);
      font-size: 1rem;
      font-weight: 500;
      color: var(--txt-head);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .post-date {
      font-family: var(--f-body);
      font-size: .78rem;
      font-weight: 400;
      color: var(--txt-sub);
      letter-spacing: .5px;
    }

    /* ━━ CTA ━━ */
    .cta-sec {
      background: var(--bg-dark);
      text-align: center;
      padding: 8rem 5vw;
      position: relative;
      overflow: hidden;
      color: #FAF5EC;
    }
    .cta-sec .sec-eye { color: #D0B9A7; }
    .cta-sec .sec-h2 { color: #FAF5EC; }
    .cta-sec::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(250,245,236,.05) 0%, transparent 68%);
    }
    .cta-inner { position: relative; max-width: 620px; margin: 0 auto; }
    .cta-body {
      font-family: var(--f-body);
      font-size: .95rem;
      font-weight: 400;
      color: rgba(250,245,236,.8);
      line-height: 2.1;
      margin: 2rem 0 3rem;
    }
