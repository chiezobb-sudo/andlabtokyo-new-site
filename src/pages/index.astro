---
// &LAB TOKYO - デザインカラー
const colors = {
	terracotta: '#d4923f',
	warmPink: '#d97d7d',
	deepNavy: '#0a0e27',
	cream: '#fef9f3'
};
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>&LAB TOKYO - Innovative Design Studio</title>
		<meta name="description" content="&LAB TOKYO - A modern design and technology studio creating elegant digital experiences." />
		<style define:vars={colors}>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
				scroll-behavior: smooth;
			}

			body {
				background-color: var(--cream);
				color: var(--deepNavy);
				line-height: 1.6;
			}

			/* ナビゲーション */
			nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 2rem 3rem;
				background-color: var(--cream);
				border-bottom: 1px solid rgba(10, 14, 39, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
			}

			.logo {
				font-size: 1.8rem;
				font-weight: 700;
				letter-spacing: 2px;
				color: var(--deepNavy);
			}

			.logo-mark {
				color: var(--terracotta);
				font-weight: 900;
			}

			nav ul {
				display: flex;
				list-style: none;
				gap: 2.5rem;
			}

			nav a {
				text-decoration: none;
				color: var(--deepNavy);
				font-size: 0.95rem;
				font-weight: 500;
				transition: color 0.3s ease;
				border-bottom: 2px solid transparent;
			}

			nav a:hover {
				color: var(--terracotta);
				border-bottom-color: var(--terracotta);
			}

			/* ヒーロー領域 */
			.hero {
				height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				background: linear-gradient(135deg, var(--cream) 0%, rgba(212, 146, 63, 0.05) 100%);
				padding: 4rem 2rem;
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				width: 400px;
				height: 400px;
				background: radial-gradient(circle, rgba(217, 125, 125, 0.1) 0%, transparent 70%);
				border-radius: 50%;
				top: -100px;
				right: -100px;
				z-index: 0;
			}

			.hero::after {
				content: '';
				position: absolute;
				width: 300px;
				height: 300px;
				background: radial-gradient(circle, rgba(212, 146, 63, 0.08) 0%, transparent 70%);
				border-radius: 50%;
				bottom: -50px;
				left: -50px;
				z-index: 0;
			}

			.hero-content {
				z-index: 1;
				max-width: 900px;
			}

			.hero h1 {
				font-size: clamp(2.5rem, 8vw, 5rem);
				line-height: 1.2;
				margin-bottom: 1.5rem;
				letter-spacing: -1px;
			}

			.hero-title {
				color: var(--deepNavy);
			}

			.hero-accent {
				color: var(--terracotta);
				display: block;
				margin-top: 0.5rem;
			}

			.hero p {
				font-size: 1.2rem;
				color: var(--deepNavy);
				opacity: 0.75;
				margin-bottom: 3rem;
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
			}

			.cta-buttons {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				flex-wrap: wrap;
			}

			.btn {
				padding: 1rem 2.5rem;
				font-size: 1rem;
				font-weight: 600;
				border: 2px solid;
				border-radius: 4px;
				cursor: pointer;
				text-decoration: none;
				display: inline-block;
				transition: all 0.3s ease;
				text-transform: uppercase;
				letter-spacing: 1px;
			}

			.btn-primary {
				background-color: var(--terracotta);
				color: var(--cream);
				border-color: var(--terracotta);
			}

			.btn-primary:hover {
				background-color: var(--warmPink);
				border-color: var(--warmPink);
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(217, 125, 125, 0.2);
			}

			.btn-secondary {
				background-color: transparent;
				color: var(--deepNavy);
				border-color: var(--deepNavy);
			}

			.btn-secondary:hover {
				background-color: var(--deepNavy);
				color: var(--cream);
				transform: translateY(-2px);
			}

			/* フィーチャー */
			.features {
				padding: 6rem 3rem;
				background-color: white;
			}

			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 3rem;
				max-width: 1200px;
				margin: 0 auto;
			}

			.feature-card {
				padding: 2rem;
				border-radius: 4px;
				border-left: 4px solid var(--terracotta);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				background-color: var(--cream);
			}

			.feature-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 15px 35px rgba(10, 14, 39, 0.1);
			}

			.feature-icon {
				font-size: 2.5rem;
				margin-bottom: 1rem;
			}

			.feature-card h3 {
				color: var(--deepNavy);
				margin-bottom: 1rem;
				font-size: 1.3rem;
			}

			.feature-card p {
				color: var(--deepNavy);
				opacity: 0.7;
				line-height: 1.8;
			}

			/* フッター */
			footer {
				background-color: var(--deepNavy);
				color: var(--cream);
				padding: 3rem;
				text-align: center;
				border-top: 3px solid var(--terracotta);
			}

			footer p {
				margin-bottom: 1rem;
				opacity: 0.9;
			}

			.footer-links {
				display: flex;
				justify-content: center;
				gap: 2rem;
				margin: 1.5rem 0;
			}

			.footer-links a {
				color: var(--terracotta);
				text-decoration: none;
				transition: opacity 0.3s ease;
			}

			.footer-links a:hover {
				opacity: 0.7;
			}

			.copyright {
				margin-top: 2rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(254, 249, 243, 0.2);
				opacity: 0.7;
				font-size: 0.9rem;
			}

			/* レスポンシブ */
			@media (max-width: 768px) {
				nav {
					flex-direction: column;
					padding: 1.5rem;
					gap: 1.5rem;
				}

				nav ul {
					flex-direction: column;
					gap: 1rem;
					text-align: center;
				}

				.cta-buttons {
					flex-direction: column;
					align-items: center;
				}

				.btn {
					width: 100%;
					max-width: 300px;
				}

				.features {
					padding: 3rem 1.5rem;
				}

				footer {
					padding: 2rem 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<!-- ナビゲーション -->
		<nav>
			<div class="logo">
				<span class="logo-mark">&</span>LAB TOKYO
			</div>
			<ul>
				<li><a href="#work">Work</a></li>
				<li><a href="#about">About</a></li>
				<li><a href="#contact">Contact</a></li>
			</ul>
		</nav>

		<!-- ヒーロー -->
		<section class="hero">
			<div class="hero-content">
				<h1>
					<span class="hero-title">Crafting Digital</span>
					<span class="hero-accent">Experiences</span>
				</h1>
				<p>
					We create elegant, innovative solutions that transform ideas into beautiful digital realities.
					Specializing in modern design and cutting-edge technology.
				</p>
				<div class="cta-buttons">
					<a href="#work" class="btn btn-primary">Explore Our Work</a>
					<a href="#contact" class="btn btn-secondary">Get In Touch</a>
				</div>
			</div>
		</section>

		<!-- フィーチャー -->
		<section class="features" id="work">
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-icon">🎨</div>
					<h3>Design Excellence</h3>
					<p>
						Thoughtfully crafted designs that blend aesthetics with functionality, creating memorable digital experiences.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">⚡</div>
					<h3>Modern Technology</h3>
					<p>
						Built with the latest technologies and best practices, ensuring performance, scalability, and reliability.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🚀</div>
					<h3>Innovation Driven</h3>
					<p>
						We stay ahead of trends, continuously exploring new possibilities to deliver cutting-edge solutions.
					</p>
				</div>
			</div>
		</section>

		<!-- フッター -->
		<footer id="contact">
			<p><strong>&LAB TOKYO</strong></p>
			<p>Innovative Design & Technology Studio</p>
			<div class="footer-links">
				<a href="mailto:info@andlabtokyo.com">Email</a>
				<a href="#">Instagram</a>
				<a href="#">Twitter</a>
			</div>
			<div class="copyright">
				<p>&copy; 2026 &LAB TOKYO. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
