---
const lang = Astro.url.searchParams.get('lang') || 'ja';

const t = {
  ja: {
    nav: ['レッスン', 'Hacco LAB', '安藤千英について', 'お問い合わせ'],
    navHref: ['#lessons', '#hacco', '#about', '#contact'],
    heroEye: 'Raw Food × Fermentation · Tokyo',
    heroH1a: 'これからの私を、',
    heroH1b: '美しく「醸す」。',
    heroSub: '細胞からデザインする、一生モノの心と体。',
    heroCta: '&LABの世界へ',
    heroCtaSub: 'まずは体験レッスンから',
    mosaicLabel: 'OUR WORLD',
    conceptEye: 'About &LAB TOKYO',
    conceptH2: '美しさを、\n自ら「つくる」人へ。',
    conceptBody: '&LAB TOKYOは、東京・渋谷を拠点とする「発酵×ローフード」のクロス理論でライフスタイルを進化させるラボです。\n\n単なる「料理」ではありません。細胞から目覚めるような生きたエネルギー（酵素）を取り入れ、古来の知恵である「発酵」で内側から美しさを醸成する。\n\n経営者、専門職、自分自身の可能性を信じるすべての女性へ。\nあなたが持つ本来の輝きを、最大化させる場所でありたい。',
    conceptCredit: 'ELLE gourmet認定料理家　安藤千英',
    s1Eye: 'Program 01', s1H: 'ローフード', s1B: '48℃以下の調理で酵素と栄養を壊さない。生きた食材のチカラで細胞から整えます。',
    s2Eye: 'Program 02', s2H: 'Hacco LAB', s2B: '麹・味噌・醤油など日本の発酵文化を現代の暮らしへ。腸から、美しさをデザインします。',
    s3Eye: 'Program 03', s3H: 'ローチョコレート', s3B: '日本ローチョコレーティエ協会公認。カカオの栄養を活かした、大人のための甘さ。',
    lessonEye: 'Lesson Info',
    lessonH: 'すべての女性が\n輝ける場所として。',
    features: [
      ['少人数制', '1〜4名。あなただけに向き合う時間。'],
      ['初心者歓迎', '知識ゼロから始められます。'],
      ['対面・オンライン', '渋谷の教室、またはご自宅から。'],
      ['¥8,000〜 入会費なし', '気軽に、でも本気で。'],
    ],
    ctaEye: 'First Step',
    ctaH: '忙しさを、輝きに変える。',
    ctaBody: '経営者・専門職・自分を更新し続けたいすべての女性のための\n発酵×ローフード ライフスタイル・ラボ',
    ctaBtn: '体験レッスンを予約する',
    ctaSub: 'お問い合わせ・ご質問はこちら →',
    footerTagline: 'Raw Food × Fermentation\nLifestyle Lab · Tokyo Shibuya',
    copyright: '© 2026 &LAB TOKYO. All rights reserved.',
  },
  en: {
    nav: ['Lessons', 'Hacco LAB', 'About Chie', 'Contact'],
    navHref: ['#lessons', '#hacco', '#about', '#contact'],
    heroEye: 'Raw Food × Fermentation · Tokyo',
    heroH1a: 'Transform yourself,',
    heroH1b: 'beautifully.',
    heroSub: 'Designing body & mind from the cellular level.',
    heroCta: 'Enter &LAB World',
    heroCtaSub: 'Start with a trial lesson',
    mosaicLabel: 'OUR WORLD',
    conceptEye: 'About &LAB TOKYO',
    conceptH2: 'For those who\ncreate their own beauty.',
    conceptBody: '&LAB TOKYO is a lifestyle lab in Shibuya, Tokyo, evolving your life through the cross-theory of fermentation × raw food.\n\nWe go beyond "cooking." We invite living enzymes that awaken cells, and cultivate inner beauty through the ancient wisdom of fermentation.\n\nFor executives, professionals, and every woman who believes in her own potential. We exist to maximize your inherent brilliance.',
    conceptCredit: 'ELLE gourmet Certified Chef  Chie Ando',
    s1Eye: 'Program 01', s1H: 'Raw Food', s1B: 'Cooking below 48°C preserves enzymes and nutrients. Nourish your cells with living ingredients.',
    s2Eye: 'Program 02', s2H: 'Hacco LAB', s2B: 'Bringing Japanese fermentation traditions — koji, miso, soy sauce — into modern life.',
    s3Eye: 'Program 03', s3H: 'Raw Chocolate', s3B: 'Certified by the Japan Raw Chocolatier Association. Sophisticated sweetness that nourishes.',
    lessonEye: 'Lesson Info',
    lessonH: 'A place for every\nwoman to shine.',
    features: [
      ['Small Classes', 'Groups of 1-4. Time dedicated to you.'],
      ['Beginners Welcome', 'Start from absolute zero.'],
      ['In-Person & Online', 'Shibuya studio or from your home.'],
      ['From ¥8,000, No Membership', 'Easy to start, seriously transformative.'],
    ],
    ctaEye: 'First Step',
    ctaH: 'Turn your busy life into brilliance.',
    ctaBody: 'A fermentation × raw food lifestyle lab\nfor executives, professionals, and women who keep reinventing themselves.',
    ctaBtn: 'Book a Trial Lesson',
    ctaSub: 'Questions & inquiries →',
    footerTagline: 'Raw Food × Fermentation\nLifestyle Lab · Tokyo Shibuya',
    copyright: '© 2026 &LAB TOKYO. All rights reserved.',
  },
  zh: {
    nav: ['课程', 'Hacco LAB', '关于千英', '联系'],
    navHref: ['#lessons', '#hacco', '#about', '#contact'],
    heroEye: 'Raw Food × Fermentation · Tokyo',
    heroH1a: '从现在起，',
    heroH1b: '美丽地「酿造」自己。',
    heroSub: '从细胞设计，终身受益的身心。',
    heroCta: '进入&LAB世界',
    heroCtaSub: '从体验课开始',
    mosaicLabel: 'OUR WORLD',
    conceptEye: 'About &LAB TOKYO',
    conceptH2: '献给那些\n亲手创造美丽的人。',
    conceptBody: '&LAB TOKYO是位于东京涩谷的生活方式实验室，通过「发酵×生食」的交叉理论进化您的生活方式。\n\n这不仅仅是「料理」。摄取唤醒细胞的活性酶，用古老的发酵智慧从内到外培养美丽。\n\n献给企业家、专业人士，以及所有相信自己可能性的女性。',
    conceptCredit: 'ELLE gourmet认证料理家　安藤千英',
    s1Eye: 'Program 01', s1H: '生食料理', s1B: '48℃以下烹饪保留酶和营养素，用活食材的力量从细胞开始调整。',
    s2Eye: 'Program 02', s2H: 'Hacco LAB', s2B: '将麹、味噌等日本发酵文化融入现代生活，从肠道设计美丽。',
    s3Eye: 'Program 03', s3H: '生巧克力', s3B: '日本生巧克力师协会认证，保留可可营养的成熟甜蜜。',
    lessonEye: 'Lesson Info',
    lessonH: '让每位女性\n都能绽放光彩。',
    features: [
      ['小班制', '1〜4人，专注于您的时间。'],
      ['欢迎初学者', '从零开始也没问题。'],
      ['线下・线上', '涩谷教室或居家参加。'],
      ['¥8,000起，无入会费', '轻松开始，认真蜕变。'],
    ],
    ctaEye: 'First Step',
    ctaH: '将忙碌变成光芒。',
    ctaBody: '为企业家、专业人士\n以及不断更新自己的所有女性而生的发酵×生食生活方式实验室',
    ctaBtn: '预约体验课',
    ctaSub: '咨询与提问 →',
    footerTagline: 'Raw Food × Fermentation\nLifestyle Lab · Tokyo Shibuya',
    copyright: '© 2026 &LAB TOKYO. All rights reserved.',
  },
}[lang] || {};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>&LAB TOKYO | 発酵×ローフード ライフスタイル・ラボ 東京渋谷</title>
  <meta name="description" content="東京・渋谷。経営者・専門職女性のための発酵×ローフード ライフスタイル・ラボ。ELLE gourmet認定料理家・安藤千英が、細胞から整える一生モノの食と美を伝えます。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@300;400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:    #0e0c0a;
      --ink2:   #1c1915;
      --ink3:   #2e2b27;
      --warm:   #c8a96e;
      --warm2:  #e8d5b0;
      --muted:  #8a7f72;
      --cream:  #f5f0e8;
      --white:  #fdfaf5;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--ink);
      color: var(--cream);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── 言語スイッチャー ─── */
    .lang {
      position: fixed; top: 0; right: 0; z-index: 500;
      display: flex; gap: 1px;
      background: var(--ink2);
    }
    .lang a {
      display: block; padding: 10px 14px;
      font-size: .72rem; letter-spacing: 1px;
      text-decoration: none; color: var(--muted);
      transition: color .2s, background .2s;
    }
    .lang a.on { color: var(--warm); }
    .lang a:hover { color: var(--warm2); }

    /* ─── ナビ ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 400;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3rem;
      height: 68px;
      background: rgba(14,12,10,.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(200,169,110,.12);
    }
    .nav-logo img { height: 38px; width: auto; filter: brightness(1.05); }
    nav ul { display: flex; list-style: none; gap: 2.5rem; }
    nav a {
      text-decoration: none; color: rgba(245,240,232,.6);
      font-size: .82rem; letter-spacing: 1.5px;
      transition: color .25s;
    }
    nav a:hover { color: var(--warm); }
    .nav-cta {
      border: 1px solid rgba(200,169,110,.4) !important;
      padding: .45rem 1.2rem !important;
      border-radius: 1px;
      color: var(--warm) !important;
    }
    .nav-cta:hover { background: var(--warm) !important; color: var(--ink) !important; }

    /* ─── ヒーロー ─── */
    .hero {
      position: relative; height: 100vh; min-height: 640px;
      display: flex; align-items: flex-end;
      overflow: hidden;
    }
    .hero-img {
      position: absolute; inset: 0;
    }
    .hero-img img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 30%;
      display: block;
    }
    .hero-img::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(
        to top,
        rgba(14,12,10,.88) 0%,
        rgba(14,12,10,.45) 45%,
        rgba(14,12,10,.15) 100%
      );
    }
    .hero-body {
      position: relative; z-index: 1;
      padding: 0 5vw 7vh;
      max-width: 860px;
    }
    .eyebrow {
      font-size: .72rem; letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--warm); margin-bottom: 1.6rem;
      font-family: 'Cormorant Garamond', serif;
    }
    .hero h1 {
      font-family: 'Noto Serif JP', serif;
      font-weight: 200;
      font-size: clamp(2.6rem, 6.5vw, 5rem);
      line-height: 1.35;
      color: var(--white);
      letter-spacing: .5px;
      margin-bottom: .6rem;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--warm2);
      font-weight: 300;
    }
    .hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-style: italic;
      color: rgba(245,240,232,.65);
      margin: 1.2rem 0 2.8rem;
      letter-spacing: .5px;
    }
    .hero-btns { display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: center; }
    .btn-gold {
      display: inline-block;
      padding: .85rem 2.4rem;
      background: var(--warm);
      color: var(--ink);
      font-size: .85rem; font-weight: 500;
      letter-spacing: 2px; text-transform: uppercase;
      text-decoration: none;
      border: none; border-radius: 1px;
      transition: background .25s, transform .2s;
    }
    .btn-gold:hover { background: var(--warm2); transform: translateY(-2px); }
    .btn-ghost {
      display: inline-block;
      padding: .85rem 2.4rem;
      border: 1px solid rgba(245,240,232,.3);
      color: rgba(245,240,232,.7);
      font-size: .85rem; letter-spacing: 2px; text-transform: uppercase;
      text-decoration: none; border-radius: 1px;
      transition: border-color .25s, color .25s, transform .2s;
    }
    .btn-ghost:hover {
      border-color: var(--warm2);
      color: var(--warm2);
      transform: translateY(-2px);
    }

    /* ─── モザイクグリッド ─── */
    .mosaic {
      display: grid;
      grid-template-columns: 1fr 1.6fr 1fr;
      grid-template-rows: 280px 280px;
      gap: 3px;
      background: var(--ink);
    }
    .mosaic-cell {
      position: relative; overflow: hidden;
      background: var(--ink2);
    }
    .mosaic-cell img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      transition: transform .6s ease;
    }
    .mosaic-cell:hover img { transform: scale(1.04); }
    .mosaic-cell.tall { grid-row: span 2; }
    .mosaic-label {
      position: absolute; bottom: 1.6rem; left: 1.6rem;
      font-size: .68rem; letter-spacing: 4px;
      text-transform: uppercase; color: var(--warm);
      font-family: 'Cormorant Garamond', serif;
    }
    .mosaic-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(14,12,10,.5) 0%, transparent 60%);
    }

    /* ─── セクション共通 ─── */
    .sec { padding: 8rem 5vw; }
    .sec-eye {
      font-size: .7rem; letter-spacing: 4px; text-transform: uppercase;
      color: var(--warm); margin-bottom: 1.4rem;
      font-family: 'Cormorant Garamond', serif;
    }
    .sec-h2 {
      font-family: 'Noto Serif JP', serif;
      font-weight: 200;
      font-size: clamp(1.9rem, 4vw, 3rem);
      line-height: 1.55; color: var(--white);
      white-space: pre-line;
    }
    .rule {
      width: 40px; height: 1px;
      background: var(--warm); margin: 2rem 0 2.8rem;
    }

    /* ─── コンセプト ─── */
    .concept { background: var(--ink2); }
    .concept-grid {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }
    .concept-img {
      position: relative; border-radius: 2px; overflow: hidden;
    }
    .concept-img img {
      width: 100%; height: 520px;
      object-fit: cover; object-position: top;
      display: block;
    }
    .concept-img::before {
      content: '';
      position: absolute; inset: -8px;
      border: 1px solid rgba(200,169,110,.2);
      border-radius: 2px;
      z-index: 1; pointer-events: none;
    }
    .concept-body p {
      font-size: .93rem; line-height: 2.1;
      color: rgba(245,240,232,.7);
      white-space: pre-line;
    }
    .concept-credit {
      margin-top: 2.5rem;
      font-size: .78rem; letter-spacing: 2px;
      color: var(--warm); font-family: 'Cormorant Garamond', serif;
    }

    /* ─── サービス ─── */
    .services { background: var(--ink); }
    .services-inner { max-width: 1200px; margin: 0 auto; }
    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; margin-top: 4rem;
      border: 1px solid rgba(200,169,110,.1);
    }
    .svc {
      padding: 3rem 2.5rem;
      border-right: 1px solid rgba(200,169,110,.08);
      background: var(--ink);
      transition: background .3s;
    }
    .svc:last-child { border-right: none; }
    .svc:hover { background: var(--ink2); }
    .svc-eye {
      font-size: .68rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--muted); margin-bottom: 1.8rem;
      font-family: 'Cormorant Garamond', serif;
    }
    .svc h3 {
      font-family: 'Noto Serif JP', serif;
      font-weight: 300; font-size: 1.3rem;
      color: var(--warm2); margin-bottom: 1.2rem;
    }
    .svc p { font-size: .88rem; color: rgba(245,240,232,.55); line-height: 1.9; }

    /* ─── レッスン概要 ─── */
    .lessons { background: var(--ink2); }
    .lessons-inner { max-width: 1200px; margin: 0 auto; }
    .features-grid {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 1px; margin-top: 4rem;
    }
    .feat {
      padding: 2.8rem 2.5rem;
      background: var(--ink);
      border-bottom: 1px solid rgba(200,169,110,.08);
      display: flex; gap: 2rem; align-items: flex-start;
    }
    .feat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem; font-style: italic;
      color: rgba(200,169,110,.25);
      line-height: 1; flex-shrink: 0; width: 2rem;
    }
    .feat h4 {
      font-size: .95rem; font-weight: 500;
      color: var(--warm2); margin-bottom: .5rem;
    }
    .feat p { font-size: .85rem; color: var(--muted); }

    /* ─── CTA ─── */
    .cta-sec {
      background: var(--ink3);
      text-align: center;
      padding: 9rem 5vw;
      position: relative; overflow: hidden;
    }
    .cta-sec::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(200,169,110,.06) 0%, transparent 70%);
    }
    .cta-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }
    .cta-sec .sec-h2 { margin-bottom: 1.5rem; }
    .cta-body {
      font-size: .9rem; color: rgba(245,240,232,.55);
      white-space: pre-line; line-height: 2; margin-bottom: 3rem;
    }
    .cta-btns { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; }
    .cta-link {
      display: block; margin-top: 1.8rem;
      font-size: .8rem; color: var(--muted);
      text-decoration: none; letter-spacing: 1px;
      transition: color .2s;
    }
    .cta-link:hover { color: var(--warm); }

    /* ─── フッター ─── */
    footer {
      background: #080706;
      padding: 5rem 5vw 3rem;
      border-top: 1px solid rgba(200,169,110,.15);
    }
    .footer-grid {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 5rem; padding-bottom: 4rem;
      border-bottom: 1px solid rgba(245,240,232,.06);
    }
    .footer-logo img { height: 40px; filter: brightness(.85); margin-bottom: 1.5rem; }
    .footer-tag {
      font-size: .82rem; color: var(--muted);
      white-space: pre-line; line-height: 1.9;
    }
    .footer-col h5 {
      font-size: .68rem; letter-spacing: 3px;
      text-transform: uppercase; color: var(--warm);
      margin-bottom: 1.4rem;
      font-family: 'Cormorant Garamond', serif;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .8rem; }
    .footer-col a {
      text-decoration: none; font-size: .85rem;
      color: rgba(245,240,232,.45); transition: color .2s;
    }
    .footer-col a:hover { color: var(--warm); }
    .footer-copy {
      max-width: 1200px; margin: 2.5rem auto 0;
      text-align: center; font-size: .72rem;
      color: rgba(245,240,232,.2); letter-spacing: 1px;
    }

    /* ─── レスポンシブ ─── */
    @media (max-width: 960px) {
      nav { padding: 0 1.5rem; }
      nav ul { display: none; }
      .hero-body { padding: 0 1.5rem 6vh; }
      .mosaic { grid-template-columns: 1fr 1fr; grid-template-rows: 220px 220px 220px; }
      .mosaic-cell.tall { grid-row: span 2; }
      .concept-grid { grid-template-columns: 1fr; gap: 3rem; }
      .concept-img img { height: 360px; }
      .services-grid { grid-template-columns: 1fr; }
      .svc { border-right: none; border-bottom: 1px solid rgba(200,169,110,.08); }
      .features-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 3rem; }
      .sec { padding: 5rem 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- 言語スイッチャー -->
  <div class="lang">
    <a href="?lang=ja" class={lang==='ja'?'on':''}>JP</a>
    <a href="?lang=en" class={lang==='en'?'on':''}>EN</a>
    <a href="?lang=zh" class={lang==='zh'?'on':''}>中</a>
  </div>

  <!-- ナビ -->
  <nav>
    <a href="/" class="nav-logo">
      <img src="/logo.png" alt="&LAB TOKYO" />
    </a>
    <ul>
      {t.nav.map((n, i) => (
        <li><a href={t.navHref[i]} class={i === t.nav.length-1 ? 'nav-cta' : ''}>{n}</a></li>
      ))}
    </ul>
  </nav>

  <!-- ヒーロー：全画面サラダ写真 -->
  <section class="hero">
    <div class="hero-img">
      <img src="/hero-food.jpg" alt="&LAB TOKYO ローフード" />
    </div>
    <div class="hero-body">
      <p class="eyebrow">{t.heroEye}</p>
      <h1>
        {t.heroH1a}<br />
        <em>{t.heroH1b}</em>
      </h1>
      <p class="hero-sub">{t.heroSub}</p>
      <div class="hero-btns">
        <a href="#lessons" class="btn-gold">{t.heroCta}</a>
        <a href="#contact" class="btn-ghost">{t.heroCtaSub}</a>
      </div>
    </div>
  </section>

  <!-- モザイクグリッド（Squarespaceスタイル） -->
  <div class="mosaic">
    <div class="mosaic-cell">
      <img src="/green-smoothie.jpg" alt="グリーンスムージー" />
      <div class="mosaic-overlay"></div>
    </div>
    <div class="mosaic-cell tall">
      <img src="/chie-portrait.jpg" alt="安藤千英" />
      <div class="mosaic-overlay"></div>
      <span class="mosaic-label">{t.mosaicLabel}</span>
    </div>
    <div class="mosaic-cell">
      <img src="/koji.jpg" alt="麹" />
      <div class="mosaic-overlay"></div>
    </div>
    <div class="mosaic-cell">
      <img src="/chie-cooking.jpg" alt="料理シーン" />
      <div class="mosaic-overlay"></div>
    </div>
  </div>

  <!-- コンセプト -->
  <section class="sec concept" id="about">
    <div class="concept-grid">
      <div class="concept-img">
        <img src="/chie-portrait.jpg" alt="安藤千英" />
      </div>
      <div class="concept-body">
        <p class="sec-eye">{t.conceptEye}</p>
        <h2 class="sec-h2">{t.conceptH2}</h2>
        <div class="rule"></div>
        <p>{t.conceptBody}</p>
        <p class="concept-credit">{t.conceptCredit}</p>
      </div>
    </div>
  </section>

  <!-- サービス -->
  <section class="sec services" id="lessons">
    <div class="services-inner">
      <p class="sec-eye">Programs</p>
      <h2 class="sec-h2">発酵とローフード、<br />ふたつの知恵で。</h2>
      <div class="services-grid" id="hacco">
        <div class="svc">
          <p class="svc-eye">{t.s1Eye}</p>
          <h3>{t.s1H}</h3>
          <p>{t.s1B}</p>
        </div>
        <div class="svc">
          <p class="svc-eye">{t.s2Eye}</p>
          <h3>{t.s2H}</h3>
          <p>{t.s2B}</p>
        </div>
        <div class="svc">
          <p class="svc-eye">{t.s3Eye}</p>
          <h3>{t.s3H}</h3>
          <p>{t.s3B}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- レッスン概要 -->
  <section class="sec lessons">
    <div class="lessons-inner">
      <p class="sec-eye">{t.lessonEye}</p>
      <h2 class="sec-h2">{t.lessonH}</h2>
      <div class="rule"></div>
      <div class="features-grid">
        {t.features.map(([h, p], i) => (
          <div class="feat">
            <span class="feat-num">0{i+1}</span>
            <div>
              <h4>{h}</h4>
              <p>{p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-sec" id="contact">
    <div class="cta-inner">
      <p class="sec-eye">{t.ctaEye}</p>
      <h2 class="sec-h2">{t.ctaH}</h2>
      <div class="rule" style="margin: 2rem auto;"></div>
      <p class="cta-body">{t.ctaBody}</p>
      <div class="cta-btns">
        <a href="mailto:info@andlabtokyo.com" class="btn-gold">{t.ctaBtn}</a>
      </div>
      <a href="mailto:info@andlabtokyo.com" class="cta-link">{t.ctaSub}</a>
    </div>
  </section>

  <!-- フッター -->
  <footer>
    <div class="footer-grid">
      <div>
        <div class="footer-logo">
          <img src="/logo.png" alt="&LAB TOKYO" />
        </div>
        <p class="footer-tag">{t.footerTagline}</p>
      </div>
      <div class="footer-col">
        <h5>Menu</h5>
        <ul>
          {t.nav.map((n, i) => (
            <li><a href={t.navHref[i]}>{n}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h5>Follow</h5>
        <ul>
          <li><a href="#" target="_blank">Instagram</a></li>
          <li><a href="#" target="_blank">YouTube</a></li>
          <li><a href="#" target="_blank">TikTok</a></li>
          <li><a href="#" target="_blank">X / Twitter</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-copy">{t.copyright}</p>
  </footer>

</body>
</html>
