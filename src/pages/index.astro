---
// &LAB TOKYO - デザインカラー
const colors = {
	terracotta: '#d4923f',
	warmPink: '#d97d7d',
	deepNavy: '#0a0e27',
	cream: '#fef9f3'
};

// 言語の初期値（URLパラメータで変更可能）
const lang = Astro.url.searchParams.get('lang') || 'ja';

// 多言語コンテンツ
const content = {
	ja: {
		navWork: 'ワーク',
		navAbout: 'について',
		navContact: 'お問い合わせ',
		heroTitle: 'デジタル体験を',
		heroAccent: 'つくる',
		heroDesc: '私たちは、アイデアを美しいデジタル現実に変える、洗練されたソリューションを創造します。最新のデザインと先端技術で、あなたのビジョンを実現します。',
		btnWork: 'ワークを見る',
		btnContact: 'お問い合わせ',
		featureDesign: 'デザイン卓越性',
		featureDesignDesc: '美しさと機能性を融合させた、思慮深くデザインされた作品。忘れられないデジタル体験を創造します。',
		featureTech: '最新技術',
		featureTechDesc: '最新技術とベストプラクティスで構築。パフォーマンス、スケーラビリティ、信頼性を実現します。',
		featureInnovation: 'イノベーション',
		featureInnovationDesc: 'トレンドを先取りし、常に新しい可能性を探求。最先端のソリューションをお届けします。',
		footerDesc: 'デザイン＆テクノロジー スタジオ',
		footerEmail: 'メール',
		footerCopyright: '2026 &LAB TOKYO. All rights reserved.',
	},
	en: {
		navWork: 'Work',
		navAbout: 'About',
		navContact: 'Contact',
		heroTitle: 'Crafting Digital',
		heroAccent: 'Experiences',
		heroDesc: 'We create elegant, innovative solutions that transform ideas into beautiful digital realities. Specializing in modern design and cutting-edge technology.',
		btnWork: 'Explore Our Work',
		btnContact: 'Get In Touch',
		featureDesign: 'Design Excellence',
		featureDesignDesc: 'Thoughtfully crafted designs that blend aesthetics with functionality, creating memorable digital experiences.',
		featureTech: 'Modern Technology',
		featureTechDesc: 'Built with the latest technologies and best practices, ensuring performance, scalability, and reliability.',
		featureInnovation: 'Innovation Driven',
		featureInnovationDesc: 'We stay ahead of trends, continuously exploring new possibilities to deliver cutting-edge solutions.',
		footerDesc: 'Innovative Design & Technology Studio',
		footerEmail: 'Email',
		footerCopyright: '2026 &LAB TOKYO. All rights reserved.',
	},
	zh: {
		navWork: '作品',
		navAbout: '关于',
		navContact: '联系',
		heroTitle: '打造数字',
		heroAccent: '体验',
		heroDesc: '我们创建优雅、创新的解决方案，将创意转化为美丽的数字现实。专注于现代设计和尖端技术。',
		btnWork: '查看作品',
		btnContact: '联系我们',
		featureDesign: '设计卓越',
		featureDesignDesc: '精心设计的作品，融美学与功能性于一体，创造难忘的数字体验。',
		featureTech: '现代技术',
		featureTechDesc: '采用最新技术和最佳实践构建，确保性能、可扩展性和可靠性。',
		featureInnovation: '创新驱动',
		featureInnovationDesc: '我们走在潮流前沿，不断探索新的可能性，提供尖端解决方案。',
		footerDesc: '创新设计和科技工作室',
		footerEmail: '邮件',
		footerCopyright: '2026 &LAB TOKYO. All rights reserved.',
	}
};

const t = content[lang] || content.ja;
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>&LAB TOKYO - Innovative Design Studio</title>
		<meta name="description" content="&LAB TOKYO - A modern design and technology studio creating elegant digital experiences." />
		<style define:vars={colors}>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
				scroll-behavior: smooth;
			}

			body {
				background-color: var(--cream);
				color: var(--deepNavy);
				line-height: 1.6;
			}

			/* ナビゲーション */
			nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 2rem 3rem;
				background-color: var(--cream);
				border-bottom: 1px solid rgba(10, 14, 39, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
			}

			.logo {
				font-size: 1.8rem;
				font-weight: 700;
				letter-spacing: 2px;
				color: var(--deepNavy);
			}

			.logo-mark {
				color: var(--terracotta);
				font-weight: 900;
			}

			nav ul {
				display: flex;
				list-style: none;
				gap: 2.5rem;
			}

			nav a {
				text-decoration: none;
				color: var(--deepNavy);
				font-size: 0.95rem;
				font-weight: 500;
				transition: color 0.3s ease;
				border-bottom: 2px solid transparent;
			}

			nav a:hover {
				color: var(--terracotta);
				border-bottom-color: var(--terracotta);
			}

			/* ヒーロー領域 */
			.hero {
				height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				background: linear-gradient(135deg, var(--cream) 0%, rgba(212, 146, 63, 0.05) 100%);
				padding: 4rem 2rem;
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				width: 400px;
				height: 400px;
				background: radial-gradient(circle, rgba(217, 125, 125, 0.1) 0%, transparent 70%);
				border-radius: 50%;
				top: -100px;
				right: -100px;
				z-index: 0;
			}

			.hero::after {
				content: '';
				position: absolute;
				width: 300px;
				height: 300px;
				background: radial-gradient(circle, rgba(212, 146, 63, 0.08) 0%, transparent 70%);
				border-radius: 50%;
				bottom: -50px;
				left: -50px;
				z-index: 0;
			}

			.hero-content {
				z-index: 1;
				max-width: 900px;
			}

			.hero h1 {
				font-size: clamp(2.5rem, 8vw, 5rem);
				line-height: 1.2;
				margin-bottom: 1.5rem;
				letter-spacing: -1px;
			}

			.hero-title {
				color: var(--deepNavy);
			}

			.hero-accent {
				color: var(--terracotta);
				display: block;
				margin-top: 0.5rem;
			}

			.hero p {
				font-size: 1.2rem;
				color: var(--deepNavy);
				opacity: 0.75;
				margin-bottom: 3rem;
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
			}

			.cta-buttons {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				flex-wrap: wrap;
			}

			.btn {
				padding: 1rem 2.5rem;
				font-size: 1rem;
				font-weight: 600;
				border: 2px solid;
				border-radius: 4px;
				cursor: pointer;
				text-decoration: none;
				display: inline-block;
				transition: all 0.3s ease;
				text-transform: uppercase;
				letter-spacing: 1px;
			}

			.btn-primary {
				background-color: var(--terracotta);
				color: var(--cream);
				border-color: var(--terracotta);
			}

			.btn-primary:hover {
				background-color: var(--warmPink);
				border-color: var(--warmPink);
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(217, 125, 125, 0.2);
			}

			.btn-secondary {
				background-color: transparent;
				color: var(--deepNavy);
				border-color: var(--deepNavy);
			}

			.btn-secondary:hover {
				background-color: var(--deepNavy);
				color: var(--cream);
				transform: translateY(-2px);
			}

			/* フィーチャー */
			.features {
				padding: 6rem 3rem;
				background-color: white;
			}

			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 3rem;
				max-width: 1200px;
				margin: 0 auto;
			}

			.feature-card {
				padding: 2rem;
				border-radius: 4px;
				border-left: 4px solid var(--terracotta);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				background-color: var(--cream);
			}

			.feature-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 15px 35px rgba(10, 14, 39, 0.1);
			}

			.feature-icon {
				font-size: 2.5rem;
				margin-bottom: 1rem;
			}

			.feature-card h3 {
				color: var(--deepNavy);
				margin-bottom: 1rem;
				font-size: 1.3rem;
			}

			.feature-card p {
				color: var(--deepNavy);
				opacity: 0.7;
				line-height: 1.8;
			}

			/* フッター */
			footer {
				background-color: var(--deepNavy);
				color: var(--cream);
				padding: 3rem;
				text-align: center;
				border-top: 3px solid var(--terracotta);
			}

			footer p {
				margin-bottom: 1rem;
				opacity: 0.9;
			}

			.footer-links {
				display: flex;
				justify-content: center;
				gap: 2rem;
				margin: 1.5rem 0;
			}

			.footer-links a {
				color: var(--terracotta);
				text-decoration: none;
				transition: opacity 0.3s ease;
			}

			.footer-links a:hover {
				opacity: 0.7;
			}

			.copyright {
				margin-top: 2rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(254, 249, 243, 0.2);
				opacity: 0.7;
				font-size: 0.9rem;
			}

			/* レスポンシブ */
			@media (max-width: 768px) {
				nav {
					flex-direction: column;
					padding: 1.5rem;
					gap: 1.5rem;
				}

				nav ul {
					flex-direction: column;
					gap: 1rem;
					text-align: center;
				}

				.cta-buttons {
					flex-direction: column;
					align-items: center;
				}

				.btn {
					width: 100%;
					max-width: 300px;
				}

				.features {
					padding: 3rem 1.5rem;
				}

				footer {
					padding: 2rem 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<!-- 言語スイッチャー -->
		<div style="position: fixed; top: 15px; right: 20px; z-index: 200; display: flex; gap: 10px;">
			<a href="?lang=ja" style="padding: 6px 12px; background-color: ${lang === 'ja' ? 'var(--terracotta)' : 'var(--cream)'}; color: ${lang === 'ja' ? 'var(--cream)' : 'var(--deepNavy)'}; border-radius: 4px; text-decoration: none; font-size: 0.85rem; font-weight: 600; border: 1px solid var(--terracotta);">日本語</a>
			<a href="?lang=en" style="padding: 6px 12px; background-color: ${lang === 'en' ? 'var(--terracotta)' : 'var(--cream)'}; color: ${lang === 'en' ? 'var(--cream)' : 'var(--deepNavy)'}; border-radius: 4px; text-decoration: none; font-size: 0.85rem; font-weight: 600; border: 1px solid var(--terracotta);">English</a>
			<a href="?lang=zh" style="padding: 6px 12px; background-color: ${lang === 'zh' ? 'var(--terracotta)' : 'var(--cream)'}; color: ${lang === 'zh' ? 'var(--cream)' : 'var(--deepNavy)'}; border-radius: 4px; text-decoration: none; font-size: 0.85rem; font-weight: 600; border: 1px solid var(--terracotta);">中文</a>
		</div>

		<!-- ナビゲーション -->
		<nav>
			<div class="logo">
				<span class="logo-mark">&</span>LAB TOKYO
			</div>
			<ul>
				<li><a href="#work">${t.navWork}</a></li>
				<li><a href="#about">${t.navAbout}</a></li>
				<li><a href="#contact">${t.navContact}</a></li>
			</ul>
		</nav>

		<!-- ヒーロー -->
		<section class="hero">
			<div class="hero-content">
				<h1>
					<span class="hero-title">${t.heroTitle}</span>
					<span class="hero-accent">${t.heroAccent}</span>
				</h1>
				<p>
					${t.heroDesc}
				</p>
				<div class="cta-buttons">
					<a href="#work" class="btn btn-primary">${t.btnWork}</a>
					<a href="#contact" class="btn btn-secondary">${t.btnContact}</a>
				</div>
			</div>
		</section>

		<!-- フィーチャー -->
		<section class="features" id="work">
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-icon">🎨</div>
					<h3>${t.featureDesign}</h3>
					<p>
						${t.featureDesignDesc}
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">⚡</div>
					<h3>${t.featureTech}</h3>
					<p>
						${t.featureTechDesc}
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🚀</div>
					<h3>${t.featureInnovation}</h3>
					<p>
						${t.featureInnovationDesc}
					</p>
				</div>
			</div>
		</section>

		<!-- フッター -->
		<footer id="contact">
			<p><strong>&LAB TOKYO</strong></p>
			<p>${t.footerDesc}</p>
			<div class="footer-links">
				<a href="mailto:info@andlabtokyo.com">${t.footerEmail}</a>
				<a href="#">Instagram</a>
				<a href="#">Twitter</a>
			</div>
			<div class="copyright">
				<p>&copy; ${t.footerCopyright}</p>
			</div>
		</footer>
	</body>
</html>
