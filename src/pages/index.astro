---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="これからの私を、美しく「醸す」。 | &LAB TOKYO"
  description="発酵と美の学校。東京・渋谷のプレミアム・ライフスタイルラボ。ローフード×発酵のクロス理論でライフスタイルを進化させる &LAB TOKYO。ELLE gourmet認定料理家・安藤千英が主宰。"
  canonical="https://www.andlabtokyo.com/"
  type="website"
>

<style>
/* ===== HERO ===== */
.hero {
  min-height: calc(100vh - 73px);
  background: #FAF9F6;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.hero-image-wrap {
  position: absolute;
  right: 0;
  top: 0;
  width: 80%;
  height: 100%;
  overflow: hidden;
}
.hero-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
.hero-gradient {
  position: absolute;
  left: 0; top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to right,
    #FAF9F6 0%,
    #FAF9F6 22%,
    rgba(250,249,246,0.82) 42%,
    rgba(250,249,246,0) 68%,
    transparent 100%
  );
  pointer-events: none;
}
.hero-text {
  position: relative;
  z-index: 10;
  padding: 0 4rem;
  width: 52%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.hero-eyebrow {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #7A7A72;
  font-weight: 400;
  display: block;
  margin-bottom: 1.2rem;
}
.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 200;
  letter-spacing: 0.28em;
  line-height: 1.45;
  color: #1C1C1A;
  margin-bottom: 2.8rem;
}
.hero-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  letter-spacing: 0.08em;
  line-height: 2.2;
  color: #7A7A72;
  font-weight: 300;
  margin-bottom: 1.2rem;
}
.hero-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  line-height: 2.1;
  color: #999;
  font-weight: 300;
  margin-bottom: 3.5rem;
}
.hero-cta {
  display: inline-block;
  width: fit-content;
  font-family: 'Noto Serif JP', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #1C1C1A;
  text-decoration: none;
  border-bottom: 1.5px solid #1C1C1A;
  padding-bottom: 0.7rem;
  transition: opacity 0.3s;
  font-weight: 300;
}
.hero-cta:hover { opacity: 0.55; }
.scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.8rem;
}
.scroll-indicator span {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 8px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #7A7A72;
}
.scroll-indicator div {
  width: 1px;
  height: 32px;
  background: #7A7A72;
  opacity: 0.35;
}

/* ===== ABOUT ===== */
.about-sec {
  padding: 10rem 4rem;
  background: #FAF9F6;
}
.about-inner {
  max-width: 820px;
  margin: 0 auto;
  text-align: center;
}
.rule {
  width: 60px;
  height: 1px;
  background: #1C1C1A;
  margin: 0 auto 3rem;
}
.about-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 15px;
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #1C1C1A;
  margin-bottom: 1.2rem;
}
.about-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #1C1C1A;
  margin-bottom: 3rem;
}
.rule-sm {
  width: 60px;
  height: 1px;
  background: #1C1C1A;
  margin: 0 auto 3.5rem;
}
.about-lead {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  line-height: 2.3;
  color: #7A7A72;
  font-weight: 300;
  margin-bottom: 1.8rem;
}

/* ===== TWO DOORS ===== */
.doors-sec {
  padding: 7rem 4rem;
  background: #FAF9F6;
}
.doors-header {
  max-width: 1000px;
  margin: 0 auto 4rem;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.doors-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 300;
  letter-spacing: 0.12em;
  color: #1C1C1A;
}
.doors-title-ja {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.2em;
  color: #7A7A72;
}
.doors-grid {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  position: relative;
}
.door-card {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: opacity 0.3s;
}
.door-card:hover { opacity: 0.88; }
.door-card-img {
  position: relative;
  aspect-ratio: 4/5;
  overflow: hidden;
  margin-bottom: 1.5rem;
  background: #E5E0DA;
}
.door-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.8s ease;
}
.door-card:hover .door-card-img img { transform: scale(1.03); }
.door-card-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(0,0,0,0.15);
  color: #fff;
  text-align: center;
}
.door-num {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 200;
  letter-spacing: 0.15em;
  margin-bottom: 1rem;
}
.door-label {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.2em;
  font-weight: 400;
  line-height: 1.7;
}
.door-card h3 {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.12em;
  margin-bottom: 0.5rem;
  color: #1C1C1A;
  font-weight: 400;
}
.door-card p {
  font-family: 'Noto Serif JP', serif;
  font-size: 11px;
  line-height: 1.9;
  color: #7A7A72;
  letter-spacing: 0.06em;
}
.doors-vert {
  position: absolute;
  right: -6%;
  top: 50%;
  writing-mode: vertical-rl;
  transform: translateY(-50%) rotateZ(180deg);
}
.doors-vert p {
  font-family: 'Noto Serif JP', serif;
  font-size: 10px;
  letter-spacing: 0.15em;
  color: #7A7A72;
  opacity: 0.45;
  font-weight: 300;
  white-space: nowrap;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .hero-text { width: 65%; }
  .hero-image-wrap { width: 70%; }
  .doors-vert { display: none; }
}
@media (max-width: 640px) {
  .hero {
    flex-direction: column;
    align-items: flex-start;
    min-height: auto;
    padding: 3rem 0 0;
  }
  .hero-image-wrap {
    position: relative;
    width: 100%;
    height: 55vw;
    min-height: 240px;
  }
  .hero-gradient {
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(250,249,246,0.7) 70%,
      #FAF9F6 100%
    );
  }
  .hero-text { width: 100%; padding: 2.5rem 1.5rem 4rem; }
  .hero-title { font-size: 1.8rem; margin-bottom: 2rem; }
  .scroll-indicator { left: 1.5rem; }
  .about-sec { padding: 6rem 1.5rem; }
  .doors-sec { padding: 5rem 1.5rem; }
  .doors-grid { grid-template-columns: 1fr; }
  .door-card + .door-card { margin-top: 0; }
}
</style>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-image-wrap">
    <img src="/herotable.JPG" alt="&LAB TOKYO Studio"
      onerror="this.style.background='#E5E0DA';this.style.opacity='0'"
    />
    <div class="hero-gradient"></div>
  </div>

  <div class="hero-text">
    <span class="hero-eyebrow">Fermentation Creator · Tokyo Shibuya</span>
    <h1 class="hero-title">
      これからの私を、<br>
      美しく「醸す」。
    </h1>
    <p class="hero-sub">
      細胞からデザインする、<br>
      一生モノの心と体。
    </p>
    <p class="hero-body">
      忙しい毎日の中で、自分の体を後回しにしていませんか。<br>
      発酵×ローフードのクロス理論で、<br>
      あなたの本来の輝きを取り戻す。
    </p>
    <a href="/brand" class="hero-cta">&LAB TOKYO について</a>

    <div class="scroll-indicator">
      <span>Scroll</span>
      <div></div>
    </div>
  </div>
</section>

<!-- ===== ABOUT ===== -->
<section class="about-sec">
  <div class="about-inner">
    <div class="rule"></div>
    <p class="about-sub">美しさを、自ら「つくる」人へ。</p>
    <h2 class="about-title">ABOUT &LAB TOKYO</h2>
    <div class="rule-sm"></div>
    <p class="about-lead">
      &LAB TOKYOは、東京・渋谷を拠点とする<br>
      「発酵×ローフード」のクロス理論でライフスタイルを進化させる。
    </p>
    <p class="about-lead">
      私たちが提案するのは、単なる「料理」ではありません。<br>
      細胞から目覚めるような生きたエネルギー（酵素）を取り入れ、<br>
      古来の知恵である「発酵」で内側から美しさを醸成する。
    </p>
    <p class="about-lead" style="margin-bottom:0">
      経営者、専門職、そして自分自身の可能性を信じるすべての女性へ。<br>
      あなたが持つ本来の輝きを、最大化させる場所でありたい。<br>
      ELLE gourmet認定料理家・安藤千英が、その旅路をガイドします。
    </p>
  </div>
</section>

<!-- ===== THE TWO DOORS ===== -->
<section class="doors-sec">
  <div class="doors-header">
    <h2 class="doors-title">The Two Doors</h2>
    <span class="doors-title-ja">ふたつの扉</span>
  </div>

  <div class="doors-grid">
    <!-- CARD 01 -->
    <a href="/listofcourses" class="door-card">
      <div class="door-card-img">
        <img src="/IMG_1203.JPG" alt="Professional Courses"
          onerror="this.style.display='none'"
        />
        <div class="door-card-overlay">
          <div class="door-num">01</div>
          <div class="door-label">PROFESSIONAL<br>COURSES</div>
        </div>
      </div>
      <h3>Professional Courses</h3>
      <p>高度なローフードと発酵の技術を体系化した本講座。</p>
    </a>

    <!-- CARD 02 -->
    <a href="/koji-fermentation-experience-tokyo" class="door-card" style="margin-top:2.5rem">
      <div class="door-card-img">
        <img src="/IMG_1544.JPG" alt="KOJI Workshops"
          onerror="this.style.display='none'"
        />
        <div class="door-card-overlay">
          <div class="door-num">02</div>
          <div class="door-label">TRADITIONAL<br>KOJI WORKSHOPS</div>
        </div>
      </div>
      <h3>Traditional KOJI Workshops</h3>
      <p>日本の知恵を五感で学ぶ、特別な発酵体験。</p>
    </a>

    <!-- vertical text -->
    <div class="doors-vert">
      <p>学ぶことは、未来の美しさをつくること。</p>
    </div>
  </div>
</section>

</Layout>
