---
import Layout from '../layouts/Layout.astro';
---

<Layout title="発酵と、美の学校。 | &LAB TOKYO">

  <!-- HERO SECTION -->
  <section style="
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    min-height: calc(100vh - 100px);
    background: #FAF9F6;
    align-items: center;
    position: relative;
    overflow: hidden;
  ">
    <!-- LEFT: TEXT AREA -->
    <div style="
      padding: 0 6rem 0 4rem;
      z-index: 10;
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
    ">
      <h1 style="
        font-size: 4rem;
        font-weight: 200;
        letter-spacing: 0.25em;
        line-height: 1.3;
        color: #1C1C1A;
        margin-bottom: 1.5rem;
        font-family: 'Noto Serif JP', serif;
      ">
        発酵と、<br>美の学校。
      </h1>

      <p style="
        font-size: 11px;
        letter-spacing: 0.15em;
        line-height: 2;
        color: #7A7A72;
        margin-bottom: 2.5rem;
        font-family: 'Noto Serif JP', serif;
      ">
        Fermentation and Raw Food School<br>
        in Omotesando, Tokyo.
      </p>

      <a href="/brand" style="
        display: inline-block;
        width: fit-content;
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #1C1C1A;
        text-decoration: none;
        border-bottom: 1px solid #1C1C1A;
        padding-bottom: 0.6rem;
        font-family: 'Noto Serif JP', serif;
        transition: opacity 0.3s;
      ">
        &LAB TOKYO
      </a>

      <!-- SCROLL INDICATOR -->
      <div style="
        position: absolute;
        bottom: 3rem;
        left: 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
      ">
        <span style="
          font-size: 8px;
          letter-spacing: 0.25em;
          text-transform: uppercase;
          color: #7A7A72;
          font-family: 'Noto Sans JP', sans-serif;
        ">Scroll</span>
        <div style="
          width: 1px;
          height: 28px;
          background: #7A7A72;
          opacity: 0.4;
        "></div>
      </div>
    </div>

    <!-- RIGHT: IMAGE -->
    <div style="
      position: absolute;
      right: -2%;
      top: 0;
      width: 60%;
      height: 100%;
      overflow: hidden;
    ">
      <img
        src="/herotable.JPG"
        alt="&LAB TOKYO Studio"
        style="
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
          display: block;
        "
      />
    </div>
  </section>

  <!-- THE TWO DOORS -->
  <section style="
    padding: 8rem 4rem;
    background: #FAF9F6;
    position: relative;
  ">
    <!-- SECTION TITLE -->
    <div style="
      max-width: 1000px;
      margin: 0 auto 4rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    ">
      <h2 style="
        font-size: 2.8rem;
        font-weight: 300;
        letter-spacing: 0.12em;
        color: #1C1C1A;
        font-family: 'Noto Serif JP', serif;
      ">
        The Two Doors
      </h2>
      <span style="
        font-size: 12px;
        letter-spacing: 0.2em;
        color: #7A7A72;
        font-family: 'Noto Serif JP', serif;
      ">
        ふたつの扉
      </span>
    </div>

    <!-- CARDS CONTAINER -->
    <div style="
      max-width: 1000px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      position: relative;
    ">
      <!-- CARD 01: PROFESSIONAL -->
      <a href="/listofcourses" style="
        text-decoration: none;
        color: inherit;
        display: block;
        transition: opacity 0.3s;
      ">
        <!-- IMAGE -->
        <div style="
          position: relative;
          aspect-ratio: 4/5;
          overflow: hidden;
          margin-bottom: 1.5rem;
          background: #e5e0da;
        ">
          <img
            src="/IMG_1203.JPG"
            alt="Professional Courses"
            style="
              width: 100%;
              height: 100%;
              object-fit: cover;
              object-position: center;
              display: block;
              transition: transform 0.8s ease;
            "
          />
          <!-- OVERLAY: NUMBER & TEXT -->
          <div style="
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.15);
            color: white;
            text-align: center;
          ">
            <div style="
              font-size: 4rem;
              font-weight: 200;
              letter-spacing: 0.15em;
              margin-bottom: 1rem;
              font-family: 'Noto Serif JP', serif;
            ">01</div>
            <div style="
              font-size: 12px;
              letter-spacing: 0.2em;
              font-weight: 400;
              line-height: 1.6;
              font-family: 'Noto Serif JP', serif;
            ">
              PROFESSIONAL<br>COURSES
            </div>
          </div>
        </div>

        <!-- TEXT BELOW -->
        <h3 style="
          font-size: 12px;
          letter-spacing: 0.12em;
          margin-bottom: 0.6rem;
          color: #1C1C1A;
          font-family: 'Noto Serif JP', serif;
          font-weight: 400;
        ">Professional Courses</h3>
        <p style="
          font-size: 10px;
          line-height: 1.8;
          color: #7A7A72;
          letter-spacing: 0.08em;
          font-family: 'Noto Serif JP', serif;
        ">
          高度なローフードと発酵の技術を体系化した本講座。
        </p>
      </a>

      <!-- CARD 02: KOJI WORKSHOPS -->
      <a href="/koji-fermentation-experience-tokyo" style="
        text-decoration: none;
        color: inherit;
        display: block;
        margin-top: 2rem;
        transition: opacity 0.3s;
      ">
        <!-- IMAGE -->
        <div style="
          position: relative;
          aspect-ratio: 4/5;
          overflow: hidden;
          margin-bottom: 1.5rem;
          background: #e5e0da;
        ">
          <img
            src="/IMG_1544.JPG"
            alt="KOJI Workshops"
            style="
              width: 100%;
              height: 100%;
              object-fit: cover;
              object-position: center;
              display: block;
              transition: transform 0.8s ease;
            "
          />
          <!-- OVERLAY: NUMBER & TEXT -->
          <div style="
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.15);
            color: white;
            text-align: center;
          ">
            <div style="
              font-size: 4rem;
              font-weight: 200;
              letter-spacing: 0.15em;
              margin-bottom: 1rem;
              font-family: 'Noto Serif JP', serif;
            ">02</div>
            <div style="
              font-size: 12px;
              letter-spacing: 0.2em;
              font-weight: 400;
              line-height: 1.6;
              font-family: 'Noto Serif JP', serif;
            ">
              TRADITIONAL<br>KOJI WORKSHOPS
            </div>
          </div>
        </div>

        <!-- TEXT BELOW -->
        <h3 style="
          font-size: 12px;
          letter-spacing: 0.12em;
          margin-bottom: 0.6rem;
          color: #1C1C1A;
          font-family: 'Noto Serif JP', serif;
          font-weight: 400;
        ">Traditional KOJI Workshops</h3>
        <p style="
          font-size: 10px;
          line-height: 1.8;
          color: #7A7A72;
          letter-spacing: 0.08em;
          font-family: 'Noto Serif JP', serif;
        ">
          日本の知恵を五感で学ぶ、特別な発酵体験。
        </p>
      </a>

      <!-- VERTICAL TEXT ON RIGHT -->
      <div style="
        position: absolute;
        right: -8%;
        top: 50%;
        transform: translateY(-50%);
        writing-mode: vertical-rl;
        transform: translateY(-50%) rotateZ(180deg);
      ">
        <p style="
          font-size: 10px;
          letter-spacing: 0.15em;
          color: #7A7A72;
          opacity: 0.5;
          font-family: 'Noto Serif JP', serif;
          font-weight: 300;
          white-space: nowrap;
        ">
          学ぶことは、未来の美しさをつくること。
        </p>
      </div>
    </div>
  </section>

</Layout>

<style>
  a:hover {
    opacity: 0.85;
  }

  img {
    display: block;
  }

  @media (max-width: 1024px) {
    section {
      display: block !important;
      padding: 4rem 2rem !important;
    }

    h1 {
      font-size: 2.5rem !important;
    }

    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }

    div[style*="absolute"][style*="right"] {
      display: none !important;
    }
  }
</style>
