---
const lang = Astro.url.searchParams.get('lang') || 'ja';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>安藤千英 | &LAB TOKYO — 発酵×ローフード 東京・渋谷</title>
  <meta name="description" content="ELLE gourmet認定料理家・安藤千英。東京・渋谷の発酵×ローフード ライフスタイルラボ。少人数制・初心者歓迎・¥8,000〜・入会費なし。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ━━━━━━━━━━━━━━━━━━━━━
       Apple DESIGN.md 準拠
       canvas #ffffff / ink #1d1d1f / primary #0066cc
    ━━━━━━━━━━━━━━━━━━━━━ */
    :root {
      --primary:        #A9D159;
      --primary-focus:  #95C240;
      --primary-dark:   #7AAF2A;
      --ink:            #1d1d1f;
      --ink-80:         #333333;
      --ink-48:         #7a7a7a;
      --canvas:         #ffffff;
      --parchment:      #f5f5f7;
      --pearl:          #fafafc;
      --tile-dark-1:    #272729;
      --tile-dark-2:    #2a2a2c;
      --divider:        #e0e0e0;
      --divider-soft:   #f0f0f0;
      --on-dark:        #ffffff;
      --chip:           #d2d2d7;

      --f: 'Noto Sans JP', -apple-system, 'SF Pro Display', system-ui, sans-serif;

      /* spacing */
      --sp-xs:  8px;
      --sp-sm:  12px;
      --sp-md:  17px;
      --sp-lg:  24px;
      --sp-xl:  32px;
      --sp-2xl: 48px;
      --sp-sec: 80px;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--f);
      font-size: 17px;
      font-weight: 400;
      line-height: 1.47;
      letter-spacing: -0.022em;
      background: var(--canvas);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ━━ Nav (Apple global nav) ━━ */
    nav {
      position: fixed; inset: 0 0 auto 0; z-index: 500;
      height: 44px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 22px;
      background: rgba(0,0,0,0.88);
      backdrop-filter: saturate(180%) blur(20px);
    }
    .nav-logo {
      background: rgba(255,255,255,0.92);
      padding: 4px 12px;
      border-radius: 4px;
      display: flex; align-items: center;
    }
    .nav-logo img { height: 28px; width: auto; }
    .nav-links { display: flex; align-items: center; gap: 0; list-style: none; }
    .nav-links a {
      font-size: 12px; font-weight: 400;
      color: rgba(255,255,255,0.85); text-decoration: none;
      padding: 0 10px; letter-spacing: -0.01em;
      transition: color .2s;
    }
    .nav-links a:hover { color: rgba(255,255,255,0.6); }
    .nav-right { display: flex; align-items: center; gap: 8px; }
    .lang-sw { display: flex; }
    .lang-sw a {
      font-size: 11px; color: rgba(255,255,255,0.6);
      text-decoration: none; padding: 0 6px;
      border-right: 1px solid rgba(255,255,255,0.2);
    }
    .lang-sw a:last-child { border-right: none; }
    .lang-sw a.on { color: rgba(255,255,255,0.9); }

    /* ━━ Hero: edge-to-edge photography, text overlay ━━ */
    .hero {
      position: relative;
      margin-top: 44px;
      height: calc(100vh - 44px);
      overflow: hidden;
      display: flex; align-items: flex-end;
    }
    .hero img.hero-photo {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 35%;
      display: block;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.72) 0%,
        rgba(0,0,0,0.25) 45%,
        rgba(0,0,0,0) 100%
      );
    }
    .hero-body {
      position: relative; z-index: 1;
      padding: 0 0 72px 80px;
      max-width: 680px;
    }
    .hero-eyebrow {
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--primary-dark);
      margin-bottom: 16px; display: block;
    }
    .hero h1 {
      font-size: clamp(28px, 3.5vw, 44px);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.022em;
      color: #ffffff;
      margin-bottom: 14px;
    }
    .hero-sub {
      font-size: 21px; font-weight: 400;
      line-height: 1.19; letter-spacing: 0.011em;
      color: rgba(255,255,255,0.8);
      margin-bottom: 28px;
    }
    .hero-desc {
      font-size: 17px; font-weight: 300;
      line-height: 1.6;
      color: rgba(255,255,255,0.72);
      margin-bottom: 32px;
    }
    .hero-cta {
      display: inline-block;
      background: var(--primary);
      color: #fff;
      font-size: 17px; font-weight: 400;
      text-decoration: none;
      border-radius: 980px;
      padding: 12px 22px;
      transition: background .2s;
    }
    .hero-cta:hover { background: var(--primary-focus); }

    /* ━━ Info strip ━━ */
    .info-strip {
      background: var(--parchment);
      border-bottom: 1px solid var(--divider-soft);
      padding: 14px 22px;
    }
    .info-strip-inner {
      max-width: 1000px; margin: 0 auto;
      display: flex; align-items: center; gap: 0;
      flex-wrap: wrap;
    }
    .info-strip span {
      font-size: 14px; font-weight: 400; color: var(--ink-80);
      padding: 0 16px;
      border-right: 1px solid var(--divider);
    }
    .info-strip span:first-child { padding-left: 0; }
    .info-strip span:last-child { border-right: none; }
    .info-strip a {
      margin-left: auto;
      font-size: 14px; color: var(--primary);
      text-decoration: none;
    }
    .info-strip a:hover { text-decoration: underline; }

    /* ━━ Sections ━━ */
    section { padding: var(--sp-sec) 22px; }
    .inner { max-width: 1000px; margin: 0 auto; }
    .eyebrow {
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--primary); margin-bottom: 8px; display: block;
    }
    h2.display {
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 600; line-height: 1.1; letter-spacing: -0.003em;
      color: var(--ink);
    }
    .body-text {
      font-size: 17px; font-weight: 400;
      line-height: 1.7; color: var(--ink-80);
      margin-bottom: 16px;
    }
    .body-text strong { color: var(--ink); font-weight: 600; }
    .rule {
      width: 40px; height: 1px;
      background: var(--divider); margin: 24px 0 32px;
    }
    a.text-link {
      color: var(--primary); text-decoration: none;
      font-size: 17px;
    }
    a.text-link:hover { text-decoration: underline; }

    /* ━━ Story: light canvas ━━ */
    .story { background: var(--canvas); }
    .story-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 64px; align-items: start;
    }
    .story-img img {
      width: 100%; aspect-ratio: 4/3;
      object-fit: cover; display: block;
      border-radius: 18px;
    }

    /* ━━ Programs: alternating tiles (Apple product-tile style) ━━ */
    .programs { background: var(--parchment); padding: var(--sp-sec) 0; }
    .programs .inner { padding: 0 22px; margin-bottom: 32px; }
    .prog-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr;
      gap: 2px;
    }
    .prog {
      position: relative; overflow: hidden;
      text-decoration: none; display: block;
    }
    .prog { height: 480px; }
    .prog:first-child { height: 480px; }
    .prog img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      transition: transform .8s ease;
    }
    .prog:hover img { transform: scale(1.03); }
    .prog-ov {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.08) 55%);
    }
    .prog-body { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 24px; }
    .prog-eye {
      font-size: 11px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--primary-dark); margin-bottom: 6px; display: block;
    }
    .prog h3 {
      font-size: 21px; font-weight: 600; line-height: 1.19;
      color: #ffffff; margin-bottom: 6px;
    }
    .prog-detail { font-size: 14px; color: rgba(255,255,255,0.75); line-height: 1.6; margin-bottom: 8px; }
    .prog-meta { font-size: 13px; color: var(--primary-dark); font-weight: 400; }

    /* ━━ Brand visual: full-bleed ━━ */
    .brand-visual {
      position: relative; height: 520px; overflow: hidden;
    }
    .brand-visual img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 40%; display: block;
    }
    .brand-visual-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.3);
      display: flex; align-items: center; justify-content: center;
    }
    .brand-visual-text { text-align: center; }
    .brand-visual-text p {
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.65); margin-bottom: 12px;
    }
    .brand-visual-text h2 {
      font-size: clamp(28px, 4vw, 48px);
      font-weight: 600; line-height: 1.1; letter-spacing: -0.003em;
      color: #ffffff;
    }

    /* ━━ Credentials: parchment tile ━━ */
    .credentials { background: var(--parchment); }
    .cred-grid {
      display: grid; grid-template-columns: 260px 1fr;
      gap: 64px; align-items: start;
    }
    .book-img img {
      width: 100%; border-radius: 11px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    }
    .cred-list { display: flex; flex-direction: column; gap: 24px; }
    .cred-item {
      display: flex; gap: 16px; align-items: flex-start;
      padding-bottom: 24px; border-bottom: 1px solid var(--divider-soft);
    }
    .cred-item:last-child { border-bottom: none; padding-bottom: 0; }
    .cred-num {
      font-size: 28px; font-weight: 300;
      color: var(--chip); flex-shrink: 0; line-height: 1;
    }
    .cred-item h4 { font-size: 17px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .cred-item p { font-size: 14px; color: var(--ink-48); line-height: 1.6; }

    /* ━━ Testimonials ━━ */
    .testimonials { background: var(--canvas); }
    .testi-grid {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 18px; margin-top: 48px;
    }
    .testi {
      background: var(--parchment);
      border-radius: 18px;
      padding: 28px 24px;
      display: flex; flex-direction: column; align-items: center; text-align: center;
    }
    .testi-photo {
      width: 80px; height: 80px; border-radius: 50%;
      object-fit: cover; object-position: top;
      margin-bottom: 20px;
      border: 2px solid var(--divider);
    }
    .testi-quote {
      font-size: 15px; line-height: 1.65;
      color: var(--ink-80); margin-bottom: 20px; flex-grow: 1;
    }
    .testi-sep { width: 24px; height: 1px; background: var(--divider); margin: 0 auto 14px; }
    .testi-name { font-size: 15px; font-weight: 600; color: var(--ink); }
    .testi-role { font-size: 13px; color: var(--ink-48); margin-top: 4px; line-height: 1.5; }

    /* ━━ Journal ━━ */
    .journal { background: var(--parchment); }
    .journal-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; }
    .post-grid {
      display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 2px;
    }
    .post {
      background: var(--canvas); padding: 28px 24px;
      text-decoration: none; color: inherit; display: block;
      border-bottom: 2px solid transparent;
      transition: border-color .2s;
    }
    .post:hover { border-bottom-color: var(--primary); }
    .post-cat {
      font-size: 11px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--primary); margin-bottom: 8px; display: block;
    }
    .post h4 { font-size: 17px; font-weight: 600; color: var(--ink); line-height: 1.4; margin-bottom: 16px; }
    .post-date { font-size: 13px; color: var(--ink-48); }

    /* ━━ CTA: dark tile ━━ */
    .cta-sec {
      background: var(--tile-dark-1);
      text-align: center; padding: var(--sp-sec) 22px;
    }
    .cta-inner { max-width: 580px; margin: 0 auto; }
    .cta-sec .eyebrow { color: var(--primary-dark); }
    .cta-sec h2 { color: var(--on-dark); font-size: clamp(28px, 4vw, 40px); font-weight: 600; line-height: 1.1; letter-spacing: -0.003em; }
    .cta-sec .rule { background: rgba(255,255,255,0.15); margin: 24px auto 32px; }
    .cta-body { font-size: 17px; color: rgba(255,255,255,0.72); line-height: 1.7; margin-bottom: 36px; }
    .cta-btn {
      display: inline-block; padding: 14px 28px;
      background: var(--primary); color: #fff;
      font-size: 17px; font-weight: 400;
      text-decoration: none; border-radius: 980px;
      transition: background .2s, transform .15s;
    }
    .cta-btn:hover { background: var(--primary-focus); transform: scale(1.02); }
    .cta-sub {
      display: block; margin-top: 16px;
      font-size: 14px; color: var(--primary-dark);
      text-decoration: none;
    }
    .cta-sub:hover { text-decoration: underline; }
    .cta-note { margin-top: 12px; font-size: 12px; color: rgba(255,255,255,0.4); }

    /* ━━ Footer ━━ */
    footer { background: #000000; padding: 48px 22px 24px; }
    .footer-grid {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 48px; padding-bottom: 32px;
      border-bottom: 1px solid #333;
    }
    .footer-logo {
      display: inline-block;
      background: rgba(255,255,255,0.9);
      padding: 4px 10px;
      border-radius: 3px;
      margin-bottom: 16px;
    }
    .footer-logo img { height: 24px; width: auto; display: block; }
    .footer-tag { font-size: 14px; color: #6e6e73; line-height: 1.8; }
    .footer-col h5 {
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--primary-dark); margin-bottom: 16px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col a { font-size: 14px; color: #6e6e73; text-decoration: none; transition: color .2s; }
    .footer-col a:hover { color: var(--on-dark); }
    .footer-copy { max-width: 1000px; margin: 20px auto 0; text-align: center; font-size: 12px; color: #6e6e73; }

    /* ━━ Responsive ━━ */
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .hero-body { padding: 0 24px 48px; max-width: 100%; }
      .story-grid { grid-template-columns: 1fr; gap: 32px; }
      .prog-grid { grid-template-columns: 1fr; }
      .prog:first-child { height: 340px; }
      .prog:not(:first-child) { height: 280px; }
      .brand-visual { height: 360px; }
      .cred-grid { grid-template-columns: 1fr; gap: 32px; }
      .testi-grid { grid-template-columns: 1fr; }
      .post-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 32px; }
      section { padding: 56px 22px; }
      .journal-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    }
  </style>
</head>
<body>

  <!-- Nav: Apple global nav style -->
  <nav>
    <a href="/" class="nav-logo"><img src="/logo-wide.png" alt="&LAB TOKYO" /></a>
    <ul class="nav-links">
      <li><a href="/lessons">レッスン</a></li>
      <li><a href="/hacco">Hacco LAB</a></li>
      <li><a href="/about">安藤千英</a></li>
      <li><a href="/blog">ブログ</a></li>
      <li><a href="/lessons" style="color:var(--primary-dark);">体験レッスン</a></li>
    </ul>
    <div class="nav-right">
      <div class="lang-sw">
        <a href="?lang=ja" class={lang==='ja'?'on':''}>JP</a>
        <a href="?lang=en" class={lang==='en'?'on':''}>EN</a>
        <a href="?lang=zh" class={lang==='zh'?'on':''}>中</a>
      </div>
    </div>
  </nav>

  <!-- Hero: edge-to-edge food photo -->
  <section class="hero">
    <img src="/brand-sushi.jpg" alt="&LAB TOKYO" class="hero-photo" />
    <div class="hero-overlay"></div>
    <div class="hero-body">
      <span class="hero-eyebrow">Raw Food × Fermentation · Tokyo Shibuya</span>
      <h1>これからの私を、<br />美しく「醸す」。</h1>
      <p class="hero-sub">細胞からデザインする、一生モノの心と体。</p>
      <p class="hero-desc">
        忙しい毎日の中で、自分の体を後回しにしていませんか。<br />
        発酵×ローフードのクロス理論で、あなたの本来の輝きを取り戻す。
      </p>
      <a href="/lessons" class="hero-cta">体験レッスンを見る</a>
    </div>
  </section>

  <!-- Info strip -->
  <div class="info-strip">
    <div class="info-strip-inner">
      <span>東京・渋谷</span>
      <span>オンライン対応</span>
      <span>少人数制 1〜4名</span>
      <span>初心者歓迎</span>
      <span>¥8,000〜</span>
      <span>入会費なし</span>
      <a href="/lessons">詳しく見る →</a>
    </div>
  </div>

  <!-- Story -->
  <section class="story">
    <div class="inner">
      <div class="story-grid">
        <div class="story-img">
          <img src="/story-lesson.jpg" alt="レッスン風景" />
        </div>
        <div>
          <span class="eyebrow">My Story</span>
          <h2 class="display">なぜ、私は食を伝えるのか。</h2>
          <div class="rule"></div>
          <p class="body-text">
            10年前の4月。娘が台所の熱湯を頭からかぶる大火傷を負いました。
            長期入院、複数回の手術。私は<strong>キッチンに立てなくなった。</strong>
          </p>
          <p class="body-text">
            そこから食を学び直しました。マクロビ、ローフード、発酵。
            食べることが娘を、そして私自身を、内側から再生させていった。
          </p>
          <p class="body-text">
            40代になったとき、更年期という新しい岐路に立ちました。
            そのとき改めて気づいたのです——<strong>「細胞から整える食」は、一生モノの武器だ</strong>、と。
          </p>
          <a href="https://note.com/chieando/n/naa6e962de57b" target="_blank" class="text-link">
            全文をnoteで読む →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs: alternating dark/light tiles -->
  <section class="programs">
    <div class="inner">
      <span class="eyebrow">Programs</span>
      <h2 class="display">3つのプログラム。</h2>
    </div>
    <div class="prog-grid">
      <a href="/lessons" class="prog">
        <img src="/rawfood-zucchini.jpg" alt="ローフード" />
        <div class="prog-ov"></div>
        <div class="prog-body">
          <span class="prog-eye">Program 01</span>
          <h3>ローフード</h3>
          <p class="prog-detail">48℃以下の調理で酵素を活かす。体験〜マイスター資格まで。</p>
          <p class="prog-meta">¥8,000〜 · 対面・オンライン · 初心者OK</p>
        </div>
      </a>
      <a href="/hacco" class="prog">
        <img src="/hacco-amazake.jpg" alt="Hacco LAB" />
        <div class="prog-ov"></div>
        <div class="prog-body">
          <span class="prog-eye">Program 02</span>
          <h3>Hacco LAB</h3>
          <p class="prog-detail">麹・味噌・醤油など日本の発酵文化を現代の暮らしへ。</p>
          <p class="prog-meta">¥8,000〜 · 対面・オンライン · 国際対応</p>
        </div>
      </a>
      <a href="/lessons" class="prog">
        <img src="/prog-chocolate.jpg" alt="ローチョコ" />
        <div class="prog-ov"></div>
        <div class="prog-body">
          <span class="prog-eye">Program 03</span>
          <h3>ローチョコレート</h3>
          <p class="prog-detail">日本ローチョコレーティエ協会公認。カカオの栄養を活かした大人の甘さ。</p>
          <p class="prog-meta">¥8,000〜 · 対面・オンライン · 資格取得可</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Brand visual: full-bleed -->
  <div class="brand-visual">
    <img src="/visual-table.jpg" alt="&LAB TOKYO の世界観" />
    <div class="brand-visual-overlay">
      <div class="brand-visual-text">
        <p>The &LAB World</p>
        <h2>食は、美意識である。</h2>
      </div>
    </div>
  </div>

  <!-- Credentials -->
  <section class="credentials">
    <div class="inner">
      <div class="cred-grid">
        <div class="book-img">
