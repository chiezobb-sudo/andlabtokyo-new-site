---
const lang = Astro.url.searchParams.get('lang') || 'ja';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>安藤千英 | &LAB TOKYO — 発酵×ローフード 東京・渋谷</title>
  <meta name="description" content="ELLE gourmet認定料理家・安藤千英。東京・渋谷の発酵×ローフード ライフスタイルラボ。細胞から整える食の知恵。体験レッスン受付中。" />
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       &LAB TOKYO — 墨と生成り・エディトリアルデザイン
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    :root {
      --linen:   #FBFBFA;
      --linen-2: #F4F2EE;
      --linen-3: #EAE7E0;
      --sumi:    #1C1C1A;
      --sumi-2:  #2A2A27;
      --sumi-3:  #3A3A36;
      --ink:     #1C1C1A;
      --ink-2:   #3D3D38;
      --ink-3:   #7A7A72;
      --on-sumi: #F4F2EE;
      --on-sumi-muted: rgba(244,242,238,.6);
      --green:   #A9D159;
      --green-d: #7AAF2A;
      --green-btn: #4E8A18;
      --green-btn-h: #3D6E12;
      --f-serif: 'Noto Serif JP', 'Times New Roman', serif;
      --f-sans:  'Noto Sans JP', sans-serif;
      --r: 0px;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      font-family: var(--f-sans);
      font-weight: 400;
      background: var(--linen);
      color: var(--ink);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3 {
      font-family: var(--f-serif);
      font-weight: 600;
      letter-spacing: 0.08em;
      line-height: 1.45;
    }
    h1 { font-size: clamp(1.8rem, 3.2vw, 2.6rem); }
    h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); }
    h3 { font-size: clamp(1.15rem, 2vw, 1.5rem); }

    /* ━━ ナビ ━━ */
    nav {
      position: fixed; inset: 0 0 auto 0; z-index: 500;
      height: 52px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3rem;
      background: rgba(28,28,26,.94);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(244,242,238,.08);
    }
    .nav-logo img {
      height: 32px; width: auto;
      mix-blend-mode: screen;
      filter: brightness(1.1);
    }
    .nav-right { display: flex; align-items: center; gap: 0; }
    .nav-links { display: flex; list-style: none; gap: 0; }
    .nav-links a {
      font-family: var(--f-sans); font-size: .82rem; font-weight: 500;
      letter-spacing: .04em;
      color: rgba(244,242,238,.65); text-decoration: none;
      padding: 0 1.1rem; transition: color .2s;
    }
    .nav-links a:hover { color: var(--green); }
    .nav-cta {
      font-family: var(--f-sans); font-size: .82rem; font-weight: 700;
      letter-spacing: .04em;
      display: inline-block;
      background: var(--green-btn); color: #FAF5EC;
      padding: .45rem 1.4rem; margin-left: 1.2rem;
      text-decoration: none; transition: background .2s;
    }
    .nav-cta:hover { background: var(--green-btn-h); color: #fff; }
    .lang { display: flex; align-items: center; margin-left: 1rem; padding-left: 1rem; border-left: 1px solid rgba(244,242,238,.12); }
    .lang a { font-size: .72rem; color: rgba(244,242,238,.4); text-decoration: none; padding: 0 6px; transition: color .2s; }
    .lang a.on { color: var(--green); font-weight: 700; }
    .lang a:hover { color: rgba(244,242,238,.8); }

    /* ━━ HERO ━━ */
    .hero {
      margin-top: 52px;
      position: relative;
      height: calc(100vh - 52px);
      min-height: 600px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
    }
    .hero-video {
      position: absolute; inset: 0; z-index: 0;
    }
    .hero-video video {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      display: block;
    }
    .hero-video-fallback {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 20%;
      display: block;
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        linear-gradient(to top, rgba(28,28,26,.82) 0%, rgba(28,28,26,.35) 50%, rgba(28,28,26,.1) 100%),
        linear-gradient(to right, rgba(28,28,26,.5) 0%, transparent 55%);
    }
    .hero-text {
      position: relative; z-index: 2;
      padding: 0 5vw 8vh;
      max-width: 680px;
    }
    .hero-eyebrow {
      font-family: var(--f-sans);
      font-size: .72rem; font-weight: 500;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--green); margin-bottom: 2rem; display: block;
    }
    .hero h1 {
      color: #FAF5EC;
      margin-bottom: 1.2rem;
      font-weight: 600;
      letter-spacing: .1em;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--green);
      display: block;
    }
    .hero-sub {
      font-family: var(--f-serif);
      font-size: 1rem; font-weight: 300;
      letter-spacing: .1em;
      color: rgba(244,242,238,.75); margin-bottom: 2.4rem;
      line-height: 2;
    }
    .hero-desc {
      font-size: .9rem; color: rgba(244,242,238,.72);
      line-height: 2; margin-bottom: 3rem;
      max-width: 420px;
    }
    .btn-primary {
      display: inline-block;
      background: var(--sumi); color: var(--on-sumi);
      font-family: var(--f-sans); font-size: .85rem; font-weight: 700;
      letter-spacing: .08em;
      padding: .95rem 2.4rem; text-decoration: none;
      transition: background .2s;
    }
    .btn-primary:hover { background: var(--sumi-2); }

    /* ━━ ストリップ ━━ */
    .strip {
      background: var(--sumi);
      padding: 1.4rem 3rem;
      border-top: 1px solid rgba(244,242,238,.06);
    }
    .strip-inner {
      max-width: 1100px; margin: 0 auto;
      display: flex; align-items: center; gap: 0; flex-wrap: wrap;
    }
    .strip-label {
      font-family: var(--f-serif);
      font-size: .72rem; letter-spacing: .18em; text-transform: uppercase;
      color: var(--green); white-space: nowrap; margin-right: 2rem;
    }
    .strip-items { display: flex; flex-wrap: wrap; gap: 0; flex: 1; }
    .strip-items span {
      font-size: .82rem; color: rgba(244,242,238,.65);
      padding: 0 1.2rem; border-right: 1px solid rgba(244,242,238,.1);
    }
    .strip-items span:last-child { border-right: none; }
    .strip-link {
      margin-left: auto; font-size: .8rem;
      color: var(--green); text-decoration: none; white-space: nowrap;
    }
    .strip-link:hover { text-decoration: underline; }

    /* ━━ STORY ━━ */
    .story { background: var(--linen-2); padding: 8rem 3rem; }
    .story-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 48% 1fr;
      gap: 6rem; align-items: start;
    }
    .story-photo { position: relative; }
    .story-photo img {
      width: 100%; aspect-ratio: 3/4;
      object-fit: cover; object-position: top;
      display: block;
    }
    .story-photo-caption {
      margin-top: .8rem;
      font-family: var(--f-serif);
      font-size: .72rem; letter-spacing: .12em;
      color: var(--ink-3); text-align: right;
    }
    .story-text { padding-top: 2rem; }
    .eyebrow {
      font-family: var(--f-sans);
      font-size: .72rem; font-weight: 500;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--green-d); display: block; margin-bottom: 1rem;
    }
    .story-text h2 { color: var(--ink); margin-bottom: 2rem; }
    .rule { width: 32px; height: 1px; background: var(--ink-3); margin: 2rem 0; }
    .body-p {
      font-size: .95rem; color: var(--ink-2);
      line-height: 2.1; margin-bottom: 1.4rem;
    }
    .body-p strong { color: var(--ink); font-weight: 700; }
    .pull-quote {
      margin: 2rem 0;
      padding: 1.2rem 1.6rem;
      border-left: 2px solid var(--ink);
    }
    .pull-quote p {
      font-family: var(--f-serif);
      font-size: 1rem; font-weight: 400;
      letter-spacing: .06em; color: var(--ink);
      line-height: 1.8;
    }
    .text-link {
      font-size: .85rem; color: var(--ink-3);
      text-decoration: none;
      border-bottom: 1px solid rgba(122,122,114,.3);
      padding-bottom: 1px; transition: all .2s;
    }
    .text-link:hover { color: var(--ink); border-color: var(--ink); }

    /* ━━ PROGRAMS ━━ */
    .programs { background: var(--sumi); padding: 8rem 3rem; }
    .programs-inner { max-width: 1100px; margin: 0 auto; }
    .programs h2 { color: var(--on-sumi); margin-bottom: 5rem; }
    .programs .eyebrow { color: var(--green); }
    .prog-featured {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 2px; margin-bottom: 2px;
    }
    .prog-featured-main {
      position: relative; overflow: hidden; height: 540px;
      text-decoration: none; display: block;
    }
    .prog-featured-main img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .8s ease; display: block;
    }
    .prog-featured-main:hover img { transform: scale(1.03); }
    .prog-sub-stack { display: grid; grid-template-rows: 1fr 1fr; gap: 2px; }
    .prog-sub {
      position: relative; overflow: hidden; height: 269px;
      text-decoration: none; display: block;
    }
    .prog-sub img { width: 100%; height: 100%; object-fit: cover; transition: transform .8s; display: block; }
    .prog-sub:hover img { transform: scale(1.04); }
    .prog-ov {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(28,28,26,.88) 0%, rgba(28,28,26,.1) 55%, transparent 100%);
      transition: background .3s;
    }
    .prog-featured-main:hover .prog-ov,
    .prog-sub:hover .prog-ov {
      background: linear-gradient(to top, rgba(28,28,26,.94) 0%, rgba(28,28,26,.25) 55%, transparent 100%);
    }
    .prog-body { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem 2rem 2.4rem; }
    .prog-eye {
      font-family: var(--f-sans);
      font-size: .68rem; font-weight: 500;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--green); margin-bottom: .6rem; display: block;
    }
    .prog-body h3 {
      font-family: var(--f-serif);
      font-size: 1.2rem; font-weight: 600;
      color: var(--on-sumi); letter-spacing: .06em;
      margin-bottom: .5rem;
    }
    .prog-featured-main .prog-body h3 { font-size: 1.5rem; }
    .prog-body p { font-size: .82rem; color: rgba(244,242,238,.65); line-height: 1.8; margin-bottom: .6rem; }
    .prog-meta { font-size: .75rem; color: var(--green); font-weight: 500; }

    /* ━━ ブランドビジュアル ━━ */
    .brand-visual { position: relative; height: 56vh; min-height: 360px; overflow: hidden; }
    .brand-visual img { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; display: block; }
    .brand-visual-overlay {
      position: absolute; inset: 0;
      background: rgba(28,28,26,.42);
      display: flex; align-items: center; justify-content: center;
    }
    .brand-visual-text { text-align: center; }
    .brand-visual-text p {
      font-family: var(--f-sans);
      font-size: .72rem; letter-spacing: .2em; text-transform: uppercase;
      color: rgba(244,242,238,.55); margin-bottom: 1rem;
    }
    .brand-visual-text h2 {
      font-family: var(--f-serif);
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 400; letter-spacing: .12em;
      color: var(--on-sumi);
    }

    /* ━━ CREDENTIALS ━━ */
    .credentials { background: var(--linen); padding: 8rem 3rem; }
    .credentials-inner { max-width: 1100px; margin: 0 auto; }
    .cred-grid { display: grid; grid-template-columns: 280px 1fr; gap: 7rem; align-items: start; }
    .book-img img { width: 100%; box-shadow: 16px 24px 48px rgba(28,28,26,.18); }
    .cred-list { display: flex; flex-direction: column; gap: 2.2rem; }
    .cred-item { display: flex; gap: 1.6rem; align-items: flex-start; padding-bottom: 2.2rem; border-bottom: 1px solid var(--linen-3); }
    .cred-item:last-child { border-bottom: none; padding-bottom: 0; }
    .cred-num {
      font-family: var(--f-serif);
      font-size: 1.8rem; font-weight: 300;
      color: var(--linen-3); flex-shrink: 0; line-height: 1;
    }
    .cred-item h4 { font-family: var(--f-serif); font-size: 1rem; font-weight: 600; letter-spacing: .04em; color: var(--ink); margin-bottom: .4rem; }
    .cred-item p { font-size: .88rem; color: var(--ink-3); line-height: 1.85; }

    /* ━━ TESTIMONIALS ━━ */
    .testimonials { background: var(--linen-2); padding: 8rem 3rem; }
    .testi-inner { max-width: 1100px; margin: 0 auto; }
    .testi-featured { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; align-items: start; margin-top: 4rem; margin-bottom: 3rem; padding-bottom: 3rem; border-bottom: 1px solid var(--linen-3); }
    .testi-featured-photo { position: relative; }
    .testi-featured-photo img { width: 100%; aspect-ratio: 3/4; object-fit: cover; object-position: top; display: block; }
    .testi-featured-content { padding-top: 1rem; }
    .testi-big-quote {
      font-family: var(--f-serif);
      font-size: 1.05rem; font-weight: 400;
      letter-spacing: .04em; color: var(--ink);
      line-height: 2; margin-bottom: 2rem;
    }
    .testi-big-quote::before { content: '「'; color: var(--green-d); font-size: 1.4rem; }
    .testi-big-quote::after  { content: '」'; color: var(--green-d); font-size: 1.4rem; }
    .testi-name { font-family: var(--f-serif); font-size: .95rem; font-weight: 600; letter-spacing: .06em; color: var(--ink); margin-bottom: .3rem; }
    .testi-role { font-size: .8rem; color: var(--ink-3); line-height: 1.6; }
    .testi-small-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
    .testi-small { display: flex; gap: 1.2rem; align-items: flex-start; }
    .testi-small-photo { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; object-position: top; flex-shrink: 0; }
    .testi-small-quote { font-size: .88rem; color: var(--ink-2); line-height: 1.9; margin-bottom: .8rem; }
    .testi-small-name { font-family: var(--f-serif); font-size: .88rem; font-weight: 600; color: var(--ink); }
    .testi-small-role { font-size: .75rem; color: var(--ink-3); }

    /* ━━ JOURNAL ━━ */
    .journal { background: var(--sumi); padding: 8rem 3rem; }
    .journal-inner { max-width: 1100px; margin: 0 auto; }
    .journal h2 { color: var(--on-sumi); margin-bottom: 4rem; }
    .journal .eyebrow { color: var(--green); }
    .journal-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
    .journal-all { font-size: .82rem; color: rgba(244,242,238,.45); text-decoration: none; transition: color .2s; }
    .journal-all:hover { color: var(--green); }
    .post-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 2px; }
    .post { background: var(--sumi-2); text-decoration: none; display: block; transition: background .2s; }
    .post:hover { background: var(--sumi-3); }
    .post-img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }
    .post:first-child .post-img { aspect-ratio: 4/3; }
    .post-body { padding: 1.6rem 1.4rem 2rem; }
    .post-cat {
      font-family: var(--f-sans); font-size: .68rem; font-weight: 500;
      letter-spacing: .16em; text-transform: uppercase;
      color: var(--green); margin-bottom: .6rem; display: block;
    }
    .post h3 {
      font-family: var(--f-serif);
      font-size: .98rem; font-weight: 600; letter-spacing: .04em;
      color: var(--on-sumi); line-height: 1.6; margin-bottom: 1rem;
    }
    .post:first-child h3 { font-size: 1.15rem; }
    .post-date { font-size: .72rem; color: rgba(244,242,238,.3); }

    /* ━━ SNS SECTION ━━ */
    .social-section {
      background: var(--sumi-2);
      padding: 6rem 3rem;
      border-top: 1px solid rgba(244,242,238,.06);
    }
    .social-inner { max-width: 900px; margin: 0 auto; text-align: center; }
    .social-label {
      font-family: var(--f-sans);
      font-size: .72rem; font-weight: 500;
      letter-spacing: .2em; text-transform: uppercase;
      color: var(--green); margin-bottom: 3rem; display: block;
    }
    .social-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
    }
    .social-item {
      display: flex; flex-direction: column;
      align-items: center; gap: .8rem;
      padding: 2.4rem 1rem;
      background: var(--sumi-3);
      text-decoration: none; color: rgba(244,242,238,.55);
      transition: background .2s, color .2s;
    }
    .social-item:hover { background: var(--sumi); color: var(--green); }
    .social-icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; }
    .social-icon svg { width: 24px; height: 24px; }
    .social-name {
      font-family: var(--f-sans); font-size: .75rem; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      color: rgba(244,242,238,.7); transition: color .2s;
    }
    .social-item:hover .social-name { color: var(--on-sumi); }
    .social-handle { font-size: .72rem; color: rgba(244,242,238,.3); letter-spacing: .04em; }

    /* ━━ CTA ━━ */
    .cta { background: var(--linen); padding: 10rem 3rem; text-align: center; }
    .cta-inner { max-width: 560px; margin: 0 auto; }
    .cta h2 { color: var(--ink); margin-bottom: 1.4rem; }
    .cta .eyebrow { color: var(--green-d); }
    .cta-rule { width: 40px; height: 1px; background: var(--linen-3); margin: 2rem auto 2.8rem; }
    .cta-desc { font-size: .95rem; color: var(--ink-3); line-height: 2; margin-bottom: 3rem; }
    .cta-sub { display: block; margin-top: 1.4rem; font-size: .82rem; color: var(--ink-3); text-decoration: none; transition: color .2s; }
    .cta-sub:hover { color: var(--ink); }

    /* ━━ FOOTER ━━ */
    footer { background: var(--sumi); padding: 5rem 3rem 2.5rem; border-top: 1px solid rgba(244,242,238,.06); }
    .footer-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 5rem; padding-bottom: 3.5rem; border-bottom: 1px solid rgba(244,242,238,.06); }
    .footer-logo img { height: 32px; margin-bottom: 1.4rem; mix-blend-mode: screen; filter: brightness(1.1); }
    .footer-tag { font-size: .82rem; color: rgba(244,242,238,.4); line-height: 1.9; }
    .footer-col h5 { font-family: var(--f-sans); font-size: .68rem; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: var(--green); margin-bottom: 1.2rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .75rem; }
    .footer-col a { font-size: .85rem; color: rgba(244,242,238,.38); text-decoration: none; transition: color .2s; }
    .footer-col a:hover { color: var(--on-sumi); }
    .footer-copy { max-width: 1100px; margin: 2.5rem auto 0; text-align: center; font-size: .72rem; color: rgba(244,242,238,.18); }

    /* ━━ レスポンシブ ━━ */
    @media (prefers-reduced-motion: reduce) {
      .hero-video video { display: none; }
    }
    @media (max-width: 960px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; }
      .hero { height: 85vh; min-height: 500px; }
      .hero-text { padding: 0 1.5rem 5vh; max-width: 100%; }
      .strip { padding: 1.4rem 1.5rem; }
      .story { padding: 5rem 1.5rem; }
      .story-inner { grid-template-columns: 1fr; gap: 3rem; }
      .story-photo img { aspect-ratio: 4/3; }
      .programs { padding: 5rem 1.5rem; }
      .prog-featured { grid-template-columns: 1fr; }
      .prog-featured-main { height: 340px; }
      .prog-sub-stack { grid-template-columns: 1fr 1fr; }
      .prog-sub { height: 220px; }
      .brand-visual { height: 42vw; min-height: 260px; }
      .credentials { padding: 5rem 1.5rem; }
      .cred-grid { grid-template-columns: 1fr; gap: 3rem; }
      .testimonials { padding: 5rem 1.5rem; }
      .testi-featured { grid-template-columns: 1fr; gap: 2.5rem; }
      .testi-featured-photo img { aspect-ratio: 16/9; }
