---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="これからの私を、美しく「醸す」。 | &LAB TOKYO"
  description="発酵と美の学校。東京・渋谷のプレミアム・ライフスタイルラボ。ローフード×発酵のクロス理論でライフスタイルを進化させる &LAB TOKYO。ELLE gourmet認定料理家・安藤千英が主宰。"
  canonical="https://www.andlabtokyo.com/"
  type="website"
>

<style>
/* ===== HERO ===== */
.hero {
  min-height: calc(100vh - 73px);
  background: #FAF9F6;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.hero-image-wrap {
  position: absolute;
  right: 0;
  top: 0;
  width: 80%;
  height: 100%;
  overflow: hidden;
}
.hero-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  filter: brightness(1.05);
}
.hero-gradient {
  position: absolute;
  left: 0; top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to right,
    #FAF9F6 0%,
    #FAF9F6 22%,
    rgba(250,249,246,0.82) 42%,
    rgba(250,249,246,0) 68%,
    transparent 100%
  );
  pointer-events: none;
}
.hero-text {
  position: relative;
  z-index: 10;
  padding: 0 4rem;
  width: 52%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.hero-eyebrow {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #7A7A72;
  font-weight: 400;
  display: block;
  margin-bottom: 1.2rem;
}
.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 200;
  letter-spacing: 0.28em;
  line-height: 1.45;
  color: #1C1C1A;
  margin-bottom: 2.8rem;
}
.hero-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  letter-spacing: 0.08em;
  line-height: 2.2;
  color: #7A7A72;
  font-weight: 300;
  margin-bottom: 1.2rem;
}
.hero-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  line-height: 2.1;
  color: #999;
  font-weight: 300;
  margin-bottom: 3.5rem;
}
.hero-cta {
  display: inline-block;
  width: fit-content;
  font-family: 'Noto Serif JP', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #1C1C1A;
  text-decoration: none;
  border-bottom: 1.5px solid #1C1C1A;
  padding-bottom: 0.7rem;
  transition: opacity 0.3s;
  font-weight: 300;
}
.hero-cta:hover { opacity: 0.55; }
.scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.8rem;
}
.scroll-indicator span {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 8px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #7A7A72;
}
.scroll-indicator div {
  width: 1px;
  height: 32px;
  background: #7A7A72;
  opacity: 0.35;
}

/* ===== ABOUT ===== */
.about-sec {
  padding: 7rem 4rem;
  background: #FAF9F6;
}
.about-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 5rem;
}
.about-left {
  display: flex;
  flex-direction: column;
}
.rule {
  width: 36px;
  height: 1px;
  background: #1C1C1A;
  margin-bottom: 2rem;
}
.about-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.08em;
  line-height: 2.2;
  color: #7A7A72;
  margin-bottom: 1.6rem;
}
.about-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.6rem, 2.2vw, 2.1rem);
  font-weight: 400;
  font-style: italic;
  letter-spacing: 0.06em;
  color: #1C1C1A;
}
.about-right {
  max-width: 640px;
}
.about-lead {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  line-height: 2.4;
  color: #7A7A72;
  font-weight: 300;
  letter-spacing: 0.03em;
  margin-bottom: 1.8rem;
}
.about-lead:last-child { margin-bottom: 0; }
.about-lead strong {
  color: #1C1C1A;
  font-weight: 400;
}

/* ===== TWO ENTRY POINTS ===== */
.entries-sec {
  padding: 0 4rem 7rem;
  background: #FAF9F6;
}
.entries-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
}
.entry-card {
  background: #F4F0E9;
  display: grid;
  grid-template-columns: 1fr 1fr;
  text-decoration: none;
  color: inherit;
}
.entry-text {
  padding: 3.2rem 2.8rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.entry-eyebrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  margin-bottom: 0.8rem;
}
.entry-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.2rem, 1.8vw, 1.5rem);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #1C1C1A;
  margin-bottom: 1.8rem;
  line-height: 1.6;
}
.entry-list {
  list-style: none;
}
.entry-list li {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  line-height: 2.4;
  color: #7A7A72;
  font-weight: 300;
}
.entry-img {
  aspect-ratio: 4/5;
  overflow: hidden;
}
.entry-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1s ease;
}
.entry-card:hover .entry-img img { transform: scale(1.04); }

/* ===== COURSE NAVIGATION ===== */
.courses-sec {
  padding: 7rem 0;
  background: #FAF9F6;
}
.courses-header {
  max-width: 1100px;
  margin: 0 auto 3rem;
  padding: 0 4rem;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.courses-eyebrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.8rem;
}
.courses-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.4vw, 2.1rem);
  font-weight: 300;
  letter-spacing: 0.12em;
  color: #1C1C1A;
}
.courses-link {
  font-family: 'Noto Serif JP', serif;
  font-size: 11px;
  letter-spacing: 0.15em;
  color: #7A7A72;
  text-decoration: none;
  border-bottom: 1px solid rgba(28,28,26,0.2);
  padding-bottom: 0.4rem;
  white-space: nowrap;
  transition: color 0.3s, border-color 0.3s;
}
.courses-link:hover { color: #1C1C1A; border-color: #1C1C1A; }
.courses-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}
.course-card {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  text-decoration: none;
  display: block;
}
.course-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.55);
  transition: filter 0.6s ease, transform 1s ease;
}
.course-card:hover img {
  filter: brightness(0.75);
  transform: scale(1.04);
}
.course-card-text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.6rem 1.4rem;
  color: #fff;
}
.course-card-jp {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  font-weight: 300;
  letter-spacing: 0.18em;
  margin-bottom: 0.5rem;
}
.course-card-en {
  font-family: 'Cormorant Garamond', serif;
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
}

/* ===== LATEST ACTIVITY ===== */
.activity-sec {
  padding: 7rem 4rem;
  background: #FAF9F6;
}
.activity-header {
  max-width: 1100px;
  margin: 0 auto 4rem;
  text-align: center;
}
.activity-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.4vw, 2.1rem);
  font-weight: 300;
  letter-spacing: 0.16em;
  color: #1C1C1A;
  margin-bottom: 1rem;
}
.activity-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  line-height: 2;
  color: #999;
  font-weight: 300;
}
.activity-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2.5rem;
}
.activity-card {
  text-decoration: none;
  color: inherit;
  display: block;
}
.activity-img {
  aspect-ratio: 4/5;
  overflow: hidden;
  margin-bottom: 1.4rem;
  background: #E5E0DA;
}
.activity-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1s ease;
}
.activity-card:hover .activity-img img { transform: scale(1.04); }
.activity-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.6rem;
}
.activity-card h3 {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0.06em;
  line-height: 1.8;
  color: #1C1C1A;
}

/* ===== LATEST JOURNALS ===== */
.journals-sec {
  padding: 7rem 4rem;
  background: #FAF9F6;
}
.journals-header {
  max-width: 1100px;
  margin: 0 auto 4rem;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.journals-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.4vw, 2.1rem);
  font-weight: 300;
  letter-spacing: 0.14em;
  color: #1C1C1A;
}
.journals-link {
  font-family: 'Noto Serif JP', serif;
  font-size: 11px;
  letter-spacing: 0.15em;
  color: #7A7A72;
  text-decoration: none;
  border-bottom: 1px solid rgba(28,28,26,0.2);
  padding-bottom: 0.4rem;
  transition: color 0.3s, border-color 0.3s;
}
.journals-link:hover { color: #1C1C1A; border-color: #1C1C1A; }
.journals-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem;
}
.journal-card {
  text-decoration: none;
  color: inherit;
  display: block;
}
.journal-img {
  aspect-ratio: 4/3;
  overflow: hidden;
  margin-bottom: 1.4rem;
  background: #E5E0DA;
}
.journal-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1s ease;
}
.journal-card:hover .journal-img img { transform: scale(1.04); }
.journal-category {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.6rem;
}
.journal-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: 0.06em;
  line-height: 1.8;
  color: #1C1C1A;
  margin-bottom: 0.8rem;
}
.journal-desc {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  color: #7A7A72;
  line-height: 1.7;
  margin-bottom: 1rem;
  font-weight: 300;
}
.journal-date {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.08em;
  color: #999;
}

/* ===== KNOWLEDGE ===== */
.knowledge-sec {
  padding: 7rem 4rem 8rem;
  background: #F4F0E9;
}
.knowledge-header {
  max-width: 1100px;
  margin: 0 auto 4rem;
  text-align: center;
}
.knowledge-eyebrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 1rem;
}
.knowledge-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem, 2.4vw, 2.1rem);
  font-weight: 300;
  letter-spacing: 0.14em;
  color: #1C1C1A;
  margin-bottom: 1.4rem;
}
.knowledge-sub {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  letter-spacing: 0.04em;
  line-height: 2.1;
  color: #999;
  font-weight: 300;
}
.knowledge-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 2px;
}
.knowledge-card {
  background: #FAF9F6;
  text-decoration: none;
  color: inherit;
  display: block;
  padding: 1.8rem 1.6rem 2.2rem;
  transition: background 0.3s;
}
.knowledge-card:hover { background: #fff; }
.knowledge-img {
  aspect-ratio: 1/1;
  overflow: hidden;
  margin-bottom: 1.4rem;
}
.knowledge-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1s ease;
}
.knowledge-card:hover .knowledge-img img { transform: scale(1.05); }
.knowledge-card h4 {
  font-family: 'Noto Serif JP', serif;
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.05em;
  line-height: 1.8;
  color: #1C1C1A;
  margin-bottom: 0.6rem;
}
.knowledge-arrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.15em;
  color: #7A7A72;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .courses-grid { grid-template-columns: repeat(3, 1fr); }
  .activity-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  .journals-grid { grid-template-columns: repeat(2, 1fr); }
  .knowledge-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .hero-text { width: 65%; }
  .hero-image-wrap { width: 70%; }
  .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  .entry-card { grid-template-columns: 1fr; }
  .entry-img { aspect-ratio: 16/9; order: -1; }
}
@media (max-width: 640px) {
  .hero {
    flex-direction: column;
    align-items: flex-start;
    min-height: auto;
    padding: 3rem 0 0;
  }
  .hero-image-wrap {
    position: relative;
    width: 100%;
    height: 55vw;
    min-height: 240px;
  }
  .hero-gradient {
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(250,249,246,0.7) 70%,
      #FAF9F6 100%
    );
  }
  .hero-text { width: 100%; padding: 2.5rem 1.5rem 4rem; }
  .hero-title { font-size: 1.8rem; margin-bottom: 2rem; }
  .scroll-indicator { left: 1.5rem; }
  .about-sec { padding: 4.5rem 1.5rem; }
  .entries-sec { padding: 0 1.5rem 4.5rem; }
  .entries-grid { grid-template-columns: 1fr; }
  .courses-sec { padding: 4.5rem 0; }
  .courses-header { padding: 0 1.5rem; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .courses-grid { grid-template-columns: repeat(2, 1fr); }
  .activity-sec { padding: 4.5rem 1.5rem; }
  .activity-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .journals-sec { padding: 4.5rem 1.5rem; }
  .journals-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .journals-grid { grid-template-columns: 1fr; }
  .knowledge-sec { padding: 4.5rem 1.5rem 5rem; }
  .knowledge-grid { grid-template-columns: 1fr 1fr; }
}
</style>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-image-wrap">
    <img src="/herotable.JPG" alt="&LAB TOKYO Studio"
      onerror="this.style.background='#E5E0DA';this.style.opacity='0'"
    />
    <div class="hero-gradient"></div>
  </div>

  <div class="hero-text">
    <span class="hero-eyebrow">Fermentation Creator · Tokyo Shibuya</span>
    <h1 class="hero-title">
      これからの私を、<br>
      美しく「醸す」。
    </h1>
    <p class="hero-sub">
      細胞からデザインする、<br>
      一生モノの心と体。
    </p>
    <p class="hero-body">
      忙しい毎日の中で、自分の体を後回しにしていませんか。<br>
      発酵×ローフードのクロス理論で、<br>
      あなたの本来の輝きを取り戻す。
    </p>
    <a href="/brand" class="hero-cta">&LAB TOKYO について</a>

    <div class="scroll-indicator">
      <span>Scroll</span>
      <div></div>
    </div>
  </div>
</section>

<!-- ===== ABOUT ===== -->
<section class="about-sec">
  <div class="about-grid">
    <div class="about-left">
      <div class="rule"></div>
      <p class="about-sub">美しさを、<br>自ら「つくる」人へ。</p>
      <h2 class="about-title">About<br>&LAB TOKYO</h2>
    </div>
    <div class="about-right">
      <p class="about-lead">
        &LAB TOKYOは、東京・渋谷を拠点とする<br>
        「発酵×ローフード」のクロス理論でライフスタイルを進化させる。
      </p>
      <p class="about-lead">
        私たちが提案するのは、単なる「料理」ではありません。<br>
        細胞から目覚めるような<strong>生きたエネルギー（酵素）</strong>を取り入れ、<br>
        古来の知恵である<strong>「発酵」</strong>で内側から美しさを醸成する。
      </p>
      <p class="about-lead">
        経営者、専門職、そして自分自身の可能性を信じるすべての女性へ。<br>
        あなたが持つ本来の輝きを、最大化させる場所でありたい。<br>
        ELLE gourmet認定料理家・安藤千英が、その旅路をガイドします。
      </p>
    </div>
  </div>
</section>

<!-- ===== TWO ENTRY POINTS ===== -->
<section class="entries-sec">
  <div class="entries-grid">
    <a href="/listofcourses" class="entry-card">
      <div class="entry-text">
        <span class="entry-eyebrow">Reset</span>
        <h3 class="entry-title">身体を<br>リセットする</h3>
        <ul class="entry-list">
          <li>ローフード講座</li>
          <li>デトックス・即効美容</li>
          <li>体が軽くなる・肌が輝く</li>
          <li>まずは変化を感じたい方へ</li>
        </ul>
      </div>
      <div class="entry-img">
        <img src="/rawfood-zucchini.jpg" alt="ローフード講座" loading="lazy" onerror="this.style.display='none'" />
      </div>
    </a>
    <a href="/listofcourses" class="entry-card">
      <div class="entry-text">
        <span class="entry-eyebrow">Mastery</span>
        <h3 class="entry-title">一生の武器を<br>得る</h3>
        <ul class="entry-list">
          <li>発酵プランナー講座</li>
          <li>根本体質改善・専門知識</li>
          <li>腸から整う・心が安定する</li>
          <li>深く学び、自立したい方へ</li>
        </ul>
      </div>
      <div class="entry-img">
        <img src="/hacco-amazake.jpg" alt="発酵プランナー講座" loading="lazy" onerror="this.style.display='none'" />
      </div>
    </a>
  </div>
</section>

<!-- ===== COURSE NAVIGATION ===== -->
<section class="courses-sec">
  <div class="courses-header">
    <div>
      <span class="courses-eyebrow">Courses</span>
      <h2 class="courses-title">ジャンルから講座を選ぶ</h2>
    </div>
    <a href="/listofcourses" class="courses-link">全ての講座を表示 →</a>
  </div>
  <div class="courses-grid">
    <a href="/rawfood" class="course-card">
      <img src="/rawfood-zucchini.jpg" alt="ローフード" loading="lazy" />
      <div class="course-card-text">
        <span class="course-card-jp">ローフード</span>
        <span class="course-card-en">Raw Food</span>
      </div>
    </a>
    <a href="/fermentation" class="course-card">
      <img src="/hacco-koji.jpg" alt="発酵" loading="lazy" />
      <div class="course-card-text">
