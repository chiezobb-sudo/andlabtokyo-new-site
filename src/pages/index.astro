---
const lang = Astro.url.searchParams.get('lang') || 'ja';
const t = {
  ja: {
    navItems: [
      { label: 'レッスン', href: '/lessons' },
      { label: 'Hacco LAB', href: '/hacco' },
      { label: 'ブログ', href: '/blog' },
      { label: '安藤千英', href: '/about' },
    ],
    navCta: '体験レッスン',
    heroEye: 'Raw Food × Fermentation · Tokyo',
    h1a: 'これからの私を、',
    h1b: '美しく「醸す」。',
    heroSub: '細胞からデザインする、一生モノの心と体。',
    heroCta: '&LABの世界へ',
    heroCtaGhost: 'まずは体験レッスン',
    conceptEye: 'About &LAB TOKYO',
    conceptH: '美しさを、\n自ら「つくる」人へ。',
    conceptBody: '&LAB TOKYOは、東京・渋谷を拠点とする「発酵×ローフード」のクロス理論でライフスタイルを進化させるラボです。\n\n単なる「料理」ではありません。細胞から目覚めるような生きたエネルギー（酵素）を取り入れ、古来の知恵である「発酵」で内側から美しさを醸成する。\n\n経営者、専門職、自分自身の可能性を信じるすべての女性へ。あなたが持つ本来の輝きを、最大化させる場所でありたい。',
    conceptCredit: 'ELLE gourmet認定料理家　安藤千英',
    conceptLink: '安藤千英について →',
    progsEye: 'Programs',
    progsH: '3つのプログラムで、\n内側から整える。',
    progs: [
      { eye: '01 Raw Food', h: 'ローフード', body: '48℃以下の調理で酵素・栄養を壊さない。生きた食材のチカラで細胞から整えます。', href: '/lessons', img: '/hero-food.jpg' },
      { eye: '02 Fermentation', h: 'Hacco LAB', body: '麹・味噌・醤油など日本の発酵文化を現代の暮らしへ。腸から美しさをデザインします。', href: '/hacco', img: '/koji.jpg' },
      { eye: '03 Raw Chocolate', h: 'ローチョコレート', body: '日本ローチョコレーティエ協会公認。カカオの栄養を活かした、大人のための甘さ。', href: '/lessons', img: '/raw-chocolate.jpg' },
    ],
    blogEye: 'Journal',
    blogH: '食と発酵の、\n知恵と実践。',
    blogLink: 'すべての記事を見る →',
    posts: [
      { cat: 'Raw Food', title: '酵素を壊さない調理の5つの基本', date: '2026.05.20', href: '/blog' },
      { cat: 'Hacco LAB', title: '自家製麹の作り方｜初心者でも失敗しない方法', date: '2026.05.10', href: '/blog' },
      { cat: 'Lifestyle', title: '忙しい経営者が「食」で自分を整える方法', date: '2026.04.28', href: '/blog' },
    ],
    ctaEye: 'First Step',
    ctaH: '忙しさを、輝きに変える。',
    ctaBody: '経営者・専門職・自分を更新し続けたいすべての女性のための\n発酵×ローフード ライフスタイル・ラボ',
    ctaBtn: '体験レッスンを予約する',
    ctaSub: 'お問い合わせ・ご質問はこちら →',
    footerTag: 'Raw Food × Fermentation\nLifestyle Lab · Tokyo Shibuya',
    footerMenuLabel: 'Menu',
    footerFollowLabel: 'Follow',
    copyright: '© 2026 &LAB TOKYO. All rights reserved.',
  },
  en: {
    navItems: [
      { label: 'Lessons', href: '/lessons' },
      { label: 'Hacco LAB', href: '/hacco' },
      { label: 'Blog', href: '/blog' },
      { label: 'About Chie', href: '/about' },
    ],
    navCta: 'Trial Lesson',
    heroEye: 'Raw Food × Fermentation · Tokyo',
    h1a: 'Transform yourself,',
    h1b: 'beautifully.',
    heroSub: 'Designing body & mind from the cellular level.',
    heroCta: 'Enter &LAB World',
    heroCtaGhost: 'Book a Trial Lesson',
    conceptEye: 'About &LAB TOKYO',
    conceptH: 'For those who\ncreate their own beauty.',
    conceptBody: '&LAB TOKYO is a lifestyle lab in Shibuya, Tokyo, evolving your life through the cross-theory of fermentation × raw food.\n\nWe go beyond "cooking." We invite living enzymes that awaken cells, and cultivate inner beauty through the ancient wisdom of fermentation.\n\nFor executives, professionals, and every woman who believes in her own potential.',
    conceptCredit: 'ELLE gourmet Certified Chef  Chie Ando',
    conceptLink: 'About Chie Ando →',
    progsEye: 'Programs',
    progsH: 'Three programs,\none beautiful transformation.',
    progs: [
      { eye: '01 Raw Food', h: 'Raw Food', body: 'Cooking below 48°C preserves enzymes. Nourish cells with living ingredients.', href: '/lessons', img: '/hero-food.jpg' },
      { eye: '02 Fermentation', h: 'Hacco LAB', body: 'Bringing Japanese fermentation traditions into modern life. Design beauty from the gut.', href: '/hacco', img: '/koji.jpg' },
      { eye: '03 Raw Chocolate', h: 'Raw Chocolate', body: 'Japan Raw Chocolatier Association certified. Sophisticated sweetness that nourishes.', href: '/lessons', img: '/raw-chocolate.jpg' },
    ],
    blogEye: 'Journal',
    blogH: 'Wisdom & practice\nof food and fermentation.',
    blogLink: 'View all articles →',
    posts: [
      { cat: 'Raw Food', title: '5 Basics of Enzyme-Preserving Cooking', date: '2026.05.20', href: '/blog' },
      { cat: 'Hacco LAB', title: 'How to Make Homemade Koji', date: '2026.05.10', href: '/blog' },
      { cat: 'Lifestyle', title: 'How Busy Executives Use Food to Thrive', date: '2026.04.28', href: '/blog' },
    ],
    ctaEye: 'First Step',
    ctaH: 'Turn your busy life into brilliance.',
    ctaBody: 'A fermentation × raw food lifestyle lab\nfor executives, professionals, and women who keep reinventing themselves.',
    ctaBtn: 'Book a Trial Lesson',
    ctaSub: 'Questions & inquiries →',
    footerTag: 'Raw Food × Fermentation\nLifestyle Lab · Tokyo Shibuya',
    footerMenuLabel: 'Menu',
    footerFollowLabel: 'Follow',
    copyright: '© 2026 &LAB TOKYO. All rights reserved.',
  },
}[lang] || {};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>&LAB TOKYO | 発酵×ローフード ライフスタイル・ラボ 東京渋谷</title>
  <meta name="description" content="東京・渋谷。経営者・専門職女性のための発酵×ローフード ライフスタイル・ラボ。ELLE gourmet認定料理家・安藤千英が、細胞から整える一生モノの食と美を伝えます。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400&family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Noto+Sans+JP:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:   #0c0a08;
      --ink2:  #181411;
      --ink3:  #221e1a;
      --gold:  #c8a96e;
      --gold2: #e8d5b0;
      --muted: #7a6f62;
      --cream: #f2ede4;
      --white: #fdfaf5;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--ink);
      color: var(--cream);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Lang ─── */
    .lang {
      position: fixed; top: 0; right: 0; z-index: 600;
      display: flex;
    }
    .lang a {
      padding: 10px 13px; font-size: .7rem; letter-spacing: 1px;
      text-decoration: none; color: var(--muted);
      background: var(--ink); transition: color .2s;
      border-left: 1px solid rgba(200,169,110,.1);
    }
    .lang a.on { color: var(--gold); }
    .lang a:hover { color: var(--gold2); }

    /* ─── Nav ─── */
    nav {
      position: fixed; inset: 0 0 auto 0; z-index: 500;
      height: 66px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3rem;
      background: rgba(12,10,8,.9);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(200,169,110,.1);
    }
    .nav-logo img { height: 36px; width: auto; }
    .nav-links { display: flex; align-items: center; gap: 2.2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: .8rem; letter-spacing: 1.5px;
      color: rgba(242,237,228,.5); transition: color .2s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-cta {
      padding: .5rem 1.4rem !important;
      border: 1px solid rgba(200,169,110,.45) !important;
      color: var(--gold) !important;
      border-radius: 1px;
    }
    .nav-cta:hover { background: var(--gold) !important; color: var(--ink) !important; }

    /* ─── Hero ─── */
    .hero {
      position: relative; height: 100vh; min-height: 600px;
      display: flex; align-items: flex-end; overflow: hidden;
    }
    .hero-bg { position: absolute; inset: 0; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; display: block; }
    .hero-bg::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(12,10,8,.9) 0%, rgba(12,10,8,.35) 50%, rgba(12,10,8,.1) 100%);
    }
    .hero-body { position: relative; z-index: 1; padding: 0 5vw 8vh; max-width: 800px; }
    .eyebrow {
      font-family: 'Cormorant Garamond', serif;
      font-size: .75rem; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.8rem;
    }
    h1 {
      font-family: 'Noto Serif JP', serif;
      font-weight: 200;
      font-size: clamp(2.6rem, 6vw, 4.8rem);
      line-height: 1.4; color: var(--white); letter-spacing: .5px;
    }
    h1 em { font-style: normal; color: var(--gold2); }
    .hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-style: italic;
      color: rgba(242,237,228,.6);
      margin: 1.2rem 0 2.8rem; letter-spacing: .5px;
    }
    .btns { display: flex; gap: 1.2rem; flex-wrap: wrap; }
    .btn-gold {
      display: inline-block; padding: .85rem 2.4rem;
      background: var(--gold); color: var(--ink);
      font-size: .8rem; letter-spacing: 2px; text-transform: uppercase;
      text-decoration: none; border-radius: 1px;
      transition: background .25s, transform .2s;
    }
    .btn-gold:hover { background: var(--gold2); transform: translateY(-2px); }
    .btn-ghost {
      display: inline-block; padding: .85rem 2.4rem;
      border: 1px solid rgba(242,237,228,.3); color: rgba(242,237,228,.65);
      font-size: .8rem; letter-spacing: 2px; text-transform: uppercase;
      text-decoration: none; border-radius: 1px;
      transition: border-color .25s, color .25s, transform .2s;
    }
    .btn-ghost:hover { border-color: var(--gold2); color: var(--gold2); transform: translateY(-2px); }

    /* ─── Mosaic ─── */
    .mosaic {
      display: grid;
      grid-template-columns: 1fr 1.5fr 1fr;
      grid-template-rows: 260px 260px;
      gap: 3px;
    }
    .mos { position: relative; overflow: hidden; background: var(--ink2); }
    .mos.tall { grid-row: span 2; }
    .mos img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; display: block; }
    .mos:hover img { transform: scale(1.04); }
    .mos::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(12,10,8,.45) 0%, transparent 55%); }
    .mos-tag {
      position: absolute; bottom: 1.4rem; left: 1.4rem; z-index: 1;
      font-family: 'Cormorant Garamond', serif;
      font-size: .68rem; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold);
    }

    /* ─── Section base ─── */
    .sec { padding: 8rem 5vw; }
    .sec-eye {
      font-family: 'Cormorant Garamond', serif;
      font-size: .7rem; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.4rem;
    }
    .sec-h2 {
      font-family: 'Noto Serif JP', serif; font-weight: 200;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      line-height: 1.55; color: var(--white); white-space: pre-line;
    }
    .rule { width: 36px; height: 1px; background: var(--gold); margin: 2rem 0 2.8rem; }

    /* ─── Concept ─── */
    .concept { background: var(--ink2); }
    .concept-grid {
      max-width: 1160px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }
    .concept-img { position: relative; border-radius: 2px; overflow: hidden; }
    .concept-img img { width: 100%; height: 500px; object-fit: cover; object-position: top; display: block; }
    .concept-img::before {
      content: ''; position: absolute; inset: -6px;
      border: 1px solid rgba(200,169,110,.18); border-radius: 2px;
      z-index: 1; pointer-events: none;
    }
    .concept-text p { font-size: .92rem; color: rgba(242,237,228,.65); white-space: pre-line; line-height: 2.1; }
    .concept-credit { margin-top: 2rem; font-family: 'Cormorant Garamond', serif; font-size: .82rem; letter-spacing: 2px; color: var(--gold); }
    .concept-link { display: inline-block; margin-top: 2rem; font-size: .8rem; color: var(--muted); text-decoration: none; letter-spacing: 1px; transition: color .2s; }
    .concept-link:hover { color: var(--gold); }

    /* ─── Programs ─── */
    .programs { background: var(--ink); }
    .programs-inner { max-width: 1160px; margin: 0 auto; }
    .prog-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 2px; margin-top: 4rem;
    }
    .prog {
      position: relative; overflow: hidden;
      height: 440px; cursor: pointer;
      text-decoration: none;
    }
    .prog img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; display: block; }
    .prog:hover img { transform: scale(1.06); }
    .prog-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(12,10,8,.85) 0%, rgba(12,10,8,.2) 100%);
      transition: background .3s;
    }
    .prog:hover .prog-overlay { background: linear-gradient(to top, rgba(12,10,8,.9) 0%, rgba(12,10,8,.35) 100%); }
    .prog-body {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 2.5rem 2rem;
    }
    .prog-eye {
      font-family: 'Cormorant Garamond', serif;
      font-size: .65rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--gold); margin-bottom: .8rem;
    }
    .prog h3 {
      font-family: 'Noto Serif JP', serif; font-weight: 300;
      font-size: 1.3rem; color: var(--white); margin-bottom: .8rem;
    }
    .prog p { font-size: .8rem; color: rgba(242,237,228,.55); line-height: 1.8; }
    .prog-arrow {
      position: absolute; top: 2rem; right: 2rem;
      width: 32px; height: 32px;
      border: 1px solid rgba(200,169,110,.3); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); font-size: .8rem;
      opacity: 0; transition: opacity .3s;
    }
    .prog:hover .prog-arrow { opacity: 1; }

    /* ─── Blog ─── */
    .blog-sec { background: var(--ink2); }
    .blog-inner { max-width: 1160px; margin: 0 auto; }
    .blog-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3.5rem; }
    .blog-link { font-size: .78rem; color: var(--muted); text-decoration: none; letter-spacing: 1px; transition: color .2s; }
    .blog-link:hover { color: var(--gold); }
    .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; }
    .post {
      background: var(--ink3); padding: 2.5rem 2rem;
      text-decoration: none; color: inherit;
      border-bottom: 2px solid transparent;
      transition: border-color .3s, background .3s;
      display: block;
    }
    .post:hover { border-bottom-color: var(--gold); background: var(--ink2); }
    .post-cat {
      font-size: .65rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1rem;
      font-family: 'Cormorant Garamond', serif;
    }
    .post h4 { font-family: 'Noto Serif JP', serif; font-weight: 300; font-size: 1rem; color: var(--white); line-height: 1.65; margin-bottom: 1.5rem; }
    .post-date { font-size: .72rem; color: var(--muted); letter-spacing: 1px; }

    /* ─── CTA ─── */
    .cta { background: var(--ink3); text-align: center; padding: 9rem 5vw; position: relative; overflow: hidden; }
    .cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(200,169,110,.05) 0%, transparent 70%); }
    .cta-inner { position: relative; max-width: 640px; margin: 0 auto; }
    .cta-body { font-size: .88rem; color: rgba(242,237,228,.5); white-space: pre-line; line-height: 2.1; margin: 2rem 0 3rem; }
    .cta-sub { display: block; margin-top: 1.6rem; font-size: .75rem; color: var(--muted); text-decoration: none; letter-spacing: 1px; transition: color .2s; }
    .cta-sub:hover { color: var(--gold); }

    /* ─── Footer ─── */
    footer {
      background: #080604; padding: 5rem 5vw 2.5rem;
      border-top: 1px solid rgba(200,169,110,.12);
    }
    .footer-grid {
      max-width: 1160px; margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 5rem; padding-bottom: 3.5rem;
      border-bottom: 1px solid rgba(242,237,228,.05);
    }
    .footer-logo img { height: 38px; margin-bottom: 1.4rem; }
    .footer-tag { font-size: .82rem; color: var(--muted); white-space: pre-line; line-height: 1.9; }
    .footer-col h5 {
      font-family: 'Cormorant Garamond', serif;
      font-size: .65rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.3rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .75rem; }
    .footer-col a { text-decoration: none; font-size: .83rem; color: rgba(242,237,228,.35); transition: color .2s; }
    .footer-col a:hover { color: var(--gold); }
    .footer-copy { max-width: 1160px; margin: 2.5rem auto 0; text-align: center; font-size: .7rem; color: rgba(242,237,228,.18); letter-spacing: 1px; }

    /* ─── Responsive ─── */
    @media (max-width: 960px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; }
      .hero-body { padding: 0 1.5rem 7vh; }
      .mosaic { grid-template-columns: 1fr 1fr; grid-template-rows: 200px 200px 200px; }
      .concept-grid { grid-template-columns: 1fr; gap: 3rem; }
      .concept-img img { height: 340px; }
      .prog-grid { grid-template-columns: 1fr; }
      .prog { height: 320px; }
      .blog-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .sec { padding: 5rem 1.5rem; }
      .blog-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>
<body>

  <!-- 言語 -->
  <div class="lang">
    <a href="?lang=ja" class={lang==='ja'?'on':''}>JP</a>
    <a href="?lang=en" class={lang==='en'?'on':''}>EN</a>
    <a href="?lang=zh" class={lang==='zh'?'on':''}>中</a>
  </div>

  <!-- ナビ -->
  <nav>
    <a href="/" class="nav-logo"><img src="/logo.png" alt="&LAB TOKYO" /></a>
    <ul class="nav-links">
      {t.navItems.map(item => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li><a href="/lessons" class="nav-cta">{t.navCta}</a></li>
    </ul>
  </nav>

  <!-- ヒーロー：全画面サラダ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/hero-food.jpg" alt="&LAB TOKYO ローフード" />
    </div>
    <div class="hero-body">
      <p class="eyebrow">{t.heroEye}</p>
      <h1>{t.h1a}<br /><em>{t.h1b}</em></h1>
      <p class="hero-sub">{t.heroSub}</p>
      <div class="btns">
        <a href="/lessons" class="btn-gold">{t.heroCta}</a>
        <a href="/lessons" class="btn-ghost">{t.heroCtaGhost}</a>
      </div>
    </div>
  </section>

  <!-- モザイクグリッド -->
  <div class="mosaic">
    <div class="mos">
      <img src="/green-smoothie.jpg" alt="グリーンスムージー" />
    </div>
    <div class="mos tall">
      <img src="/lesson-table.jpg" alt="レッスン" />
      <span class="mos-tag">Our World</span>
    </div>
    <div class="mos">
      <img src="/koji.jpg" alt="麹" />
    </div>
    <div class="mos">
      <img src="/raw-chocolate.jpg" alt="ローチョコレート" />
    </div>
  </div>

  <!-- コンセプト -->
  <section class="sec concept" id="about">
    <div class="concept-grid">
      <div class="concept-img">
        <img src="/chie-portrait.jpg" alt="安藤千英" />
      </div>
      <div>
        <p class="sec-eye">{t.conceptEye}</p>
        <h2 class="sec-h2">{t.conceptH}</h2>
        <div class="rule"></div>
        <p class="concept-text">{t.conceptBody}</p>
        <p class="concept-credit">{t.conceptCredit}</p>
        <a href="/about" class="concept-link">{t.conceptLink}</a>
      </div>
    </div>
  </section>

  <!-- プログラム -->
  <section class="sec programs">
    <div class="programs-inner">
      <p class="sec-eye">{t.progsEye}</p>
      <h2 class="sec-h2">{t.progsH}</h2>
      <div class="prog-grid">
        {t.progs.map(p => (
          <a href={p.href} class="prog">
            <img src={p.img} alt={p.h} />
            <div class="prog-overlay"></div>
            <span class="prog-arrow">→</span>
            <div class="prog-body">
              <p class="prog-eye">{p.eye}</p>
              <h3>{p.h}</h3>
              <p>{p.body}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ブログ -->
  <section class="sec blog-sec">
    <div class="blog-inner">
      <div class="blog-header">
        <div>
          <p class="sec-eye">{t.blogEye}</p>
          <h2 class="sec-h2">{t.blogH}</h2>
        </div>
        <a href="/blog" class="blog-link">{t.blogLink}</a>
      </div>
      <div class="blog-grid">
        {t.posts.map(post => (
          <a href={post.href} class="post">
            <p class="post-cat">{post.cat}</p>
            <h4>{post.title}</h4>
            <p class="post-date">{post.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="contact">
    <div class="cta-inner">
      <p class="sec-eye">{t.ctaEye}</p>
      <h2 class="sec-h2">{t.ctaH}</h2>
      <div class="rule" style="margin: 2rem auto;"></div>
      <p class="cta-body">{t.ctaBody}</p>
      <div class="btns" style="justify-content: center;">
        <a href="mailto:info@andlabtokyo.com" class="btn-gold">{t.ctaBtn}</a>
      </div>
      <a href="mailto:info@andlabtokyo.com" class="cta-sub">{t.ctaSub}</a>
    </div>
  </section>

  <!-- フッター -->
  <footer>
    <div class="footer-grid">
      <div>
        <div class="footer-logo"><img src="/logo.png" alt="&LAB TOKYO" /></div>
        <p class="footer-tag">{t.footerTag}</p>
      </div>
      <div class="footer-col">
        <h5>{t.footerMenuLabel}</h5>
        <ul>
          {t.navItems.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h5>{t.footerFollowLabel}</h5>
        <ul>
          <li><a href="#" target="_blank">Instagram</a></li>
          <li><a href="#" target="_blank">YouTube</a></li>
          <li><a href="#" target="_blank">TikTok</a></li>
          <li><a href="#" target="_blank">X / Twitter</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-copy">{t.copyright}</p>
  </footer>

</body>
</html>
