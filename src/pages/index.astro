---

<!DOCTYPE html>
<html lang={lang === 'ja' ? 'ja' : lang === 'zh' ? 'zh' : 'en'}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>&LAB TOKYO | ローフード＆発酵の料理教室・東京外苑前</title>
		<meta name="description" content="東京・外苑前のローフード＆発酵料理教室。少人数・丁寧なレッスンで、細胞から整えるリビングフードのある暮らしをご提案します。" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;700&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />
		<style>
			:root {
				--terracotta: #d4923f;
				--warm-pink: #d97d7d;
				--deep-navy: #0a0e27;
				--cream: #fef9f3;
				--warm-gray: #f5f0ea;
				--text-main: #2a2520;
				--text-light: #7a6f65;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }

			html { scroll-behavior: smooth; }

			body {
				font-family: 'Noto Sans JP', sans-serif;
				background-color: var(--cream);
				color: var(--text-main);
				line-height: 1.8;
			}

			/* ---- 言語スイッチャー ---- */
			.lang-switcher {
				position: fixed;
				top: 16px;
				right: 24px;
				z-index: 300;
				display: flex;
				gap: 8px;
			}
			.lang-switcher a {
				padding: 5px 12px;
				font-size: 0.78rem;
				font-weight: 500;
				text-decoration: none;
				border-radius: 20px;
				border: 1px solid var(--terracotta);
				transition: all 0.2s;
			}
			.lang-switcher a.active {
				background: var(--terracotta);
				color: var(--cream);
			}
			.lang-switcher a:not(.active) {
				color: var(--terracotta);
				background: transparent;
			}
			.lang-switcher a:hover:not(.active) {
				background: rgba(212,146,63,0.1);
			}

			/* ---- ナビゲーション ---- */
			nav {
				position: sticky;
				top: 0;
				z-index: 200;
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 1.4rem 3rem;
				background: rgba(254,249,243,0.95);
				backdrop-filter: blur(8px);
				border-bottom: 1px solid rgba(212,146,63,0.15);
			}
			.logo {
				font-family: 'Noto Serif JP', serif;
				font-size: 1.5rem;
				font-weight: 700;
				letter-spacing: 3px;
				color: var(--deep-navy);
				text-decoration: none;
			}
			.logo-amp { color: var(--terracotta); }
			nav ul {
				display: flex;
				list-style: none;
				gap: 2.5rem;
			}
			nav a {
				text-decoration: none;
				color: var(--text-main);
				font-size: 0.9rem;
				font-weight: 400;
				letter-spacing: 0.5px;
				transition: color 0.2s;
				position: relative;
			}
			nav a::after {
				content: '';
				position: absolute;
				left: 0; bottom: -3px;
				width: 0; height: 1px;
				background: var(--terracotta);
				transition: width 0.3s;
			}
			nav a:hover { color: var(--terracotta); }
			nav a:hover::after { width: 100%; }

			/* ---- ヒーロー ---- */
			.hero {
				position: relative;
				min-height: 92vh;
				display: flex;
				align-items: center;
				background: linear-gradient(160deg, var(--cream) 55%, rgba(212,146,63,0.08) 100%);
				padding: 5rem 3rem;
				overflow: hidden;
			}
			.hero-bg-circle {
				position: absolute;
				border-radius: 50%;
				pointer-events: none;
			}
			.hero-bg-circle.c1 {
				width: 500px; height: 500px;
				background: radial-gradient(circle, rgba(217,125,125,0.07) 0%, transparent 70%);
				top: -100px; right: -80px;
			}
			.hero-bg-circle.c2 {
				width: 350px; height: 350px;
				background: radial-gradient(circle, rgba(212,146,63,0.07) 0%, transparent 70%);
				bottom: 0; left: 5%;
			}
			.hero-inner {
				max-width: 720px;
				position: relative;
				z-index: 1;
			}
			.hero-eyebrow {
				font-size: 0.82rem;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: var(--terracotta);
				margin-bottom: 1.5rem;
				font-weight: 500;
			}
			.hero h1 {
				font-family: 'Noto Serif JP', serif;
				font-size: clamp(2rem, 5vw, 3.6rem);
				line-height: 1.4;
				font-weight: 300;
				color: var(--deep-navy);
				margin-bottom: 0.5rem;
			}
			.hero h1 .accent {
				color: var(--terracotta);
				font-weight: 700;
				display: block;
			}
			.hero-sub {
				font-family: 'Noto Serif JP', serif;
				font-size: 1rem;
				color: var(--text-light);
				margin: 1rem 0 1.8rem;
				font-style: italic;
			}
			.hero-desc {
				font-size: 1rem;
				color: var(--text-main);
				opacity: 0.8;
				margin-bottom: 2.5rem;
				white-space: pre-line;
				line-height: 2;
			}
			.cta-group {
				display: flex;
				gap: 1.2rem;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-block;
				padding: 0.9rem 2.2rem;
				font-size: 0.9rem;
				font-weight: 500;
				letter-spacing: 1px;
				text-decoration: none;
				border-radius: 2px;
				transition: all 0.3s;
				cursor: pointer;
			}
			.btn-primary {
				background: var(--terracotta);
				color: var(--cream);
				border: 2px solid var(--terracotta);
			}
			.btn-primary:hover {
				background: var(--warm-pink);
				border-color: var(--warm-pink);
				transform: translateY(-2px);
				box-shadow: 0 8px 20px rgba(217,125,125,0.25);
			}
			.btn-outline {
				background: transparent;
				color: var(--deep-navy);
				border: 2px solid var(--deep-navy);
			}
			.btn-outline:hover {
				background: var(--deep-navy);
				color: var(--cream);
				transform: translateY(-2px);
			}

			/* ---- セクション共通 ---- */
			section { padding: 6rem 3rem; }
			.section-label {
				font-size: 0.78rem;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: var(--terracotta);
				margin-bottom: 1rem;
				font-weight: 500;
			}
			.section-title {
				font-family: 'Noto Serif JP', serif;
				font-size: clamp(1.6rem, 3vw, 2.4rem);
				font-weight: 400;
				color: var(--deep-navy);
				margin-bottom: 2rem;
				line-height: 1.5;
			}
			.divider {
				width: 48px;
				height: 2px;
				background: var(--terracotta);
				margin: 1.5rem 0 2.5rem;
			}

			/* ---- コンセプト ---- */
			.concept {
				background: white;
			}
			.concept-inner {
				max-width: 1100px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 5rem;
				align-items: center;
			}
			.concept-image-placeholder {
				background: linear-gradient(135deg, rgba(212,146,63,0.12), rgba(217,125,125,0.12));
				border-radius: 4px;
				height: 420px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--text-light);
				font-size: 0.9rem;
				border: 1px dashed rgba(212,146,63,0.3);
				flex-direction: column;
				gap: 1rem;
			}
			.concept-text p {
				color: var(--text-main);
				opacity: 0.85;
				line-height: 2;
				font-size: 0.98rem;
			}

			/* ---- サービス ---- */
			.services {
				background: var(--warm-gray);
			}
			.services-inner { max-width: 1100px; margin: 0 auto; }
			.services-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
				margin-top: 3rem;
			}
			.service-card {
				background: white;
				padding: 2.5rem 2rem;
				border-radius: 4px;
				border-top: 3px solid var(--terracotta);
				transition: transform 0.3s, box-shadow 0.3s;
			}
			.service-card:hover {
				transform: translateY(-6px);
				box-shadow: 0 16px 40px rgba(10,14,39,0.08);
			}
			.service-icon { font-size: 2.2rem; margin-bottom: 1.2rem; }
			.service-card h3 {
				font-family: 'Noto Serif JP', serif;
				font-size: 1.15rem;
				color: var(--deep-navy);
				margin-bottom: 1rem;
			}
			.service-card p {
				font-size: 0.9rem;
				color: var(--text-light);
				line-height: 1.9;
			}

			/* ---- レッスン概要 ---- */
			.lessons { background: white; }
			.lessons-inner { max-width: 1100px; margin: 0 auto; }
			.lessons-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				margin-top: 3rem;
			}
			.lesson-item {
				display: flex;
				gap: 1.5rem;
				align-items: flex-start;
				padding: 1.8rem;
				background: var(--warm-gray);
				border-radius: 4px;
			}
			.lesson-num {
				font-family: 'Noto Serif JP', serif;
				font-size: 2rem;
				color: var(--terracotta);
				opacity: 0.5;
				line-height: 1;
				flex-shrink: 0;
				width: 2rem;
			}
			.lesson-item h4 {
				font-size: 1rem;
				font-weight: 500;
				color: var(--deep-navy);
				margin-bottom: 0.4rem;
			}
			.lesson-item p {
				font-size: 0.88rem;
				color: var(--text-light);
			}

			/* ---- メディア ---- */
			.media {
				background: var(--deep-navy);
				color: var(--cream);
				text-align: center;
			}
			.media .section-title { color: var(--cream); }
			.media .divider { margin: 1.5rem auto 2.5rem; }
			.media p { opacity: 0.8; max-width: 600px; margin: 0 auto 2rem; }
			.media-logos {
				display: flex;
				justify-content: center;
				gap: 3rem;
				flex-wrap: wrap;
				opacity: 0.5;
				font-size: 0.85rem;
				letter-spacing: 2px;
			}

			/* ---- お問い合わせ ---- */
			.contact {
				background: var(--warm-gray);
				text-align: center;
			}
			.contact-inner { max-width: 600px; margin: 0 auto; }
			.contact p {
				color: var(--text-light);
				white-space: pre-line;
				margin-bottom: 2.5rem;
				line-height: 2;
			}

			/* ---- フッター ---- */
			footer {
				background: var(--deep-navy);
				color: var(--cream);
				padding: 4rem 3rem 2rem;
				border-top: 3px solid var(--terracotta);
			}
			.footer-inner {
				max-width: 1100px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 2fr 1fr 1fr;
				gap: 4rem;
				padding-bottom: 3rem;
				border-bottom: 1px solid rgba(254,249,243,0.1);
			}
			.footer-logo {
				font-family: 'Noto Serif JP', serif;
				font-size: 1.4rem;
				letter-spacing: 3px;
				margin-bottom: 1rem;
			}
			.footer-logo .amp { color: var(--terracotta); }
			.footer-desc {
				font-size: 0.88rem;
				opacity: 0.65;
				white-space: pre-line;
				line-height: 1.9;
			}
			footer h4 {
				font-size: 0.78rem;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: var(--terracotta);
				margin-bottom: 1.2rem;
			}
			footer ul {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.7rem;
			}
			footer ul a {
				color: rgba(254,249,243,0.7);
				text-decoration: none;
				font-size: 0.88rem;
				transition: color 0.2s;
			}
			footer ul a:hover { color: var(--terracotta); }
			.footer-bottom {
				max-width: 1100px;
				margin: 2rem auto 0;
				text-align: center;
				font-size: 0.8rem;
				opacity: 0.4;
			}

			/* ---- レスポンシブ ---- */
			@media (max-width: 900px) {
				nav { padding: 1.2rem 1.5rem; }
				nav ul { gap: 1.5rem; }
				.hero { padding: 4rem 1.5rem; }
				.concept-inner { grid-template-columns: 1fr; gap: 3rem; }
				.services-grid { grid-template-columns: 1fr; }
				.lessons-grid { grid-template-columns: 1fr; }
				.footer-inner { grid-template-columns: 1fr; gap: 2.5rem; }
				section { padding: 4rem 1.5rem; }
			}
			@media (max-width: 600px) {
				nav ul { display: none; }
				.lang-switcher { top: 12px; right: 12px; }
			}
		</style>
	</head>
	<body>

		<!-- 言語スイッチャー -->
		<div class="lang-switcher">
			<a href="?lang=ja" class={lang === 'ja' ? 'active' : ''}>日本語</a>
			<a href="?lang=en" class={lang === 'en' ? 'active' : ''}>EN</a>
