---
const lang = Astro.url.searchParams.get('lang') || 'ja';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>安藤千英 | &LAB TOKYO — 発酵×ローフード 東京・渋谷</title>
  <meta name="description" content="ELLE gourmet認定料理家・安藤千英。東京・渋谷の発酵×ローフード ライフスタイルラボ。医師監修書籍、国内外の受講生実績。体験レッスン受付中。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Noto+Sans+JP:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:  #0c0a08;
      --ink2: #161210;
      --ink3: #201c18;
      --gold: #c8a96e;
      --gold2:#e8d5b0;
      --muted:#7a6f62;
      --cream:#f2ede4;
      --white:#fdfaf5;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Noto Sans JP',sans-serif;background:var(--ink);color:var(--cream);line-height:1.7;-webkit-font-smoothing:antialiased;}

    /* Lang */
    .lang{position:fixed;top:0;right:0;z-index:600;display:flex;}
    .lang a{padding:10px 13px;font-size:.7rem;letter-spacing:1px;text-decoration:none;color:var(--muted);background:var(--ink);border-left:1px solid rgba(200,169,110,.1);transition:color .2s;}
    .lang a.on{color:var(--gold);}
    .lang a:hover{color:var(--gold2);}

    /* Nav */
    nav{position:fixed;inset:0 0 auto 0;z-index:500;height:66px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;background:rgba(12,10,8,.92);backdrop-filter:blur(14px);border-bottom:1px solid rgba(200,169,110,.1);}
    .nav-logo img{height:36px;width:auto;}
    .nav-links{display:flex;align-items:center;gap:2rem;list-style:none;}
    .nav-links a{text-decoration:none;font-size:.8rem;letter-spacing:1.5px;color:rgba(242,237,228,.5);transition:color .2s;}
    .nav-links a:hover{color:var(--gold);}
    .nav-cta{padding:.5rem 1.4rem!important;border:1px solid rgba(200,169,110,.45)!important;color:var(--gold)!important;border-radius:1px;}
    .nav-cta:hover{background:var(--gold)!important;color:var(--ink)!important;}

    /* Hero — プロ写真メイン */
    .hero{position:relative;height:100vh;min-height:640px;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;}
    .hero-left{position:relative;display:flex;flex-direction:column;justify-content:center;padding:120px 5vw 80px 5vw;background:var(--ink2);z-index:1;}
    .hero-right{position:relative;overflow:hidden;}
    .hero-right img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;}
    .hero-right::after{content:'';position:absolute;inset:0;background:linear-gradient(to right,var(--ink2) 0%,transparent 30%);}
    .hero-tag{font-family:'Cormorant Garamond',serif;font-size:.72rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:2rem;}
    .hero h1{font-family:'Noto Serif JP',serif;font-weight:200;font-size:clamp(1.8rem,3.5vw,3rem);line-height:1.5;color:var(--white);margin-bottom:1rem;}
    .hero h1 em{font-style:normal;color:var(--gold2);display:block;font-size:1.2em;}
    .hero-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;letter-spacing:3px;color:var(--muted);margin-bottom:.5rem;}
    .hero-title{font-size:.82rem;color:rgba(242,237,228,.4);letter-spacing:2px;margin-bottom:2.5rem;}
    .hero-desc{font-size:.88rem;color:rgba(242,237,228,.6);line-height:2;margin-bottom:3rem;max-width:420px;}
    .btns{display:flex;gap:1rem;flex-wrap:wrap;}
    .btn-gold{display:inline-block;padding:.85rem 2rem;background:var(--gold);color:var(--ink);font-size:.8rem;letter-spacing:2px;text-transform:uppercase;text-decoration:none;border-radius:1px;transition:background .25s,transform .2s;font-weight:500;}
    .btn-gold:hover{background:var(--gold2);transform:translateY(-2px);}
    .btn-ghost{display:inline-block;padding:.85rem 2rem;border:1px solid rgba(242,237,228,.25);color:rgba(242,237,228,.6);font-size:.8rem;letter-spacing:2px;text-transform:uppercase;text-decoration:none;border-radius:1px;transition:all .25s;}
    .btn-ghost:hover{border-color:var(--gold);color:var(--gold);}

    /* Credentials strip */
    .cred-strip{background:var(--ink3);padding:1.8rem 5vw;border-top:1px solid rgba(200,169,110,.1);border-bottom:1px solid rgba(200,169,110,.1);}
    .cred-inner{max-width:1160px;margin:0 auto;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;justify-content:center;}
    .cred-item{display:flex;align-items:center;gap:.8rem;font-size:.75rem;color:var(--muted);letter-spacing:1px;white-space:nowrap;}
    .cred-item span.dot{width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0;}

    /* Section base */
    .sec{padding:8rem 5vw;}
    .sec-eye{font-family:'Cormorant Garamond',serif;font-size:.72rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:1.4rem;}
    .sec-h2{font-family:'Noto Serif JP',serif;font-weight:200;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.55;color:var(--white);}
    .rule{width:36px;height:1px;background:var(--gold);margin:2rem 0 2.8rem;}
    .inner{max-width:1160px;margin:0 auto;}

    /* Story */
    .story{background:var(--ink2);}
    .story-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;}
    .story-img{position:relative;overflow:hidden;border-radius:2px;}
    .story-img img{width:100%;height:500px;object-fit:cover;object-position:center top;display:block;}
    .story-img::before{content:'';position:absolute;inset:-8px;border:1px solid rgba(200,169,110,.2);border-radius:2px;z-index:1;pointer-events:none;}
    .story-body p{font-size:.92rem;color:rgba(242,237,228,.65);line-height:2.2;margin-bottom:1.5rem;}
    .story-body p strong{color:var(--gold2);font-weight:400;}
    .story-link{display:inline-block;margin-top:1rem;font-size:.78rem;color:var(--muted);text-decoration:none;letter-spacing:1px;border-bottom:1px solid rgba(122,111,98,.3);padding-bottom:2px;transition:color .2s,border-color .2s;}
    .story-link:hover{color:var(--gold);border-color:var(--gold);}

    /* For whom */
    .forwhom{background:var(--ink);}
    .forwhom-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:4rem;}
    .whom-list{list-style:none;display:flex;flex-direction:column;gap:1.2rem;}
    .whom-list li{display:flex;align-items:flex-start;gap:1rem;font-size:.9rem;color:rgba(242,237,228,.7);line-height:1.8;}
    .whom-list li::before{content:'—';color:var(--gold);flex-shrink:0;margin-top:.1rem;}
    .forwhom-right{background:var(--ink2);padding:3rem;border:1px solid rgba(200,169,110,.12);}
    .forwhom-right .label{font-family:'Cormorant Garamond',serif;font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;}
    .forwhom-right p{font-size:.88rem;color:rgba(242,237,228,.55);line-height:2;}

    /* Cross Theory */
    .theory{background:var(--ink3);text-align:center;padding:8rem 5vw;}
    .theory-formula{display:flex;align-items:center;justify-content:center;gap:2rem;margin:4rem 0;flex-wrap:wrap;}
    .theory-block{padding:2.5rem 3rem;border:1px solid rgba(200,169,110,.2);}
    .theory-block .label{font-family:'Cormorant Garamond',serif;font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;}
    .theory-block h3{font-family:'Noto Serif JP',serif;font-weight:200;font-size:1.6rem;color:var(--white);}
    .theory-op{font-family:'Cormorant Garamond',serif;font-size:3rem;color:rgba(200,169,110,.4);}
    .theory-result{margin-top:1rem;padding:2rem 4rem;background:rgba(200,169,110,.08);border:1px solid rgba(200,169,110,.3);}
    .theory-result h3{font-family:'Noto Serif JP',serif;font-weight:300;font-size:1.3rem;color:var(--gold2);}
    .theory-body{max-width:640px;margin:2rem auto 0;font-size:.88rem;color:rgba(242,237,228,.5);line-height:2;}

    /* Programs */
    .programs{background:var(--ink2);}
    .prog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:4rem;}
    .prog{position:relative;overflow:hidden;height:480px;text-decoration:none;display:block;}
    .prog img{width:100%;height:100%;object-fit:cover;transition:transform .7s ease;display:block;}
    .prog:hover img{transform:scale(1.05);}
    .prog-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,10,8,.9) 0%,rgba(12,10,8,.2) 100%);transition:background .3s;}
    .prog:hover .prog-ov{background:linear-gradient(to top,rgba(12,10,8,.95) 0%,rgba(12,10,8,.4) 100%);}
    .prog-body{position:absolute;bottom:0;left:0;right:0;padding:2.5rem 2rem;}
    .prog-eye{font-family:'Cormorant Garamond',serif;font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:.8rem;}
    .prog h3{font-family:'Noto Serif JP',serif;font-weight:300;font-size:1.2rem;color:var(--white);margin-bottom:.8rem;}
    .prog-detail{font-size:.78rem;color:rgba(242,237,228,.5);line-height:1.9;margin-bottom:1rem;}
    .prog-meta{font-size:.72rem;color:var(--gold);letter-spacing:1px;}

    /* Book + Credentials */
    .credentials{background:var(--ink);}
    .cred-grid{display:grid;grid-template-columns:280px 1fr;gap:6rem;align-items:center;}
    .book-cover{position:relative;}
    .book-cover img{width:100%;border-radius:4px;box-shadow:0 20px 60px rgba(0,0,0,.5);}
    .cred-list{display:flex;flex-direction:column;gap:2rem;}
    .cred-item-lg{display:flex;gap:1.5rem;align-items:flex-start;padding-bottom:2rem;border-bottom:1px solid rgba(200,169,110,.08);}
    .cred-item-lg:last-child{border-bottom:none;padding-bottom:0;}
    .cred-icon{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:rgba(200,169,110,.3);font-style:italic;flex-shrink:0;width:2rem;}
    .cred-text h4{font-size:.9rem;color:var(--gold2);margin-bottom:.4rem;font-weight:400;}
    .cred-text p{font-size:.82rem;color:var(--muted);line-height:1.8;}

    /* Testimonials */
    .testimonials{background:var(--ink2);}
    .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:4rem;}
    .testi{background:var(--ink3);padding:2.5rem 2rem;}
    .testi-img{width:60px;height:60px;border-radius:50%;object-fit:cover;object-position:top;margin-bottom:1.5rem;border:1px solid rgba(200,169,110,.2);}
    .testi-quote{font-family:'Noto Serif JP',serif;font-weight:300;font-size:.95rem;color:rgba(242,237,228,.8);line-height:1.9;margin-bottom:1.5rem;font-style:italic;}
    .testi-name{font-size:.75rem;color:var(--gold);letter-spacing:2px;}
    .testi-role{font-size:.72rem;color:var(--muted);margin-top:.3rem;}

    /* Blog */
    .blog-sec{background:var(--ink);}
    .blog-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3.5rem;}
    .blog-link{font-size:.78rem;color:var(--muted);text-decoration:none;letter-spacing:1px;transition:color .2s;}
    .blog-link:hover{color:var(--gold);}
    .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;}
    .post{background:var(--ink2);padding:2.5rem 2rem;text-decoration:none;color:inherit;border-bottom:2px solid transparent;transition:border-color .3s,background .3s;display:block;}
    .post:hover{border-bottom-color:var(--gold);background:var(--ink3);}
    .post-cat{font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;font-family:'Cormorant Garamond',serif;}
    .post h4{font-family:'Noto Serif JP',serif;font-weight:300;font-size:.98rem;color:var(--white);line-height:1.7;margin-bottom:1.5rem;}
    .post-date{font-size:.72rem;color:var(--muted);letter-spacing:1px;}

    /* CTA */
    .cta-sec{background:var(--ink3);text-align:center;padding:9rem 5vw;position:relative;overflow:hidden;}
    .cta-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(200,169,110,.06) 0%,transparent 70%);}
    .cta-inner{position:relative;max-width:660px;margin:0 auto;}
    .cta-body{font-size:.88rem;color:rgba(242,237,228,.5);line-height:2.2;margin:2rem 0 3rem;white-space:pre-line;}
    .cta-btns{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;}
    .cta-note{margin-top:1.5rem;font-size:.75rem;color:var(--muted);}

    /* Footer */
    footer{background:#060504;padding:5rem 5vw 2.5rem;border-top:1px solid rgba(200,169,110,.12);}
    .footer-grid{max-width:1160px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:5rem;padding-bottom:3.5rem;border-bottom:1px solid rgba(242,237,228,.05);}
    .footer-logo img{height:38px;margin-bottom:1.4rem;}
    .footer-tag{font-size:.82rem;color:var(--muted);line-height:1.9;}
    .footer-col h5{font-family:'Cormorant Garamond',serif;font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:1.3rem;}
    .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.75rem;}
    .footer-col a{text-decoration:none;font-size:.83rem;color:rgba(242,237,228,.35);transition:color .2s;}
    .footer-col a:hover{color:var(--gold);}
    .footer-copy{max-width:1160px;margin:2.5rem auto 0;text-align:center;font-size:.7rem;color:rgba(242,237,228,.18);letter-spacing:1px;}

    /* Responsive */
    @media(max-width:960px){
      nav{padding:0 1.5rem;}
      .nav-links{display:none;}
      .hero{grid-template-columns:1fr;height:auto;}
      .hero-left{padding:100px 1.5rem 3rem;}
      .hero-right{height:50vh;}
      .hero-right::after{background:linear-gradient(to bottom,var(--ink2) 0%,transparent 30%);}
      .story-grid,.cred-grid,.forwhom-grid{grid-template-columns:1fr;gap:3rem;}
      .story-img img{height:340px;}
      .prog-grid{grid-template-columns:1fr;}
      .prog{height:320px;}
      .testi-grid{grid-template-columns:1fr;}
      .blog-grid{grid-template-columns:1fr;}
      .footer-grid{grid-template-columns:1fr;gap:2.5rem;}
      .sec{padding:5rem 1.5rem;}
      .blog-header{flex-direction:column;align-items:flex-start;gap:1rem;}
      .theory-formula{gap:1rem;}
      .theory-block{padding:1.5rem 2rem;}
    }
  </style>
</head>
<body>

  <!-- 言語 -->
  <div class="lang">
    <a href="?lang=ja" class={lang==='ja'?'on':''}>JP</a>
    <a href="?lang=en" class={lang==='en'?'on':''}>EN</a>
    <a href="?lang=zh" class={lang==='zh'?'on':''}>中</a>
  </div>

  <!-- ナビ -->
  <nav>
    <a href="/" class="nav-logo"><img src="/logo.png" alt="&LAB TOKYO" /></a>
    <ul class="nav-links">
      <li><a href="/lessons">レッスン</a></li>
      <li><a href="/hacco">Hacco LAB</a></li>
      <li><a href="/about">安藤千英</a></li>
      <li><a href="/blog">ブログ</a></li>
      <li><a href="mailto:info@andlabtokyo.com" class="nav-cta">体験レッスン</a></li>
    </ul>
  </nav>

  <!-- ① HERO — 「発酵創家 安藤千英」を主役に -->
  <section class="hero">
    <div class="hero-left">
      <p class="hero-tag">Fermentation Creator · Tokyo Shibuya</p>
      <p class="hero-name">安藤 千英　Chie Ando</p>
      <p class="hero-title">ELLE gourmet認定料理家　/ 発酵×ローフード研究家</p>
      <h1>
        これからの私を、
        <em>美しく「醸す」。</em>
      </h1>
      <p class="hero-desc">
        細胞からデザインする、一生モノの心と体。<br />
        経営者・専門職・自分を更新し続けたいすべての女性へ。<br />
        発酵×ローフードのクロス理論で、あなたの本来の輝きを取り戻す。
      </p>
      <div class="btns">
        <a href="mailto:info@andlabtokyo.com" class="btn-gold">体験レッスンを予約する</a>
        <a href="/about" class="btn-ghost">安藤千英について</a>
      </div>
    </div>
    <div class="hero-right">
      <img src="/chie-main.jpg" alt="発酵創家 安藤千英" />
    </div>
  </section>

  <!-- Credentials strip -->
  <div class="cred-strip">
    <div class="cred-inner">
      <div class="cred-item"><span class="dot"></span>ELLE gourmet認定クリエイター</div>
      <div class="cred-item"><span class="dot"></span>医師監修書籍「&RAW LIVING」著者</div>
      <div class="cred-item"><span class="dot"></span>循環器内科医・内科医が受講</div>
      <div class="cred-item"><span class="dot"></span>国際受講生：米・墨・香港ほか</div>
      <div class="cred-item"><span class="dot"></span>東京・渋谷 / オンライン対応</div>
    </div>
  </div>

  <!-- モザイクグリッド -->
  <div style="display:grid;grid-template-columns:1fr 1.5fr 1fr;grid-template-rows:260px 260px;gap:3px;background:var(--ink);">
    <div style="overflow:hidden;"><img src="/mosaic-drinks.jpg" alt="ローフードジュース" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" /></div>
    <div style="overflow:hidden;grid-row:span 2;position:relative;">
      <img src="/prog-rawfood.jpg" alt="手毬寿司ローフード" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(12,10,8,.5) 0%,transparent 60%);"></div>
      <span style="position:absolute;bottom:1.4rem;left:1.4rem;font-family:'Cormorant Garamond',serif;font-size:.68rem;letter-spacing:4px;text-transform:uppercase;color:#c8a96e;">Our World</span>
    </div>
    <div style="overflow:hidden;"><img src="/koji.jpg" alt="麹 発酵" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
    <div style="overflow:hidden;"><img src="/prog-chocolate.jpg" alt="ローチョコレート" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" /></div>
  </div>

  <!-- ② STORY — WHY -->
  <section class="sec story">
    <div class="inner">
      <div class="story-grid">
        <div class="story-img">
          <img src="/chie-speaking.jpg" alt="安藤千英 講演" />
        </div>
        <div class="story-body">
          <p class="sec-eye">My Story</p>
          <h2 class="sec-h2">なぜ、私は食を伝えるのか。</h2>
          <div class="rule"></div>
          <p>
            10年前の4月。娘が台所の熱湯を頭からかぶる大火傷を負いました。
            長期入院、複数回の手術。私は<strong>キッチンに立てなくなった。</strong>
          </p>
          <p>
            そこから食を学び直しました。マクロビ、ローフード、発酵。
            食べることが娘を、そして私自身を、内側から再生させていった。
          </p>
          <p>
            40代になったとき、更年期という新しい岐路に立ちました。
            そのとき改めて気づいたのです——<strong>「細胞から整える食」は、一生モノの武器だ</strong>、と。
          </p>
          <p>
            忙しい女性が、食から自分を取り戻せる場所をつくりたい。
            それが&LAB TOKYOの原点です。
          </p>
          <a href="https://note.com/chieando/n/naa6e962de57b" target="_blank" class="story-link">
            全文をnoteで読む →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ FOR WHOM — ターゲット明確化 -->
  <section class="sec forwhom">
    <div class="inner">
      <p class="sec-eye">For Whom</p>
      <h2 class="sec-h2">こんな女性のための場所です。</h2>
      <div class="forwhom-grid">
        <ul class="whom-list">
          <li>毎日忙しく、自分の体を後回しにしてきた経営者・専門職</li>
          <li>更年期や体調の変化を感じ、食から根本的に変えたい</li>
          <li>「料理が苦手」「難しそう」と思っていたけれど興味はある</li>
          <li>海外からでも学べる、グローバルなコンテンツを求めている</li>
          <li>ダイエットや美容だけでなく、一生使える知識がほしい</li>
          <li>認定資格を取得して、自分のビジネスや活動に活かしたい</li>
        </ul>
        <div class="forwhom-right">
          <p class="label">Lesson Style</p>
          <p>
            少人数制（1〜4名）で丁寧に。<br />
            初心者・お子様も歓迎。<br /><br />
