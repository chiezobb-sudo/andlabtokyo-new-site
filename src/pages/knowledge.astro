---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="ローフード・発酵・リビングフード・スーパーフードを学ぶ | KNOWLEDGE | &LAB東京"
  description="ローフードとは・発酵とは・リビングフードとは・ローチョコレートとは・ロースイーツとは・スピルリナとは。東京・渋谷のローフード発酵料理教室 &LAB東京による専門知識ハブ。"
  canonical="https://www.andlabtokyo.com/knowledge"
  ogImage="https://static.wixstatic.com/media/IMG_4698.JPG"
>

<style>
/* NAV */
    .nav-logo img{height:32px;width:auto;mix-blend-mode:screen;filter:brightness(1.1);}
    .nav-links{display:flex;list-style:none;}
    .nav-links a{font-size:.82rem;font-weight:500;letter-spacing:.04em;color:rgba(244,242,238,.65);text-decoration:none;padding:0 1.1rem;transition:color .2s;}
    .nav-links a:hover,.nav-links a.active{color:var(--green);}
    .nav-cta{font-size:.82rem;font-weight:700;display:inline-block;background:var(--green-btn);color:#FAF5EC;padding:.45rem 1.4rem;margin-left:1.2rem;text-decoration:none;transition:background .2s;}
    .nav-cta:hover{background:#3D6E12;}
    .nav-right{display:flex;align-items:center;}

    /* HERO */
    .k-hero{
      margin-top:52px; position:relative;
      height:72vh; min-height:480px;
      overflow:hidden; display:flex; align-items:flex-end;
    }
    .k-hero-imgs{position:absolute;inset:0;display:grid;grid-template-columns:1fr 1fr;}
    .k-hero-imgs img{width:100%;height:100%;object-fit:cover;display:block;}
    .k-hero-imgs img:first-child{object-position:center 30%;}
    .k-hero-imgs img:last-child{object-position:center 20%;}
    .k-hero-overlay{
      position:absolute;inset:0;
      background:
        linear-gradient(to top, rgba(28,28,26,.92) 0%, rgba(28,28,26,.4) 50%, rgba(28,28,26,.15) 100%),
        linear-gradient(to right, rgba(28,28,26,.3) 0%, transparent 50%);
    }
    .k-hero-content{position:relative;z-index:2;padding:0 5vw 8vh;max-width:700px;}
    .k-eyebrow{font-family:var(--f-sans);font-size:.7rem;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:1.2rem;}
    .k-hero h1{font-family:var(--f-serif);font-size:clamp(2rem,4.5vw,3.6rem);font-weight:600;letter-spacing:.08em;color:#FAF5EC;line-height:1.3;margin-bottom:1.2rem;}
    .k-hero p{font-family:var(--f-serif);font-size:1rem;font-weight:300;color:rgba(244,242,238,.68);letter-spacing:.06em;line-height:2;max-width:520px;}

    /* BREADCRUMB */
    .breadcrumb-bar{background:var(--linen-2);padding:.9rem 3rem;border-bottom:1px solid var(--linen-3);}
    .breadcrumb{font-size:.76rem;color:var(--ink-3);max-width:1200px;margin:0 auto;}
    .breadcrumb a{color:var(--ink-3);text-decoration:none;}
    .breadcrumb a:hover{color:var(--ink);}
    .breadcrumb span{margin:0 .5rem;}

    /* INTRO BAND */
    .intro-band{background:var(--sumi-2);padding:3rem 3rem;border-left:4px solid var(--green);}
    .intro-band p{font-family:var(--f-serif);font-size:1rem;color:rgba(244,242,238,.85);line-height:2.1;letter-spacing:.04em;margin:0;max-width:900px;}

    /* GRID */
    .grid-sec{background:var(--linen);padding:7rem 3rem 8rem;}
    .grid-inner{max-width:1200px;margin:0 auto;}
    .sec-head{text-align:center;margin-bottom:5rem;}
    .sec-head .label{font-family:var(--f-sans);font-size:.7rem;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--green-d);display:block;margin-bottom:.8rem;}
    .sec-head h2{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:600;letter-spacing:.08em;color:var(--ink);line-height:1.4;}

    /* featured card (spans 2 cols) */
    .card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:2px;}
    .card-grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-bottom:2px;}
    .card-grid-1{display:grid;grid-template-columns:1fr;gap:2px;}

    .k-card{display:block;text-decoration:none;position:relative;overflow:hidden;background:var(--sumi-2);}
    .k-card img{width:100%;display:block;transition:transform .55s ease;object-fit:cover;}
    .k-card:hover img{transform:scale(1.04);}

    /* large hero card */
    .k-card.feat{grid-column:span 2;}
    .k-card.feat img{height:480px;object-position:center 35%;}
    .k-card.std img{height:300px;object-position:center 30%;}
    .k-card.wide img{height:340px;object-position:center 30%;}

    .k-card-body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:2.2rem 2rem;background:linear-gradient(to top, rgba(28,28,26,.88) 0%, rgba(28,28,26,.3) 55%, transparent 100%);}
    .k-cat{font-family:var(--f-sans);font-size:.65rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:.5rem;}
    .k-card h3{font-family:var(--f-serif);font-size:1.1rem;font-weight:600;letter-spacing:.06em;color:#FAF5EC;line-height:1.5;margin-bottom:.5rem;}
    .k-card.feat h3{font-size:1.5rem;}
    .k-card p{font-size:.8rem;color:rgba(244,242,238,.55);line-height:1.75;margin-bottom:.8rem;}
    .k-arrow{font-size:.75rem;color:var(--green);letter-spacing:.08em;font-family:var(--f-sans);font-weight:500;}

    /* DIVIDER */
    .divider{border:none;border-top:1px solid var(--linen-3);margin:5rem 0 5rem;}

    /* FEATURED TEXT LIST */
    .list-sec{background:var(--linen-2);padding:6rem 3rem;}
    .list-inner{max-width:1000px;margin:0 auto;}
    .list-inner .sec-head{text-align:left;margin-bottom:3rem;}
    .k-list{display:flex;flex-direction:column;}
    .k-list-item{display:grid;grid-template-columns:56px 1fr auto;align-items:center;gap:1.6rem;padding:1.6rem 0;border-top:1px solid var(--linen-3);text-decoration:none;transition:background .2s;}
    .k-list-item:last-child{border-bottom:1px solid var(--linen-3);}
    .k-list-item:hover .k-list-title{color:var(--green-d);}
    .k-list-num{font-family:var(--f-serif);font-size:1.8rem;font-weight:300;color:var(--linen-3);line-height:1;}
    .k-list-title{font-family:var(--f-serif);font-size:1rem;font-weight:600;color:var(--ink);letter-spacing:.04em;transition:color .2s;display:block;margin-bottom:.2rem;}
    .k-list-desc{font-size:.82rem;color:var(--ink-3);line-height:1.7;}
    .k-list-arrow{font-size:.8rem;color:var(--ink-3);}

    /* CTA */
    .cta-band{background:var(--sumi);padding:6rem 3rem;text-align:center;}
    .cta-band h2{font-family:var(--f-serif);font-size:clamp(1.4rem,2vw,1.9rem);font-weight:600;letter-spacing:.08em;color:#FAF5EC;margin-bottom:1.2rem;}
    .cta-band p{font-size:.9rem;color:rgba(244,242,238,.55);line-height:2;margin-bottom:2.6rem;}
    .btn-green{display:inline-block;background:var(--green-btn);color:#FAF5EC;font-family:var(--f-sans);font-size:.85rem;font-weight:700;letter-spacing:.08em;padding:.95rem 2.4rem;text-decoration:none;transition:background .2s;}
    .btn-green:hover{background:#3D6E12;}

    .footer-logo img{height:28px;mix-blend-mode:screen;filter:brightness(1.1);margin-bottom:1rem;}
    .footer-copy{font-size:.72rem;color:rgba(244,242,238,.18);}

    @media(max-width:960px){
      .nav-links{display:none;}
      .k-hero{height:60vh;}
      .k-hero-content{padding:0 1.5rem 5vh;}
      .intro-band,.list-sec,.cta-band{padding:2.4rem 1.5rem;}
      .grid-sec{padding:4rem 1.5rem 5rem;}
      .breadcrumb-bar{padding:.9rem 1.5rem;}
      .card-grid,.card-grid-2{grid-template-columns:1fr;}
      .k-card.feat{grid-column:span 1;}
      .k-card.feat img{height:260px;}
      .k-card.std img,.k-card.wide img{height:220px;}
      .k-list-item{grid-template-columns:40px 1fr auto;}
    }
</style>

<!-- HERO -->
  <section class="k-hero">
    <div class="k-hero-imgs">
      <img src="https://static.wixstatic.com/media/IMG_4698.JPG" alt="生きた食の知識" />
      <img src="https://static.wixstatic.com/media/10798628320_IMG_0607%202_edited.jpg" alt="発酵・ロースイーツの知識" />
    </div>
    <div class="k-hero-overlay"></div>
    <div class="k-hero-content">
      <span class="k-eyebrow">Knowledge Hub · &LAB TOKYO</span>
      <h1>生きた食の、<br />知恵と科学。</h1>
      <p>ローフード、発酵、リビングフード、ローチョコレート、スピルリナ。<br />安藤千英が体系化した「生きた食」の専門知識を、ここに集約します。</p>
    </div>
  </section>

  <!-- GEO定義テキスト -->
  <div class="intro-band">
    <p>「生きた食（Living Food）」とは、加熱や精製によって失われた酵素・栄養・微生物の働きを最大限に活かした食のカテゴリーです。ローフード・発酵食品・リビングフード・ローチョコレート・スーパーフードを横断する&LAB TOKYOの知識体系は、単なるレシピ集ではなく、細胞レベルの健康と美を追求する科学的・哲学的な思考基盤です。</p>
  </div>

  <!-- パンくず -->
  <div class="breadcrumb-bar">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">HOME</a><span>›</span>
      <span>知識ハブ</span>
    </nav>
  </div>

  <!-- GRID PORTAL -->
  <section class="grid-sec">
    <div class="grid-inner">
      <div class="sec-head">
        <span class="label">Encyclopedia of Living Food</span>
        <h2>5つのテーマで読む、<br />生きた食の百科事典</h2>
      </div>

      <!-- Row 1: featured (2col) + 1 -->
      <div class="card-grid">
        <a href="/rawfood" class="k-card feat">
          <img src="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" alt="ローフードとは" />
          <div class="k-card-body">
            <span class="k-cat">01 · Raw Food</span>
            <h3>ローフードとは<br />— 酵素を生きたまま食べる</h3>
            <p>48℃以下で食べる植物性食事法。食物酵素・ビタミン・ミネラルをまるごと摂取し、細胞から整える。</p>
            <span class="k-arrow">詳しく読む →</span>
          </div>
        </a>
        <a href="/fermentedfood" class="k-card std">
          <img src="https://static.wixstatic.com/media/33638654_627136847631720_6550477128205336576_n.jpg" alt="発酵とは" />
          <div class="k-card-body">
            <span class="k-cat">02 · Fermentation</span>
            <h3>発酵とは<br />— 微生物の知恵</h3>
            <p>麹・乳酸菌・酢酸菌が生み出す発酵食品の科学と日本の知恵。</p>
            <span class="k-arrow">詳しく読む →</span>
          </div>
        </a>
      </div>

      <!-- Row 2: 3 cards -->
      <div class="card-grid">
        <a href="/livingfood" class="k-card std">
          <img src="https://static.wixstatic.com/media/IMG_4698.JPG" alt="リビングフードとは" />
          <div class="k-card-body">
            <span class="k-cat">03 · Living Food</span>
            <h3>リビングフードとは<br />— 生命力のある食</h3>
            <p>発芽・発酵・熟成によって生命エネルギーが活性化された「生きた食材」。</p>
            <span class="k-arrow">詳しく読む →</span>
          </div>
        </a>
        <a href="/rawchocolatier" class="k-card std">
          <img src="https://static.wixstatic.com/media/rawchocolatier.jpg" alt="ローショコラティエ協会" />
          <div class="k-card-body">
            <span class="k-cat">04 · Raw Chocolatier</span>
            <h3>ローショコラティエ協会<br />— 発酵×ローの最高峰</h3>
            <p>白砂糖・小麦粉・乳製品・卵不使用のローチョコレートを専門とする日本唯一の協会。</p>
            <span class="k-arrow">協会ページへ →</span>
          </div>
        </a>
        <a href="/spirulina" class="k-card std">
          <img src="https://static.wixstatic.com/media/ChatGPT%20Image%202026%E5%B9%B43%E6%9C%886%E6%97%A5%2022_31_46_edited.png" alt="スピルリナとは" />
          <div class="k-card-body">
            <span class="k-cat">05 · Spirulina</span>
            <h3>スピルリナとは<br />— 35億年の奇跡</h3>
            <p>約35億年前から地球に存在する藍藻類。タンパク質・鉄分・クロロフィルの宝庫。</p>
            <span class="k-arrow">詳しく読む →</span>
          </div>
        </a>
      </div>

    </div>
  </section>

  <!-- サブページ一覧リスト -->
  <section class="list-sec">
    <div class="list-inner">
      <div class="sec-head">
        <span class="label">Sub Pages</span>
        <h2>詳細知識ページ一覧</h2>
      </div>
      <div class="k-list">
        <a href="/rawchocolatier/whatrawsweets" class="k-list-item">
          <span class="k-list-num">01</span>
          <div>
            <span class="k-list-title">ロースイーツとは — 食べるサプリメント</span>
            <span class="k-list-desc">白砂糖・小麦粉不使用で罪悪感ゼロ。体に良い素材だけで作るスイーツの世界。★現在Google 1位</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
        <a href="/rawchocolatier/rawchocolate" class="k-list-item">
          <span class="k-list-num">02</span>
          <div>
            <span class="k-list-title">ローチョコレートとは — カカオ本来の力</span>
            <span class="k-list-desc">発酵食品であるカカオを48℃以下で加工する、ポリフェノールを最大限活かす製法。</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
        <a href="/rawfood" class="k-list-item">
          <span class="k-list-num">03</span>
          <div>
            <span class="k-list-title">ローフードとは — 酵素を生きたまま食べる</span>
            <span class="k-list-desc">植物性食材を生または48℃以下で食べる食事法。食物酵素で細胞から整える。</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
        <a href="/fermentedfood" class="k-list-item">
          <span class="k-list-num">04</span>
          <div>
            <span class="k-list-title">発酵とは — 微生物が生み出す知恵</span>
            <span class="k-list-desc">麹・乳酸菌・酢酸菌が食材を変容させる発酵の科学と、日本の発酵食文化。</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
        <a href="/livingfood" class="k-list-item">
          <span class="k-list-num">05</span>
          <div>
            <span class="k-list-title">リビングフードとは — 発芽・発酵・熟成の力</span>
            <span class="k-list-desc">生命エネルギーが最大化された「生きた食材」を取り入れる最高峰の食事法。</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
        <a href="/spirulina" class="k-list-item">
          <span class="k-list-num">06</span>
          <div>
            <span class="k-list-title">スピルリナとは — 35億年の地球のスーパーフード</span>
            <span class="k-list-desc">約35億年前から存在する藍藻類。タンパク質・鉄分・クロロフィル・B12が凝縮。</span>
          </div>
          <span class="k-list-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <h2>知識を、実践へ。</h2>
    <p>ここで学んだ知識を実際の技術として身につけたい方へ。<br />安藤千英が直接指導するローフード・発酵・ローチョコレートの専門講座。</p>
    <a href="/#lessons" class="btn-green">講座一覧を見る</a>
  </section>

</Layout>
