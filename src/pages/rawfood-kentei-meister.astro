---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="ローフード教室 渋谷｜JLBA認定 資格取得・酵素料理・プラントベース｜&LAB TOKYO"
  description="東京・渋谷のローフードマイスター養成講座。JLBA認定・ELLE gourmet公認料理家・安藤千英が直接指導。2級・準1級・1級の3段階。対面／オンライン対応。最短3日で資格取得。"
  canonical="https://www.andlabtokyo.com/rawfood-kentei-meister"
>

<style>
/* ===== SHARED ===== */
.sec { padding: 6rem 2rem; }
.inner { max-width: 1060px; margin: 0 auto; }
.eyebrow {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #8C7A6A;
  display: block;
  margin-bottom: 0.8rem;
}
.rule { width: 32px; height: 1px; background: #8C7A6A; margin: 1.2rem 0 1.8rem; }

/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: #1A1715;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('https://static.wixstatic.com/media/857257_57641e1211764fd187c7ca8641660c39~mv2.jpg');
  background-size: cover;
  background-position: center 30%;
  opacity: 0.5;
}
.hero-content {
  position: relative;
  z-index: 2;
  padding: 0 5vw 7rem;
  max-width: 800px;
}
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  margin-bottom: 1.8rem;
}
.hero-badge {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.12em;
  color: rgba(250,245,236,0.65);
  border: 1px solid rgba(250,245,236,0.25);
  padding: 0.3rem 0.8rem;
}
.hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 1.2rem;
}
.hero h1 {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 200;
  color: #FAF5EC;
  line-height: 1.4;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}
.hero-tagline {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(0.9rem, 1.5vw, 1.1rem);
  color: rgba(250,245,236,0.5);
  letter-spacing: 0.08em;
  line-height: 2;
  margin-bottom: 2.5rem;
}
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-amber {
  display: inline-block;
  background: #C6A15B;
  color: #1A1715;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 0.9rem 2rem;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-amber:hover { background: #A8865A; }
.btn-ghost-light {
  display: inline-block;
  border: 1px solid rgba(250,245,236,0.3);
  color: rgba(250,245,236,0.75);
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  letter-spacing: 0.12em;
  padding: 0.85rem 1.8rem;
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost-light:hover { border-color: rgba(250,245,236,0.7); color: #FAF5EC; }

/* ===== ABOUT ===== */
.about-sec { background: #FAF9F6; }
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.about-img {
  aspect-ratio: 4/5;
  overflow: hidden;
  background: #E5E0DA;
}
.about-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.about-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.6rem, 2.5vw, 2.4rem);
  font-weight: 300;
  color: #1C1C1A;
  line-height: 1.5;
  margin-bottom: 0.6rem;
}
.about-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 15px;
  color: #5A5A58;
  line-height: 2.2;
  margin-bottom: 1.2rem;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 2px;
  margin-top: 3.5rem;
}
.stat-item {
  background: #fff;
  padding: 1.6rem 1rem;
  text-align: center;
  border: 1px solid rgba(28,28,26,0.05);
}
.stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem,3.5vw,3rem);
  font-weight: 600;
  color: #1C1C1A;
  display: block;
  line-height: 1;
  margin-bottom: 0.4rem;
}
.stat-label {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.1em;
  color: #8C7A6A;
}

/* ===== COURSE LEVELS ===== */
.levels-sec { background: #1C1C1A; }
.levels-sec .eyebrow { color: #A8865A; }
.levels-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem,2.5vw,2.2rem);
  font-weight: 300;
  color: #FAF5EC;
  line-height: 1.5;
  margin-bottom: 0.6rem;
}
.levels-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 2px;
  margin-top: 3rem;
}
.level-card {
  background: #24211E;
  padding: 2.5rem 2rem;
  border-bottom: 2px solid transparent;
  transition: border-color 0.2s, background 0.2s;
}
.level-card:hover { background: #2C2926; border-bottom-color: #C6A15B; }
.level-tag {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.6rem;
}
.level-name {
  font-family: 'Noto Serif JP', serif;
  font-size: 1.3rem;
  font-weight: 400;
  color: #FAF5EC;
  margin-bottom: 1rem;
  line-height: 1.5;
}
.level-desc {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  color: rgba(250,245,236,0.6);
  line-height: 1.9;
  margin-bottom: 1.4rem;
}
.level-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 600;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.2rem;
}
.level-price-note {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  color: rgba(250,245,236,0.35);
  letter-spacing: 0.05em;
  display: block;
  margin-bottom: 1.4rem;
}
.level-features {
  list-style: none;
  margin-bottom: 1.8rem;
}
.level-features li {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  color: rgba(250,245,236,0.55);
  padding: 0.35rem 0;
  border-bottom: 1px solid rgba(250,245,236,0.06);
  letter-spacing: 0.04em;
}
.level-features li::before { content: '✓ '; color: #C6A15B; }
.btn-apply {
  display: block;
  width: 100%;
  text-align: center;
  background: transparent;
  border: 1px solid rgba(198,161,91,0.4);
  color: #C6A15B;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  letter-spacing: 0.15em;
  padding: 0.75rem;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.btn-apply:hover { background: #C6A15B; color: #1A1715; }

/* ===== SET PRICING ===== */
.set-band {
  background: #110E0B;
  padding: 3rem 2rem;
  margin-top: 2px;
}
.set-inner {
  max-width: 1060px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
}
.set-card {
  background: #1A1715;
  padding: 2rem 2rem;
  border: 1px solid rgba(198,161,91,0.12);
}
.set-tag {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #A8865A;
  display: block;
  margin-bottom: 0.5rem;
}
.set-name {
  font-family: 'Noto Serif JP', serif;
  font-size: 1rem;
  color: #FAF5EC;
  margin-bottom: 0.6rem;
}
.set-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.2rem;
}
.set-orig {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  color: rgba(250,245,236,0.3);
  text-decoration: line-through;
  letter-spacing: 0.04em;
}
.set-desc {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  color: rgba(250,245,236,0.5);
  line-height: 1.8;
  margin-top: 0.6rem;
  margin-bottom: 1.2rem;
}

/* ===== REASONS ===== */
.reasons-sec { background: #F5F3EE; }
.reasons-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 2px;
  margin-top: 2.5rem;
}
.reason-item {
  background: #fff;
  padding: 2rem 1.8rem;
  border-bottom: 2px solid transparent;
  transition: border-color 0.2s;
}
.reason-item:hover { border-bottom-color: #C6A15B; }
.reason-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 600;
  color: rgba(198,161,91,0.35);
  display: block;
  margin-bottom: 0.6rem;
  line-height: 1;
}
.reason-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 1rem;
  font-weight: 600;
  color: #1C1C1A;
  margin-bottom: 0.6rem;
  line-height: 1.5;
}
.reason-body {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  color: #6A6A68;
  line-height: 1.9;
}

/* ===== CURRICULUM ===== */
.curriculum-sec { background: #FAF9F6; }
.tab-btns {
  display: flex;
  gap: 2px;
  margin-bottom: 2rem;
}
.tab-btn {
  flex: 1;
  padding: 0.8rem 1rem;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  letter-spacing: 0.08em;
  color: #6A6A68;
  background: #E8E5DF;
  border: none;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  text-align: center;
}
.tab-btn.active, .tab-btn:hover { background: #1C1C1A; color: #FAF5EC; }
.tab-panel { display: none; }
.tab-panel.active { display: block; }
.curriculum-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}
.curriculum-img {
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #E5E0DA;
}
.curriculum-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.curri-level {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #C6A15B;
  display: block;
  margin-bottom: 0.6rem;
}
.curri-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 1.4rem;
  font-weight: 400;
  color: #1C1C1A;
  margin-bottom: 1rem;
  line-height: 1.5;
}
.curri-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  color: #5A5A58;
  line-height: 2.1;
  margin-bottom: 1.6rem;
}
.recipe-list-title {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #8C7A6A;
  margin-bottom: 0.8rem;
}
.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.6rem;
}
.recipe-tag {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  color: #5A5A58;
  background: #F0EDE8;
  padding: 0.3rem 0.8rem;
  letter-spacing: 0.04em;
}
.target-list {
  list-style: none;
  margin-bottom: 1.8rem;
}
.target-list li {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  color: #5A5A58;
  padding: 0.4rem 0;
  border-bottom: 1px solid rgba(28,28,26,0.06);
}
.target-list li::before { content: '✓ '; color: #C6A15B; font-weight: 700; }

/* ===== INSTRUCTOR ===== */
.instructor-sec { background: #1C1C1A; padding: 6rem 2rem; }
.instructor-inner {
  max-width: 1060px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}
.instructor-img {
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #24211E;
}
.instructor-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
.instructor-eyebrow { color: #A8865A; }
.instructor-name {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem,2.5vw,2.2rem);
  font-weight: 300;
  color: #FAF5EC;
  margin-bottom: 0.3rem;
}
.instructor-name-en {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-style: italic;
  color: #C6A15B;
  display: block;
  margin-bottom: 1.2rem;
}
.instructor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.6rem;
}
.instructor-tag {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 10px;
  color: #A8865A;
  border: 1px solid rgba(168,134,90,0.35);
  padding: 0.3rem 0.8rem;
  letter-spacing: 0.05em;
}
.instructor-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  color: rgba(250,245,236,0.65);
  line-height: 2.1;
  margin-bottom: 1rem;
}
.instructor-note {
  background: #24211E;
  border-left: 2px solid #C6A15B;
  padding: 1.2rem 1.5rem;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  color: rgba(250,245,236,0.5);
  line-height: 1.9;
  margin-top: 1.5rem;
  letter-spacing: 0.04em;
}

/* ===== TESTIMONIALS ===== */
.testi-sec { background: #F5F3EE; }
.testi-grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 2px;
  margin-top: 2.5rem;
}
.testi-card {
  background: #fff;
  padding: 2rem 2rem;
}
.testi-age {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.25em;
  color: #8C7A6A;
  display: block;
  margin-bottom: 0.8rem;
  text-transform: uppercase;
}
.testi-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  color: #3C3C3A;
  line-height: 2;
}

/* ===== EXAM ===== */
.exam-sec { background: #FAF9F6; }
.exam-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.2rem,2vw,1.6rem);
  font-weight: 400;
  color: #1C1C1A;
  margin-bottom: 1.5rem;
}
.exam-body {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 13px;
  color: #5A5A58;
  line-height: 2;
  margin-bottom: 2rem;
  max-width: 720px;
}
.exam-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 2rem;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
}
.exam-table th {
  background: #1C1C1A;
  color: rgba(250,249,246,0.75);
  text-align: left;
  padding: 0.8rem 1.2rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  width: 160px;
}
.exam-table td {
  background: #fff;
  color: #5A5A58;
  padding: 0.8rem 1.2rem;
  border-bottom: 1px solid rgba(28,28,26,0.06);
  line-height: 1.8;
}
.exam-table tr:last-child td { border-bottom: none; }
.btn-exam {
  display: inline-block;
  border: 1px solid rgba(28,28,26,0.2);
  color: #1C1C1A;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 12px;
  letter-spacing: 0.12em;
  padding: 0.75rem 2rem;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.btn-exam:hover { background: #1C1C1A; color: #FAF9F6; }

/* ===== CTA ===== */
.cta-sec {
  background: url('https://static.wixstatic.com/media/857257_71e778c96dc949e5ac55fa8c0489b4ef~mv2.jpg') center/cover no-repeat;
  position: relative;
  padding: 8rem 2rem;
  text-align: center;
}
.cta-sec::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(26,23,21,0.72);
}
.cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
.cta-eyebrow { color: #A8865A; }
.cta-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(1.5rem,2.5vw,2.2rem);
  font-weight: 200;
  color: #FAF5EC;
  line-height: 1.5;
  margin-bottom: 0.8rem;
}
.cta-body {
  font-family: 'Noto Serif JP', serif;
  font-size: 14px;
  color: rgba(250,245,236,0.6);
  line-height: 2;
  margin-bottom: 2.5rem;
}

/* ===== APPLICATION FORM ===== */
.form-sec { background: #FAF9F6; }
.form-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 1.3rem;
  font-weight: 400;
  color: #1C1C1A;
  margin-bottom: 2rem;
  text-align: center;
}
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  max-width: 680px;
  margin: 0 auto;
}
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-group.full { grid-column: 1/-1; }
.form-label {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  letter-spacing: 0.1em;
  color: #6A6A68;
}
.form-label .req { color: #C6A15B; margin-left: 2px; }
.form-input, .form-select, .form-textarea {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 13px;
  color: #1C1C1A;
  background: #fff;
  border: 1px solid rgba(28,28,26,0.15);
  padding: 0.65rem 0.9rem;
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: #C6A15B;
}
.form-textarea { height: 100px; resize: vertical; }
.form-submit {
  display: block;
  width: 100%;
  max-width: 680px;
  margin: 1.5rem auto 0;
  padding: 1rem;
  background: #1C1C1A;
  color: #FAF5EC;
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.15em;
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}
.form-submit:hover { background: #3C3C3A; }
.form-note {
  font-family: 'Noto Sans JP', sans-serif;
  font-size: 11px;
  color: #8C8C8A;
  line-height: 1.8;
  text-align: center;
  margin-top: 1.5rem;
  max-width: 680px;
  margin-left: auto;
  margin-right: auto;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .about-grid { grid-template-columns: 1fr; gap: 3rem; }
  .levels-grid { grid-template-columns: 1fr; }
  .set-inner { grid-template-columns: 1fr; }
  .reasons-grid { grid-template-columns: 1fr 1fr; }
  .curriculum-inner { grid-template-columns: 1fr; gap: 2rem; }
  .instructor-inner { grid-template-columns: 1fr; gap: 2rem; }
  .testi-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: repeat(2,1fr); }
}
@media (max-width: 600px) {
  .hero-content { padding: 0 1.5rem 5rem; }
  .sec { padding: 4rem 1.5rem; }
  .reasons-grid { grid-template-columns: 1fr; }
  .form-grid { grid-template-columns: 1fr; }
  .tab-btns { flex-direction: column; }
}
</style>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-badges">
      <span class="hero-badge">✓ 日本発ローフード教育</span>
      <span class="hero-badge">✓ 対面 / オンライン対応</span>
      <span class="hero-badge">✓ 世界中から受講</span>
    </div>
    <span class="hero-sub">Raw Food Meister Certification</span>
