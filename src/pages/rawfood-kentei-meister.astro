---
const title = "ローフードマイスター資格・検定講座 | &LAB TOKYO 東京・渋谷";
const description = "東京・渋谷（原宿・外苑前）のプレミアムスクール&LAB TOKYOによるローフードマイスター資格取得コース。2級〜1級・認定講師養成。ELLE gourmet公認。医師監修・少人数制。対面/オンライン対応。";
const url = "https://www.andlabtokyo.com/rawfood-kentei-meister";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <link rel="icon" href="/favicon.ico" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "ローフードマイスター資格・検定講座",
    "description": "東京・渋谷のプレミアムスクール&LAB TOKYOによる、ローフード（リビングフード）の資格取得から認定講師養成まで。ELLE gourmet公認。医師監修カリキュラム。",
    "url": url,
    "provider": {
      "@type": "EducationalOrganization",
      "name": "&LAB TOKYO",
      "url": "https://www.andlabtokyo.com/",
      "address": { "@type": "PostalAddress", "addressLocality": "渋谷区", "addressRegion": "東京都", "addressCountry": "JP" }
    },
    "instructor": { "@type": "Person", "name": "安藤千英" },
    "courseMode": ["onsite", "online"],
    "inLanguage": "ja",
    "image": "https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg"
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --linen:#FBFBFA; --linen-2:#F4F2EE; --linen-3:#EAE7E0;
      --sumi:#1C1C1A;  --sumi-2:#2A2A27;
      --ink:#1C1C1A;   --ink-2:#3D3D38;  --ink-3:#7A7A72;
      --green:#A9D159; --green-d:#7AAF2A;
      --f-serif:'Noto Serif JP',serif; --f-sans:'Noto Sans JP',sans-serif;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--f-sans);background:var(--linen);color:var(--ink);line-height:1.8;-webkit-font-smoothing:antialiased;}
    nav{position:fixed;inset:0 0 auto 0;z-index:500;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;background:rgba(28,28,26,.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(244,242,238,.06);}
    .nav-logo img{height:32px;mix-blend-mode:screen;filter:brightness(1.1);}
    .nav-links{display:flex;list-style:none;}
    .nav-links a{font-size:.8rem;color:rgba(244,242,238,.55);text-decoration:none;padding:0 1rem;letter-spacing:.04em;transition:color .2s;}
    .nav-links a:hover,.nav-links a.active{color:var(--green);}
    .nav-right{display:flex;align-items:center;}
    .nav-cta{font-size:.8rem;font-weight:700;display:inline-block;background:transparent;color:rgba(244,242,238,.6);padding:.4rem 1.2rem;margin-left:1rem;text-decoration:none;border:1px solid rgba(244,242,238,.2);letter-spacing:.06em;transition:all .2s;}
    .nav-cta:hover{color:#FAF5EC;border-color:rgba(244,242,238,.5);}

    /* HERO */
    .hero{margin-top:52px;position:relative;height:88vh;min-height:560px;overflow:hidden;display:flex;align-items:flex-end;}
    .hero img.bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,12,10,.97) 0%,rgba(12,12,10,.42) 50%,rgba(12,12,10,.1) 100%);}
    .hero-content{position:relative;z-index:2;padding:0 6vw 9vh;max-width:700px;}
    .hero-eye{font-family:var(--f-sans);font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(244,242,238,.25);display:block;margin-bottom:2.5rem;}
    .hero h1{font-family:var(--f-serif);font-size:clamp(1.9rem,4vw,3.4rem);font-weight:200;letter-spacing:.18em;color:#FAF5EC;line-height:1.3;margin-bottom:1.8rem;}
    .hero-sub{font-family:var(--f-serif);font-size:.95rem;font-weight:300;color:rgba(244,242,238,.38);letter-spacing:.1em;line-height:2.3;margin-bottom:3.5rem;max-width:480px;}
    .hero-credentials{display:flex;flex-wrap:wrap;gap:.8rem;margin-bottom:3.5rem;}
    .hero-cred{font-family:var(--f-sans);font-size:.65rem;letter-spacing:.12em;color:rgba(244,242,238,.3);border:1px solid rgba(244,242,238,.1);padding:.3rem .9rem;}
    .btn-ghost{display:inline-block;font-family:var(--f-serif);font-size:.82rem;font-weight:300;letter-spacing:.2em;color:rgba(244,242,238,.6);text-decoration:none;border:1px solid rgba(244,242,238,.18);padding:1.1rem 3rem;transition:all .4s;}
    .btn-ghost:hover{color:#FAF5EC;border-color:rgba(244,242,238,.5);}

    /* GEO BAND */
    .geo-band{background:var(--sumi-2);padding:3rem 3rem;border-left:3px solid rgba(169,209,89,.35);}
    .geo-band p{font-family:var(--f-serif);font-size:.98rem;font-weight:300;color:rgba(244,242,238,.68);line-height:2.3;letter-spacing:.06em;margin:0;max-width:880px;}

    /* BREADCRUMB */
    .bc-bar{background:var(--linen-2);padding:.85rem 3rem;border-bottom:1px solid var(--linen-3);}
    .bc{font-size:.74rem;color:var(--ink-3);max-width:1100px;margin:0 auto;}
    .bc a{color:var(--ink-3);text-decoration:none;}
    .bc span{margin:0 .4rem;}

    /* COURSE STEPS */
    .courses-sec{padding:10rem 3rem;background:var(--linen);}
    .courses-inner{max-width:1100px;margin:0 auto;}
    .sec-eye{font-family:var(--f-sans);font-size:.62rem;letter-spacing:.26em;text-transform:uppercase;color:var(--ink-3);display:block;margin-bottom:1.4rem;}
    .sec-h2{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:300;letter-spacing:.14em;color:var(--ink);margin-bottom:5rem;line-height:1.4;}
    .step-list{display:flex;flex-direction:column;gap:0;}
    .step{display:grid;grid-template-columns:200px 1fr;gap:0;border-top:1px solid var(--linen-3);}
    .step:last-child{border-bottom:1px solid var(--linen-3);}
    .step-left{padding:3.5rem 2rem 3.5rem 0;border-right:1px solid var(--linen-3);}
    .step-level{font-family:var(--f-serif);font-size:.7rem;font-weight:300;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-3);display:block;margin-bottom:.6rem;}
    .step-name{font-family:var(--f-serif);font-size:.95rem;font-weight:600;letter-spacing:.08em;color:var(--ink);line-height:1.55;}
    .step-right{padding:3.5rem 0 3.5rem 4rem;display:flex;flex-direction:column;gap:1.4rem;}
    .step-desc{font-size:.9rem;color:var(--ink-2);line-height:2.1;}
    .step-meta{display:flex;gap:3rem;flex-wrap:wrap;}
    .step-meta-item{display:flex;flex-direction:column;gap:.3rem;}
    .step-meta-label{font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);}
    .step-meta-val{font-family:var(--f-serif);font-size:.88rem;color:var(--ink);}

    /* DIVIDER IMAGE */
    .img-div{position:relative;height:55vh;min-height:320px;overflow:hidden;}
    .img-div img{width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;}
    .img-div-overlay{position:absolute;inset:0;background:rgba(12,12,10,.35);display:flex;align-items:center;justify-content:center;}
    .img-div-text p{font-family:var(--f-serif);font-size:clamp(1.3rem,2.5vw,2rem);font-weight:200;letter-spacing:.22em;color:rgba(244,242,238,.8);text-align:center;line-height:1.7;}

    /* CREDENTIALS */
    .cred-sec{background:var(--linen-2);padding:10rem 3rem;}
    .cred-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:8rem;align-items:start;}
    .cred-inner h2{font-family:var(--f-serif);font-size:clamp(1.4rem,2.2vw,2rem);font-weight:300;letter-spacing:.14em;color:var(--ink);margin-bottom:4rem;grid-column:1/-1;line-height:1.4;}
    .cred-list{display:flex;flex-direction:column;gap:2.5rem;}
    .cred-item{border-top:1px solid var(--linen-3);padding-top:2rem;}
    .cred-num{font-family:var(--f-serif);font-size:.7rem;font-weight:300;letter-spacing:.14em;color:var(--ink-3);display:block;margin-bottom:.7rem;}
    .cred-item h4{font-family:var(--f-serif);font-size:.98rem;font-weight:600;letter-spacing:.06em;color:var(--ink);margin-bottom:.5rem;}
    .cred-item p{font-size:.86rem;color:var(--ink-3);line-height:2;}
    .testi-block{background:var(--linen);padding:3rem;border-left:2px solid var(--linen-3);}
    .testi-q{font-family:var(--f-serif);font-size:.95rem;font-weight:300;color:var(--ink-2);line-height:2.2;margin-bottom:1.4rem;letter-spacing:.04em;}
    .testi-name{font-family:var(--f-serif);font-size:.88rem;font-weight:600;color:var(--ink);display:block;margin-bottom:.2rem;}
    .testi-role{font-size:.76rem;color:var(--ink-3);}

    /* 1DAY体験 */
    .oneday-sec{background:var(--sumi);padding:11rem 3rem;text-align:center;}
    .oneday-inner{max-width:640px;margin:0 auto;}
    .oneday-inner h2{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:300;letter-spacing:.16em;color:#FAF5EC;line-height:1.55;margin-bottom:2.5rem;}
    .oneday-rule{width:28px;height:1px;background:rgba(244,242,238,.1);margin:2.5rem auto;}
    .oneday-inner p{font-family:var(--f-serif);font-size:.95rem;font-weight:300;color:rgba(244,242,238,.42);line-height:2.4;letter-spacing:.06em;margin-bottom:1.4rem;}
    .oneday-price{font-family:var(--f-serif);font-size:2rem;font-weight:200;color:#FAF5EC;letter-spacing:.1em;display:block;margin:3rem 0 .5rem;}
    .oneday-note{font-size:.73rem;color:rgba(244,242,238,.2);letter-spacing:.1em;display:block;margin-bottom:3.5rem;}
    .btn-outline-light{display:inline-block;font-family:var(--f-serif);font-size:.82rem;font-weight:300;letter-spacing:.2em;color:rgba(244,242,238,.55);text-decoration:none;border:1px solid rgba(244,242,238,.16);padding:1.1rem 3rem;transition:all .4s;}
    .btn-outline-light:hover{color:#FAF5EC;border-color:rgba(244,242,238,.45);}
    .oneday-footnote{font-size:.76rem;color:rgba(244,242,238,.18);margin-top:1.8rem;line-height:2;font-style:italic;}

    footer{background:var(--sumi);padding:3rem;text-align:center;border-top:1px solid rgba(244,242,238,.04);}
    .footer-logo img{height:26px;mix-blend-mode:screen;filter:brightness(1.1);margin-bottom:.7rem;}
    .footer-copy{font-size:.68rem;color:rgba(244,242,238,.14);}

    @media(max-width:960px){
      nav{padding:0 1.5rem;}
      .nav-links{display:none;}
      .hero{height:80vh;}
      .hero-content{padding:0 1.5rem 6vh;}
      .geo-band,.bc-bar,.courses-sec,.cred-sec,.oneday-sec{padding:4rem 1.5rem;}
      .step{grid-template-columns:1fr;}
      .step-left{border-right:none;border-bottom:1px solid var(--linen-3);padding:2rem 0;}
      .step-right{padding:2rem 0;}
      .cred-inner{grid-template-columns:1fr;gap:0;}
      .cred-inner h2{grid-column:1;}
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo"><img src="/logo-wide.png" alt="&LAB TOKYO" /></a>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="/listofcourses">講座一覧</a></li>
        <li><a href="/rawfood-kentei-meister" class="active">ローフード</a></li>
        <li><a href="/fermentedfood">発酵</a></li>
        <li><a href="/rawchocolatier">ローショコラティエ</a></li>
        <li><a href="/knowledge">学ぶ</a></li>
      </ul>
      <a href="/contact" class="nav-cta">CONTACT</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img src="https://static.wixstatic.com/media/857257_0bda58f50f72486a8707583f068b87f1~mv2.jpg" alt="ローフードマイスター資格講座 東京・渋谷" class="bg" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="hero-eye">Raw Food Meister · &LAB TOKYO · Tokyo Shibuya</span>
      <h1>ローフードで、<br />細胞から整える。</h1>
      <p class="hero-sub">
        酵素・ビタミン・ミネラルを生きたまま摂取する食の哲学。<br />
        48℃以下の調理が解き放つ、本来の生命力。
      </p>
      <div class="hero-credentials">
        <span class="hero-cred">日本リビングビューティー協会 公認</span>
        <span class="hero-cred">ELLE gourmet 公認</span>
        <span class="hero-cred">医師監修カリキュラム</span>
        <span class="hero-cred">対面（渋谷）/ オンライン</span>
      </div>
      <a href="#courses" class="btn-ghost">資格コースを見る</a>
    </div>
  </section>

  <!-- GEO定義バンド -->
  <div class="geo-band">
    <p>ローフードマイスター資格とは、植物性の食材を48℃以下で扱う「ローフード（リビングフード）」の理論・技術・実践力を体系的に認定する資格です。&LAB TOKYOは、東京・渋谷（原宿・外苑前エリア）を拠点に、ELLE gourmet公認・医師監修カリキュラムに基づく少人数制の本格ローフードマイスター資格講座を提供しています。東京でローフード資格・検定を学ぶなら&LAB TOKYOへ。</p>
  </div>

  <div class="bc-bar">
    <nav class="bc" aria-label="パンくずリスト">
      <a href="/">HOME</a><span>›</span>
      <a href="/listofcourses">講座一覧</a><span>›</span>
      <span>ローフードマイスター資格</span>
    </nav>
  </div>

  <!-- COURSE STEPS -->
  <section class="courses-sec" id="courses">
    <div class="courses-inner">
      <span class="sec-eye">Certification Courses</span>
      <h2>ローフードマイスター<br />資格取得コース</h2>

      <div class="step-list">

        <div class="step">
          <div class="step-left">
            <span class="step-level">Step 1 · Foundation</span>
            <span class="step-name">ローフードマイスター<br />2級（初級）</span>
          </div>
          <div class="step-right">
            <p class="step-desc">ローフードの基礎理論から実践まで。食物酵素とは何か、なぜ48℃以下で調理するのか。美しいビジュアルのローフード料理を8品習得します。食の知識・料理経験は不問。</p>
            <div class="step-meta">
              <div class="step-meta-item">
                <span class="step-meta-label">受講形式</span>
                <span class="step-meta-val">対面（渋谷）/ オンライン</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">対象</span>
                <span class="step-meta-val">食に興味のある全ての方</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">取得資格</span>
                <span class="step-meta-val">ローフードマイスター2級</span>
              </div>
            </div>
            <div><a href="/contact" style="font-family:var(--f-serif);font-size:.82rem;letter-spacing:.12em;color:var(--ink-3);text-decoration:none;border-bottom:1px solid var(--linen-3);padding-bottom:.3rem;transition:all .2s;">詳細・お申し込み →</a></div>
          </div>
        </div>

        <div class="step">
          <div class="step-left">
            <span class="step-level">Step 2 · Intermediate</span>
            <span class="step-name">ローフードマイスター<br />準1級（中級）</span>
          </div>
          <div class="step-right">
            <p class="step-desc">2級修了者向け。発酵×ローフードのクロス理論を実践に繋げる中級編。腸内環境と細胞の両面から体を整える理論を深め、人に伝えられる知識と技術を習得します。</p>
            <div class="step-meta">
              <div class="step-meta-item">
                <span class="step-meta-label">受講形式</span>
                <span class="step-meta-val">対面（渋谷）/ オンライン</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">前提</span>
                <span class="step-meta-val">2級修了</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">取得資格</span>
                <span class="step-meta-val">ローフードマイスター準1級</span>
              </div>
            </div>
            <div><a href="/contact" style="font-family:var(--f-serif);font-size:.82rem;letter-spacing:.12em;color:var(--ink-3);text-decoration:none;border-bottom:1px solid var(--linen-3);padding-bottom:.3rem;transition:all .2s;">詳細・お申し込み →</a></div>
          </div>
        </div>

        <div class="step">
          <div class="step-left">
            <span class="step-level">Step 3 · Professional</span>
            <span class="step-name">ローフードマイスター<br />1級・認定講師養成</span>
          </div>
          <div class="step-right">
            <p class="step-desc">独立・開業・講師活動を目指す最終ステップ。循環器内科医・吉田和弘医師もほぼ満点で合格した本格カリキュラム。認定後は自身の名でローフード講座を開催できます。</p>
            <div class="step-meta">
              <div class="step-meta-item">
                <span class="step-meta-label">受講形式</span>
                <span class="step-meta-val">対面（渋谷・外苑前）/ オンライン</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">前提</span>
                <span class="step-meta-val">2級・準1級修了</span>
              </div>
              <div class="step-meta-item">
                <span class="step-meta-label">取得資格</span>
                <span class="step-meta-val">ローフードマイスター1級（認定講師）</span>
              </div>
            </div>
            <div><a href="/contact" style="font-family:var(--f-serif);font-size:.82rem;letter-spacing:.12em;color:var(--ink-3);text-decoration:none;border-bottom:1px solid var(--linen-3);padding-bottom:.3rem;transition:all .2s;">詳細・お申し込み →</a></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FULL IMAGE DIVIDER -->
  <div class="img-div">
    <img src="https://static.wixstatic.com/media/IMG_4698.JPG" alt="生きた食の静寂" />
    <div class="img-div-overlay">
      <div class="img-div-text">
        <p>食は、静かに<br />細胞を変えていく。</p>
      </div>
    </div>
  </div>

  <!-- CREDENTIALS + TESTIMONIALS -->
  <section class="cred-sec">
    <div class="cred-inner">
      <h2>信頼の根拠がある、<br />スクールを選ぶ。</h2>

      <div class="cred-list">
        <div class="cred-item">
          <span class="cred-num">Credential 01</span>
          <h4>ELLE gourmet 認定クリエイター</h4>
          <p>フランス発のプレミアム食専門誌に認定。日本でも数少ない料理家として掲載。</p>
        </div>
        <div class="cred-item">
          <span class="cred-num">Credential 02</span>
          <h4>医師監修書籍「&RAW LIVING」著者</h4>
          <p>循環器内科医・吉田和弘医師の監修のもと出版。医学的根拠に基づくカリキュラム。</p>
        </div>
        <div class="cred-item">
          <span class="cred-num">Credential 03</span>
          <h4>医師・経営者・海外プロが受講</h4>
          <p>複数の医師が資格取得。米・メキシコ・香港など海外からも受講者が来日する品質。</p>
        </div>
        <div class="cred-item">
          <span class="cred-num">Credential 04</span>
          <h4>東京・渋谷 少人数制プライベート</h4>
          <p>1〜4名の完全少人数制。東京・渋谷（原宿・外苑前エリア）の静謐なラボで、安藤千英が直接指導。</p>
        </div>
      </div>

