---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>お問い合わせ | &LAB TOKYO</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root { --bg: #1A1715; --txt: #F3EEE5; --txth: #FAF5EC; --txts: #C0B6A8; --cta: #C6A15B; --ctat: #221C17; --div: rgba(243,238,229,.12); }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Noto Sans JP', sans-serif; background: var(--bg); color: var(--txt); min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 1.5rem; -webkit-font-smoothing: antialiased; }
    nav { position: fixed; top: 0; left: 0; right: 0; height: 66px; display: flex; align-items: center; padding: 0 2.5rem; background: rgba(26,23,21,.93); border-bottom: 1px solid var(--div); }
    nav a { color: var(--cta); text-decoration: none; font-weight: 700; font-size: 1rem; }
    .wrap { max-width: 560px; width: 100%; text-align: center; }
    .eye { font-size: .72rem; letter-spacing: 4px; text-transform: uppercase; color: var(--cta); margin-bottom: 1.2rem; display: block; }
    h1 { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; color: var(--txth); margin-bottom: 2rem; }
    .desc { font-size: .95rem; color: var(--txt); line-height: 2; margin-bottom: 3rem; }
    form { display: flex; flex-direction: column; gap: 1.2rem; text-align: left; }
    label { font-size: .85rem; font-weight: 500; color: var(--txts); margin-bottom: .3rem; display: block; }
    input, textarea, select {
      width: 100%; padding: .85rem 1rem;
      background: #24211E; border: 1px solid var(--div);
      color: var(--txt); font-family: 'Noto Sans JP', sans-serif;
      font-size: .95rem; border-radius: 2px; outline: none;
      transition: border-color .2s;
    }
    input:focus, textarea:focus, select:focus { border-color: var(--cta); }
    textarea { min-height: 140px; resize: vertical; }
    .submit {
      display: inline-block; padding: 1rem 2.5rem;
      background: var(--cta); color: var(--ctat);
      font-size: .95rem; font-weight: 700;
      border: none; border-radius: 2px; cursor: pointer;
      transition: background .2s; width: 100%;
    }
    .submit:hover { background: #D4B06A; }
    .note { font-size: .78rem; color: var(--txts); margin-top: .8rem; text-align: center; }
    .back { display: inline-block; margin-top: 2rem; font-size: .85rem; color: var(--txts); text-decoration: none; }
    .back:hover { color: var(--cta); }
  </style>
</head>
<body>
  <nav><a href="/">← &LAB TOKYO</a></nav>
  <div class="wrap">
    <span class="eye">Contact</span>
    <h1>お問い合わせ</h1>
    <p class="desc">体験レッスンのご予約・ご質問はこちらからどうぞ。<br />3日以内にご返信いたします。</p>
    <form action="https://formspree.io/f/info@andlabtokyo.com" method="POST">
      <div>
        <label>お名前 *</label>
        <input type="text" name="name" required placeholder="山田 花子" />
      </div>
      <div>
        <label>メールアドレス *</label>
        <input type="email" name="email" required placeholder="example@email.com" />
      </div>
      <div>
        <label>ご興味のあるプログラム</label>
        <select name="program">
          <option value="">選択してください</option>
          <option value="rawfood">ローフード 体験レッスン</option>
          <option value="hacco">Hacco LAB（発酵）体験レッスン</option>
          <option value="chocolate">ローチョコレート 体験レッスン</option>
          <option value="other">その他・未定</option>
        </select>
      </div>
      <div>
        <label>ご質問・ご要望</label>
        <textarea name="message" placeholder="お気軽にご記入ください"></textarea>
      </div>
      <button type="submit" class="submit">送信する</button>
      <p class="note">入会費・登録費は一切ありません</p>
    </form>
    <a href="/" class="back">← TOPに戻る</a>
  </div>
</body>
</html>
