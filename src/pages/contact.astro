---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="お問い合わせ・体験レッスン予約 | &LAB TOKYO"
  canonical="https://www.andlabtokyo.com/contact"
>

<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    
    
    
    .page{padding-top:52px;display:grid;grid-template-columns:1fr 1fr;min-height:calc(100vh - 52px);}
    .page-left{background:var(--sumi);padding:6rem 5vw;display:flex;flex-direction:column;justify-content:center;position:sticky;top:52px;height:calc(100vh - 52px);overflow:hidden;}
    .page-left::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 60%,rgba(169,209,89,.06) 0%,transparent 65%);}
    .left-content{position:relative;z-index:1;}
    .left-eye{font-family:var(--f-sans);font-size:.72rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--green);display:block;margin-bottom:1.4rem;}
    .left-h1{font-family:var(--f-serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:400;letter-spacing:.1em;color:#F4F2EE;line-height:1.6;margin-bottom:1.4rem;}
    .left-rule{width:28px;height:1px;background:rgba(244,242,238,.2);margin:1.8rem 0;}
    .left-desc{font-size:.9rem;color:rgba(244,242,238,.5);line-height:2;margin-bottom:2.5rem;}
    .left-meta{display:flex;flex-direction:column;gap:.8rem;}
    .left-meta-item{display:flex;gap:.8rem;align-items:center;font-size:.82rem;color:rgba(244,242,238,.45);}
    .left-meta-item::before{content:'—';color:var(--green);flex-shrink:0;}
    .page-right{background:var(--linen);padding:5rem 4vw 4rem;}
    .form-wrap{max-width:520px;margin:0 auto;}
    .form-title{font-family:var(--f-serif);font-size:1.5rem;font-weight:400;letter-spacing:.08em;color:var(--ink);margin-bottom:.6rem;}
    .form-sub{font-size:.88rem;color:var(--ink-3);margin-bottom:3rem;line-height:1.8;}
    form{display:flex;flex-direction:column;gap:1.4rem;}
    .field{display:flex;flex-direction:column;gap:.5rem;}
    label{font-size:.8rem;font-weight:500;color:var(--ink-2);letter-spacing:.04em;}
    label .req{color:var(--green-d);margin-left:3px;}
    input[type="text"],input[type="email"],input[type="tel"],textarea,select{width:100%;padding:.85rem 1rem;background:var(--linen-2);border:1px solid var(--divider);border-radius:0;color:var(--ink);font-family:var(--f-sans);font-size:.92rem;outline:none;transition:border-color .2s,background .2s;-webkit-appearance:none;}
    input:focus,textarea:focus,select:focus{border-color:var(--green-d);background:#fff;}
    textarea{min-height:130px;resize:vertical;}
    .program-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-top:.4rem;}
    .program-item{display:flex;align-items:center;gap:.6rem;background:var(--linen-2);border:1px solid var(--divider);padding:.75rem 1rem;cursor:pointer;transition:border-color .2s,background .2s;font-size:.85rem;color:var(--ink-2);}
    .program-item:hover{border-color:var(--green-d);background:#fff;}
    .program-item input[type="checkbox"]{width:15px;height:15px;border:1px solid var(--divider);background:transparent;padding:0;flex-shrink:0;accent-color:var(--green-d);}
    /* ━━ メルマガチェックボックス ━━
       将来: name="newsletter" value="yes" を参照して
       Brevo/Mailchimp APIでリスト自動登録を実装すること */
    .newsletter-field{margin-top:.4rem;padding:1.2rem;background:rgba(169,209,89,.06);border:1px solid rgba(169,209,89,.2);}
    .newsletter-label{display:flex;align-items:flex-start;gap:.8rem;cursor:pointer;font-size:.88rem;color:var(--ink-2);line-height:1.6;}
    .newsletter-label input[type="checkbox"]{width:16px;height:16px;border:1px solid var(--divider);background:transparent;padding:0;flex-shrink:0;margin-top:2px;accent-color:var(--green-d);}
    .newsletter-label strong{color:var(--ink);font-weight:700;}
    .newsletter-note{margin-top:.6rem;font-size:.75rem;color:var(--ink-3);padding-left:24px;line-height:1.6;}
    .submit{width:100%;padding:1.1rem;background:var(--sumi);color:#F4F2EE;font-family:var(--f-sans);font-size:.9rem;font-weight:700;letter-spacing:.08em;border:none;border-radius:0;cursor:pointer;transition:background .2s;}
    .submit:hover{background:var(--sumi-2);}
    .form-note{font-size:.78rem;color:var(--ink-3);text-align:center;line-height:1.7;}
    .privacy-check{display:flex;align-items:flex-start;gap:.7rem;font-size:.82rem;color:var(--ink-3);line-height:1.6;cursor:pointer;}
    .privacy-check input[type="checkbox"]{width:15px;height:15px;padding:0;flex-shrink:0;margin-top:2px;accent-color:var(--green-d);}
    
    
    @media(max-width:768px){.page{grid-template-columns:1fr;}.page-left{position:static;height:auto;padding:4rem 1.5rem;}.page-right{padding:3rem 1.5rem;}.program-grid{grid-template-columns:1fr;}}
</style>

<div class="page">
    <div class="page-left">
      <div class="left-content">
        <span class="left-eye">LABへの入口</span>
        <h1 class="left-h1">まずは体験レッスンから、<br />&LAB TOKYOの世界へ。</h1>
        <div class="left-rule"></div>
        <p class="left-desc">ここは、単なる料理教室ではありません。<br />細胞から整える食の知恵と美意識に触れる、<br />あなた自身の再生への入口です。</p>
        <div class="left-meta">
          <div class="left-meta-item">神宮前、表参道、青山、千駄ヶ谷よりアクセス</div>
          <div class="left-meta-item">東京都渋谷区神宮前</div>
          <div class="left-meta-item">少人数制（1〜4名）</div>
          <div class="left-meta-item">¥8,000〜 入会費なし</div>
          <div class="left-meta-item">詳しいレッスン会場はお申し込み後にご案内いたします。</div>
          <div class="left-meta-item">3日以内にご返信いたします</div>
        </div>
      </div>
    </div>
    <div class="page-right">
      <div class="form-wrap">
        <h2 class="form-title">お問い合わせ</h2>
        <p class="form-sub">体験レッスンのご予約・ご質問はこちらからどうぞ。<br />内容を確認後、3日以内にご連絡いたします。</p>
        <form action="https://formspree.io/f/contact" method="POST">
          <div class="field">
            <label for="name">お名前<span class="req">*</span></label>
            <input type="text" id="name" name="name" required placeholder="山田 花子" />
          </div>
          <div class="field">
            <label for="email">メールアドレス<span class="req">*</span></label>
            <input type="email" id="email" name="email" required placeholder="example@email.com" />
          </div>
          <div class="field">
            <label for="tel">お電話番号（任意）</label>
            <input type="tel" id="tel" name="tel" placeholder="090-0000-0000" />
          </div>
          <div class="field">
            <label>ご興味のあるプログラム</label>
            <div class="program-grid">
              <label class="program-item"><input type="checkbox" name="program" value="rawfood" />🌿 ローフード</label>
              <label class="program-item"><input type="checkbox" name="program" value="fermentation" />🍶 発酵 / Hacco LAB</label>
              <label class="program-item"><input type="checkbox" name="program" value="raw-sweets" />🍫 ロースイーツ</label>
              <label class="program-item"><input type="checkbox" name="program" value="umami-lab" />✨ UMAMI &amp; KOJI LAB</label>
            </div>
          </div>
          <div class="field">
            <label for="format">ご希望の受講形式</label>
            <select id="format" name="format">
              <option value="">選択してください</option>
              <option value="tokyo-onsite">東京・渋谷（対面）</option>
              <option value="online">オンライン</option>
              <option value="either">どちらでも可</option>
            </select>
          </div>
          <div class="field">
            <label for="message">ご質問・ご要望（任意）</label>
            <textarea id="message" name="message" placeholder="ご自由にお書きください。体験レッスンの希望日程などもここに。"></textarea>
          </div>
          <!-- メルマガ登録 / 将来: name="newsletter" value="yes" でBrevo連携 -->
          <div class="field">
            <div class="newsletter-field">
              <label class="newsletter-label">
                <input type="checkbox" name="newsletter" value="yes" id="newsletter" />
                <span><strong>&LAB TOKYOからのお知らせを受け取る</strong><br />新しいレッスン情報・発酵×ローフードの知恵・安藤千英からのメッセージをメールでお届けします。</span>
              </label>
              <p class="newsletter-note">※ いつでも配信停止できます。迷惑メールは送りません。</p>
            </div>
          </div>
          <div class="field">
            <label class="privacy-check">
              <input type="checkbox" name="privacy" required />
              個人情報の取り扱いについて同意します。お問い合わせへの返信目的にのみ使用します。
            </label>
          </div>
          <button type="submit" class="submit">&LAB TOKYOの世界を体験する</button>
          <p class="form-note">3日以内にご返信いたします。<br />入会費・登録費は一切ありません。</p>
        </form>
      </div>
    </div>
  </div>

</Layout>
